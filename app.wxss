/* 全局样式 */
@import "styles/iconfont.wxss";

page {
  --primary: #1a1a2e;
  --primary-light: #2d2d4a;
  --accent: #e8a87c;
  --accent-light: #f0c4a8;
  --accent-gradient: linear-gradient(135deg, #e8a87c, #d4a574);
  --bg: #f5f5f7;
  --card-bg: #ffffff;
  --text-primary: #1a1a2e;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border: #eeeeee;
  --danger: #e74c3c;
  --success: #27ae60;
  --warm: #f39c12;
  --cool: #3498db;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--bg);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* 通用按钮 */
.btn-primary {
  background: var(--accent-gradient);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: transparent;
  color: var(--accent);
  border: 2rpx solid var(--accent);
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-outline::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-warm {
  background: rgba(232, 168, 124, 0.15);
  color: var(--accent);
}

.tag-cool {
  background: rgba(52, 152, 219, 0.15);
  color: var(--cool);
}

.tag-primary {
  background: rgba(26, 26, 46, 0.08);
  color: var(--primary);
}

/* 评分条 */
.score-bar {
  height: 12rpx;
  background: var(--border);
  border-radius: 6rpx;
  overflow: hidden;
}

.score-bar-inner {
  height: 100%;
  background: var(--accent-gradient);
  border-radius: 6rpx;
  transition: width 0.6s ease;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* 页面标题 */
.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 32rpx;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state .empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  color: var(--accent);
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}
