/* 全局样式 */
@import "styles/iconfont.wxss";

page {
  /* ============ 设计系统 v2 · 三段色 ============ */
  /* 主品牌色（樱粉）—— 全平台 CTA / 选中态 / 强调 */
  --brand: #F1849B;
  --brand-soft: #FFF0F4;
  --brand-deep: #D96A85;
  --brand-gradient: linear-gradient(135deg, #F1849B 0%, #FF9EB0 100%);

  /* 高级金（高价值时刻：报告、决策完成、VIP 徽章、装饰） */
  --gold: #C9A45C;
  --gold-deep: #4A3B26;
  --gold-soft: #FAF4E6;
  --gold-gradient: linear-gradient(135deg, #F5E6B8 0%, #D4B883 50%, #B89968 100%);

  /* 信息蓝（科技 / 诊断 / 数据） */
  --info: #2D9BFF;
  --info-soft: #EAF4FF;

  /* 中性 */
  --text-1: #1A1A2E;
  --text-2: #666666;
  --text-3: #999999;
  --bg-page: #FFFFFF;
  --bg-soft: #FAFAFC;
  --line: #EFEFEF;

  /* 语义 */
  --c-success: #50B896;
  --c-danger:  #CC7878;
  --c-warning: #E8A87C;

  /* ============ 兼容旧变量（DEPRECATED, 勿在新代码使用） ============ */
  --primary: #1a1a2e;
  --primary-light: #2d2d4a;
  --accent: #e8a87c;
  --accent-light: #f0c4a8;
  --accent-gradient: linear-gradient(135deg, #e8a87c, #d4a574);
  --bg: #f5f5f7;
  --card-bg: #ffffff;
  --text-primary: #1a1a2e;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border: #eeeeee;
  --danger: #e74c3c;
  --success: #27ae60;
  --warm: #f39c12;
  --cool: #3498db;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--bg);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 24rpx;
  box-sizing: border-box;
}

/* 通用卡片 */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

/* 通用按钮 */
.btn-primary {
  background: var(--accent-gradient);
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 64rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: transparent;
  color: var(--accent);
  border: 2rpx solid var(--accent);
  border-radius: 48rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-outline::after {
  border: none;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-warm {
  background: rgba(232, 168, 124, 0.15);
  color: var(--accent);
}

.tag-gold {
  background: rgba(200, 169, 126, 0.12);
  color: #9A7B4F;
  border: 1rpx solid rgba(200, 169, 126, 0.2);
}

.tag-cool {
  background: rgba(52, 152, 219, 0.15);
  color: var(--cool);
}

.tag-primary {
  background: rgba(26, 26, 46, 0.08);
  color: var(--primary);
}

/* 评分条 */
.score-bar {
  height: 12rpx;
  background: var(--border);
  border-radius: 6rpx;
  overflow: hidden;
}

.score-bar-inner {
  height: 100%;
  background: var(--accent-gradient);
  border-radius: 6rpx;
  transition: width 0.6s ease;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 24rpx 0;
}

/* 页面标题 */
.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-hint);
  margin-bottom: 32rpx;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-state .empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  color: var(--accent);
}

.empty-state .empty-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

/* ==================== 全局后台任务进度条（形象诊断 / 穿搭决策 通用） ==================== */
.task-bars {
  position: sticky;
  top: 16rpx;
  z-index: 1000;
  margin: 16rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.task-bar {
  background: #FFFFFF;
  border: 1rpx solid #DCE5EF;
  border-radius: 18rpx;
  padding: 18rpx 24rpx 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(40, 60, 90, 0.08);
}
.task-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.task-bar-typetag {
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}
.task-bar-typetag-diagnose {
  background: rgba(45, 155, 255, 0.1);
  color: #2D9BFF;
  border: 1rpx solid rgba(45, 155, 255, 0.28);
}
.task-bar-typetag-consult {
  background: rgba(184, 153, 104, 0.12);
  color: #8C6E3A;
  border: 1rpx solid rgba(184, 153, 104, 0.32);
}
.task-bar-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2E7BD6;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(46, 123, 214, 0.18);
  animation: task-bar-pulse 1.4s ease-in-out infinite;
}
.task-bar-consult .task-bar-dot {
  background: #B89968;
  box-shadow: 0 0 0 4rpx rgba(184, 153, 104, 0.22);
}
.task-bar-label {
  font-size: 24rpx;
  color: #1F1A17;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  flex: 1;
}
.task-bar-progress {
  font-size: 22rpx;
  color: #2E7BD6;
  font-weight: 600;
  font-family: 'Menlo', 'Courier New', monospace;
  flex-shrink: 0;
}
.task-bar-consult .task-bar-progress {
  color: #B89968;
}
.task-bar-cta {
  font-size: 22rpx;
  color: #2E7BD6;
  font-weight: 600;
  flex-shrink: 0;
}
.task-bar-consult .task-bar-cta {
  color: #B89968;
}
.task-bar-cta-error {
  color: #C0392B !important;
}
.task-bar-track {
  width: 100%;
  height: 6rpx;
  background: #EEF3F8;
  border-radius: 3rpx;
  overflow: hidden;
}
.task-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #2E7BD6, #6BB6FF);
  border-radius: 3rpx;
  transition: width 0.4s ease;
}
.task-bar-consult .task-bar-fill {
  background: linear-gradient(90deg, #B89968, #D4B883);
}
.task-bar-done .task-bar-dot {
  background: #4CAF50 !important;
  box-shadow: 0 0 0 4rpx rgba(76, 175, 80, 0.18);
  animation: none;
}
.task-bar-done .task-bar-fill {
  background: linear-gradient(90deg, #4CAF50, #81C784) !important;
}
.task-bar-done .task-bar-cta,
.task-bar-done .task-bar-progress {
  color: #2E7D32 !important;
}
.task-bar-error .task-bar-dot {
  background: #E74C3C !important;
  box-shadow: 0 0 0 4rpx rgba(231, 76, 60, 0.18);
  animation: none;
}
.task-bar-error .task-bar-fill {
  background: #E74C3C !important;
}
@keyframes task-bar-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}
