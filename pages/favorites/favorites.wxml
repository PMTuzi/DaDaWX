<!--pages/favorites/favorites.wxml-->
<view class="page-favorites">
  <view class="tab-bar">
    <view class="tab-item {{currentTab === item.key ? 'active' : ''}}"
      wx:for="{{tabs}}" wx:key="key"
      data-key="{{item.key}}" bindtap="onSwitchTab">
      {{item.name}}
    </view>
  </view>

  <view class="favorites-list" wx:if="{{favorites.length > 0}}">
    <view class="fav-item card" wx:for="{{favorites}}" wx:key="id">
      <view class="fav-content">
        <text class="fav-name">{{item.name}}</text>
        <text class="fav-type">{{item.type === 'hairstyle' ? '发型' : '穿搭'}}</text>
      </view>
      <text class="fav-remove" data-id="{{item.id}}" bindtap="onRemoveFavorite">取消收藏</text>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">❤️</text>
    <text class="empty-text">暂无收藏</text>
  </view>
</view>
