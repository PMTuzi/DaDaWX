<!--pages/consult-analyzing/consult-analyzing.wxml-->
<view class="page-analyzing">
  <!-- 顶部提示 -->
  <view class="top-hint">
    <text class="top-hint-text">哒哒努力中，不要离开哦～</text>
  </view>

  <!-- 动画区域 -->
  <view class="animation-area">
    <view class="scan-circle">
      <view class="scan-ring ring-1"></view>
      <view class="scan-ring ring-2"></view>
      <view class="scan-ring ring-3"></view>
      <view class="scan-center">
        <text class="scan-percent">{{progress}}%</text>
      </view>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-inner" style="width: {{progress}}%"></view>
  </view>

  <!-- 步骤列表 -->
  <view class="steps-area">
    <view class="step-item {{index < currentStep ? 'done' : ''}} {{index === currentStep ? 'active' : ''}}"
      wx:for="{{steps}}" wx:key="index">
      <view class="step-icon-wrap">
        <view class="step-icon icon icon-checkmark" wx:if="{{index < currentStep}}"></view>
        <view class="step-icon icon icon-{{item.icon}}" wx:elif="{{index === currentStep}}"></view>
        <text class="step-icon" wx:else>○</text>
      </view>
      <text class="step-label">{{item.label}}</text>
      <text class="step-status" wx:if="{{index < currentStep}}">完成</text>
      <text class="step-status active" wx:elif="{{index === currentStep}}">分析中...</text>
    </view>
  </view>

  <!-- 提示文字 -->
  <view class="tip-area">
    <text class="tip-text">3000亿参数模型提取穿搭特征，请耐心等待...</text>
  </view>
</view>