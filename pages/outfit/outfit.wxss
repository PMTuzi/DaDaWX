/* pages/outfit/outfit.wxss */
.page-outfit {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.page-header {
  padding: 48rpx 32rpx 28rpx;
  display: flex;
  justify-content: center;
}

.ph-logo {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.ph-logo-zh {
  font-family: "PingFang SC", "Hiragino Sans GB", sans-serif;
  font-weight: 800;
  font-size: 56rpx;
  letter-spacing: 8rpx;
  color: #1F1812;
  line-height: 1;
}

.ph-logo-sep {
  width: 3rpx;
  height: 40rpx;
  border-radius: 2rpx;
  background: linear-gradient(180deg, transparent 0%, #C9A45C 50%, transparent 100%);
  flex-shrink: 0;
  align-self: center;
}

.ph-logo-en {
  font-family: "PingFang SC", "Hiragino Sans GB", sans-serif;
  font-weight: 700;
  font-size: 28rpx;
  letter-spacing: 8rpx;
  color: #B89968;
  text-transform: uppercase;
  padding-left: 4rpx;
}

.ph-title,
.ph-sub,
.ph-meta,
.ph-rule,
.ph-meta-text,
.ph-zh,
.ph-zh-dot,
.ph-en,
.ph-en-line,
.ph-rule-bottom { display: none; }

.header-title-text {
  font-family: "PingFang SC", "Hiragino Sans GB", sans-serif;
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 10rpx;
  padding-left: 10rpx;
  background: linear-gradient(180deg, #2A2118 0%, #4A3B26 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  line-height: 1.15;
}

.header-accent {
  width: 56rpx;
  height: 3rpx;
  margin: 22rpx auto 0;
  background: linear-gradient(90deg, #E5C988, #C9A45C);
  border-radius: 2rpx;
}

.header-subtitle {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #8B7B6A;
  letter-spacing: 2rpx;
  font-weight: 400;
}

/* 统一入口卡片 - 黑金主按钮风格 */
.unified-card {
  position: relative;
  display: flex;
  align-items: center;
  margin: 0 32rpx;
  padding: 36rpx 40rpx;
  gap: 24rpx;
  background:
    linear-gradient(135deg, rgba(212, 184, 131, 0.18) 0%, rgba(212, 184, 131, 0) 55%),
    linear-gradient(180deg, #1A1612 0%, #2A2520 100%);
  border-radius: 24rpx;
  border: 1rpx solid rgba(212, 184, 131, 0.5);
  box-shadow:
    0 10rpx 32rpx rgba(20, 16, 12, 0.35),
    0 0 0 0 rgba(212, 184, 131, 0.0),
    inset 0 1rpx 0 rgba(255, 240, 200, 0.12);
  overflow: hidden;
  animation: unified-card-glow 4.5s ease-in-out infinite;
}
@keyframes unified-card-glow {
  0%, 100% {
    box-shadow:
      0 10rpx 32rpx rgba(20, 16, 12, 0.35),
      0 0 0 0 rgba(212, 184, 131, 0),
      inset 0 1rpx 0 rgba(255, 240, 200, 0.12);
  }
  50% {
    box-shadow:
      0 10rpx 32rpx rgba(20, 16, 12, 0.35),
      0 0 14rpx 2rpx rgba(212, 184, 131, 0.18),
      inset 0 1rpx 0 rgba(255, 240, 200, 0.14);
  }
}
.unified-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 50%;
  border-radius: 24rpx 24rpx 0 0;
  background: linear-gradient(180deg, rgba(255, 246, 220, 0.08), rgba(255, 246, 220, 0));
  pointer-events: none;
}
.unified-card::after {
  content: '';
  position: absolute;
  top: 0;
  left: -50%;
  width: 35%;
  height: 100%;
  background: linear-gradient(
    100deg,
    transparent 0%,
    rgba(255, 246, 220, 0) 35%,
    rgba(255, 246, 220, 0.18) 50%,
    rgba(255, 246, 220, 0) 65%,
    transparent 100%
  );
  transform: skewX(-20deg);
  animation: unified-card-shine 4.5s ease-in-out infinite;
  pointer-events: none;
}
@keyframes unified-card-shine {
  0%   { left: -50%; opacity: 0; }
  25%  { opacity: 1; }
  70%  { opacity: 1; }
  100% { left: 130%; opacity: 0; }
}

.unified-card .card-icon {
  font-size: 56rpx;
  color: #D4B883;
  flex-shrink: 0;
  text-shadow: 0 0 12rpx rgba(212, 184, 131, 0.4);
}

.unified-card .card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.unified-card .card-title {
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 1.5rpx;
  background: linear-gradient(135deg, #F5E6B8 0%, #D4B883 50%, #B89968 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

.unified-card .card-subtitle {
  font-size: 22rpx;
  color: #E6DCC8;
  letter-spacing: 0.5rpx;
}

.unified-card .card-arrow {
  font-size: 36rpx;
  color: #D4B883;
  opacity: 0.95;
  flex-shrink: 0;
}

.unified-card:active {
  transform: scale(0.98);
  transition: transform 0.15s;
}

/* 新手提示 */
.beginner-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 19rpx 32rpx 0;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid #F0EBE5;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.tip-icon {
  font-size: 28rpx;
  color: #C8A97E;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #8B7355;
  line-height: 1.5;
}

.tip-arrow {
  font-size: 28rpx;
  color: #C8A97E;
  flex-shrink: 0;
}

/* 空列表占位视频 */
.empty-video-wrap {
  position: relative;
  margin: 32rpx 32rpx 0;
  height: calc(100vh - 420rpx);
  min-height: 560rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #000;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.empty-video {
  width: 100%;
  height: 100%;
  display: block;
}

/* 透明点击层，覆盖整个视频区域，捕获点击（除底部 CTA 区域） */
.empty-video-tap {
  position: absolute;
  inset: 0;
  z-index: 5;
  background: transparent;
}

/* 视频内浮动 CTA - 科技风 */
.tech-overlay {
  position: absolute;
  inset: 0;
  z-index: 10;
  background: linear-gradient(180deg, rgba(0, 8, 24, 0.45) 0%, rgba(0, 8, 24, 0) 28%, rgba(0, 8, 24, 0) 55%, rgba(0, 8, 24, 0.78) 100%);
  pointer-events: none;
}

.tech-cta {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 78rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  pointer-events: auto;
}

.tech-cta-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 36rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, rgba(0, 16, 40, 0.35) 0%, rgba(94, 230, 255, 0.18) 50%, rgba(0, 16, 40, 0.35) 100%);
  border: 1rpx solid rgba(94, 230, 255, 0.55);
  box-shadow: 0 0 24rpx rgba(94, 230, 255, 0.35), inset 0 0 16rpx rgba(94, 230, 255, 0.18);
  animation: outfitTechGlow 2.2s ease-in-out infinite;
}

.tech-arrow {
  font-size: 32rpx;
  color: #5EE6FF;
  text-shadow: 0 0 10rpx rgba(94, 230, 255, 0.9);
  animation: outfitTechArrow 1.4s ease-in-out infinite;
}

.tech-arrow-rev {
  animation-delay: 0.7s;
}

.tech-cta-text {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #FFFFFF;
  background: linear-gradient(90deg, #FFFFFF 0%, #B8F4FF 50%, #FFFFFF 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 0 14rpx rgba(94, 230, 255, 0.55);
}

@keyframes outfitTechGlow {
  0%, 100% { box-shadow: 0 0 24rpx rgba(94, 230, 255, 0.35), inset 0 0 16rpx rgba(94, 230, 255, 0.18); }
  50% { box-shadow: 0 0 36rpx rgba(94, 230, 255, 0.7), inset 0 0 24rpx rgba(94, 230, 255, 0.34); }
}

@keyframes outfitTechArrow {
  0%, 100% { transform: translateX(0); opacity: 0.7; }
  50% { transform: translateX(6rpx); opacity: 1; }
}

/* 历史记录 */
.history-section {
  margin-top: 40rpx;
  padding: 0 32rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 1rpx;
}

.section-tip {
  font-size: 22rpx;
  color: #C8A97E;
  letter-spacing: 1rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  align-items: stretch;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  gap: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F0EBE5;
  overflow: hidden;
  position: relative;
}

.history-item.card-accept::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #F1849B, #D96A85);
  border-radius: 0 3rpx 3rpx 0;
}

.history-item.card-reject::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #5BB0FF, #1A6FB8);
  border-radius: 0 3rpx 3rpx 0;
}

.history-item.card-compare::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #C9A45C, #B8935A);
  border-radius: 0 3rpx 3rpx 0;
}

.history-thumb-wrap {
  width: 108rpx;
  height: 108rpx;
  flex-shrink: 0;
}

.history-thumb {
  width: 108rpx;
  height: 108rpx;
  border-radius: 16rpx;
  background: #F5F0EB;
}

.history-thumb-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F5F0EB, #EDE5DA);
}

.history-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.history-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.history-info {
  flex: 1;
  min-width: 0;
}

.history-verdict {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.verdict-positive {
  color: #D96A85;
}

.verdict-negative {
  color: #1A6FB8;
}

.verdict-compare {
  color: #4A3B26;
}

.type-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.tag-accept {
  background: rgba(241, 132, 155, 0.1);
  color: #D96A85;
}

.tag-reject {
  background: rgba(45, 155, 255, 0.12);
  color: #1A6FB8;
}

.tag-compare {
  background: rgba(201, 164, 92, 0.12);
  color: #4A3B26;
  border: 1rpx solid rgba(201, 164, 92, 0.25);
}

.history-score-ring {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ring-positive {
  background: rgba(241, 132, 155, 0.08);
  border: 3rpx solid rgba(241, 132, 155, 0.32);
}

.ring-negative {
  background: rgba(45, 155, 255, 0.1);
  border: 3rpx solid rgba(45, 155, 255, 0.32);
}

.ring-compare {
  background: rgba(201, 164, 92, 0.1);
  border: 3rpx solid rgba(201, 164, 92, 0.35);
}

.history-score-ring .score-num {
  font-size: 30rpx;
  font-weight: 800;
}

.ring-positive .score-num {
  color: #D96A85;
}

.ring-negative .score-num {
  color: #1A6FB8;
}

.ring-compare .score-num {
  color: #4A3B26;
}

.history-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.history-summary {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.history-time {
  font-size: 22rpx;
  color: #bbb;
}

.history-arrow {
  font-size: 32rpx;
  color: #C8A97E;
  font-weight: 300;
}

/* 底部分享Banner - 固定悬浮 */
.invite-banner {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.invite-banner-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100% !important;
  margin: 0 !important;
  padding: 24rpx 32rpx !important;
  background: #fff !important;
  border-radius: 0 !important;
  border: none !important;
  text-align: left;
  line-height: 1;
  box-sizing: border-box;
}

.invite-banner-inner::after {
  border: none;
}

.invite-left {
  flex: 1;
  min-width: 0;
}

.invite-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.invite-desc {
  font-size: 22rpx;
  color: #8B7355;
}

.invite-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #eaacbe, #d4956a);
  border-radius: 36rpx;
  flex-shrink: 0;
  margin-left: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(234, 172, 190, 0.4);
}

.invite-action-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.invite-arrow {
  font-size: 24rpx;
  color: #fff;
}

.invite-banner-inner:active {
  opacity: 0.9;
  transform: scale(0.98);
  transition: all 0.15s;
}

/* ===== 你的风格标签卡片 ===== */
.style-tags-card {
  margin: 0 32rpx 24rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF1E5 100%);
  border: 1rpx solid rgba(200, 169, 126, 0.25);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(200, 169, 126, 0.08);
}

.style-tags-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.style-tags-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.style-tags-icon {
  color: #C8A97E;
  font-size: 24rpx;
}

.style-tags-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #8B7355;
  letter-spacing: 1rpx;
}

.style-tags-chips {
  white-space: nowrap;
  width: 100%;
}

.style-tags-chips .style-chip {
  display: inline-block;
  margin-right: 12rpx;
}

.style-chip {
  padding: 6rpx 16rpx;
  background: #fff;
  border: 1rpx solid rgba(200, 169, 126, 0.3);
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #8B7355;
  letter-spacing: 0.5rpx;
}

.style-tags-toggle {
  font-size: 22rpx;
  color: #C8A97E;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

.style-tags-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed rgba(200, 169, 126, 0.3);
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.detail-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.detail-row-multi {
  flex-direction: column;
  gap: 6rpx;
}

.detail-key {
  flex-shrink: 0;
  width: 200rpx;
  color: #8B7355;
  font-weight: 600;
}

.detail-row-multi .detail-key {
  width: auto;
}

.detail-val {
  flex: 1;
  color: #444;
}

.detail-cta {
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 14rpx 0;
  background: rgba(200, 169, 126, 0.12);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #C8A97E;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.detail-cta-arrow {
  font-size: 26rpx;
}

/* 顶部后台任务进度条 */
.task-bar {
  position: sticky;
  top: 16rpx;
  z-index: 1000;
  margin: 16rpx 24rpx 0;
  background: #FFFFFF;
  border: 1rpx solid #DCE5EF;
  border-radius: 18rpx;
  padding: 18rpx 24rpx 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(40, 60, 90, 0.08);
}
.task-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.task-bar-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2E7BD6;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(46, 123, 214, 0.18);
  animation: task-bar-pulse 1.4s ease-in-out infinite;
}
.task-bar-label {
  font-size: 24rpx;
  color: #1F1A17;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  flex: 1;
}
.task-bar-progress {
  font-size: 22rpx;
  color: #2E7BD6;
  font-weight: 600;
  font-family: 'Menlo', 'Courier New', monospace;
  flex-shrink: 0;
}
.task-bar-cta {
  font-size: 22rpx;
  color: #2E7BD6;
  font-weight: 600;
  flex-shrink: 0;
}
.task-bar-cta-error {
  color: #C0392B;
}
.task-bar-track {
  width: 100%;
  height: 6rpx;
  background: #EEF3F8;
  border-radius: 3rpx;
  overflow: hidden;
}
.task-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #2E7BD6, #6BB6FF);
  border-radius: 3rpx;
  transition: width 0.4s ease;
}
.task-bar-done .task-bar-dot {
  background: #4CAF50;
  box-shadow: 0 0 0 4rpx rgba(76, 175, 80, 0.18);
  animation: none;
}
.task-bar-done .task-bar-fill {
  background: linear-gradient(90deg, #4CAF50, #81C784);
}
.task-bar-done .task-bar-cta {
  color: #2E7D32;
}
.task-bar-error .task-bar-dot {
  background: #E74C3C;
  box-shadow: 0 0 0 4rpx rgba(231, 76, 60, 0.18);
  animation: none;
}
.task-bar-error .task-bar-fill {
  background: #E74C3C;
}
@keyframes task-bar-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}
