/* pages/outfit/outfit.wxss */
.page-outfit {
  min-height: 100vh;
  background: #FAFAF5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.page-header {
  padding: 40rpx 32rpx 24rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #8B7355;
  letter-spacing: 1rpx;
}

/* 统一入口卡片 - 金色主按钮风格 */
.unified-card {
  display: flex;
  align-items: center;
  margin: 0 32rpx;
  padding: 36rpx 40rpx;
  gap: 24rpx;
  background: #F1849B;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(241, 132, 155, 0.3);
}

.unified-card .card-icon {
  font-size: 56rpx;
  color: #fff;
  flex-shrink: 0;
}

.unified-card .card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.unified-card .card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.unified-card .card-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

.unified-card .card-arrow {
  font-size: 36rpx;
  color: #fff;
  opacity: 0.9;
  flex-shrink: 0;
}

.unified-card:active {
  transform: scale(0.98);
  transition: transform 0.15s;
}

/* 新手提示 */
.beginner-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 24rpx 32rpx 0;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 1rpx solid #F0EBE5;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.tip-icon {
  font-size: 28rpx;
  color: #C8A97E;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #8B7355;
  line-height: 1.5;
}

.tip-arrow {
  font-size: 28rpx;
  color: #C8A97E;
  flex-shrink: 0;
}

/* 历史记录 */
.history-section {
  margin-top: 40rpx;
  padding: 0 32rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 1rpx;
}

.section-tip {
  font-size: 22rpx;
  color: #C8A97E;
  letter-spacing: 1rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  align-items: stretch;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  gap: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F0EBE5;
  overflow: hidden;
  position: relative;
}

.history-item.card-accept::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #50b896, #3a9a7a);
  border-radius: 0 3rpx 3rpx 0;
}

.history-item.card-reject::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: #E8655A;
  border-radius: 0 3rpx 3rpx 0;
}

.history-item.card-compare::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #d88ca8, #c49060);
  border-radius: 0 3rpx 3rpx 0;
}

.history-thumb-wrap {
  width: 108rpx;
  height: 108rpx;
  flex-shrink: 0;
}

.history-thumb {
  width: 108rpx;
  height: 108rpx;
  border-radius: 16rpx;
  background: #F5F0EB;
}

.history-thumb-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #F5F0EB, #EDE5DA);
}

.history-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.history-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.history-info {
  flex: 1;
  min-width: 0;
}

.history-verdict {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.verdict-positive {
  color: #3a9a7a;
}

.verdict-negative {
  color: #E8655A;
}

.verdict-compare {
  background: linear-gradient(135deg, #d88ca8, #c49060);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.type-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.tag-accept {
  background: rgba(80, 184, 150, 0.1);
  color: #3a9a7a;
}

.tag-reject {
  background: rgba(232, 101, 90, 0.1);
  color: #E8655A;
}

.tag-compare {
  background: rgba(196, 144, 96, 0.1);
  color: #c49060;
}

.history-score-ring {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ring-positive {
  background: rgba(80, 184, 150, 0.08);
  border: 3rpx solid rgba(80, 184, 150, 0.3);
}

.ring-negative {
  background: rgba(232, 101, 90, 0.08);
  border: 3rpx solid rgba(232, 101, 90, 0.3);
}

.ring-compare {
  background: rgba(196, 144, 96, 0.08);
  border: 3rpx solid rgba(196, 144, 96, 0.3);
}

.history-score-ring .score-num {
  font-size: 30rpx;
  font-weight: 800;
}

.ring-positive .score-num {
  color: #3a9a7a;
}

.ring-negative .score-num {
  color: #E8655A;
}

.ring-compare .score-num {
  background: linear-gradient(135deg, #d88ca8, #c49060);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.history-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.history-summary {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.history-time {
  font-size: 22rpx;
  color: #bbb;
}

.history-arrow {
  font-size: 32rpx;
  color: #C8A97E;
  font-weight: 300;
}

/* 底部分享Banner - 固定悬浮 */
.invite-banner {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  padding-bottom: env(safe-area-inset-bottom);
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.invite-banner-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100% !important;
  margin: 0 !important;
  padding: 24rpx 32rpx !important;
  background: #fff !important;
  border-radius: 0 !important;
  border: none !important;
  text-align: left;
  line-height: 1;
  box-sizing: border-box;
}

.invite-banner-inner::after {
  border: none;
}

.invite-left {
  flex: 1;
  min-width: 0;
}

.invite-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.invite-desc {
  font-size: 22rpx;
  color: #8B7355;
}

.invite-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #eaacbe, #d4956a);
  border-radius: 36rpx;
  flex-shrink: 0;
  margin-left: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(234, 172, 190, 0.4);
}

.invite-action-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.invite-arrow {
  font-size: 24rpx;
  color: #fff;
}

.invite-banner-inner:active {
  opacity: 0.9;
  transform: scale(0.98);
  transition: all 0.15s;
}
