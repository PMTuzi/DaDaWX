/* pages/outfit/outfit.wxss */
.page-outfit {
  min-height: 100vh;
  background: #FAFAF5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.page-header {
  padding: 40rpx 32rpx 24rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #333333;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: #999;
}

/* 功能卡片 */
.consult-cards {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* 统一入口卡片 */
.unified-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  margin: 0 32rpx;
  padding: 44rpx 32rpx;
  display: flex;
  align-items: center;
}

.unified-card .card-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.12;
  border-radius: 24rpx;
}

.unified-card .card-content {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.unified-card .card-icon {
  color: #C8A97E;
}

.unified-card .card-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.unified-card .card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
}

.unified-card .card-subtitle {
  font-size: 24rpx;
  color: #666;
}

.unified-card .card-arrow {
  font-size: 36rpx;
  color: #C8A97E;
  position: relative;
  z-index: 1;
}

.unified-card:active {
  transform: scale(0.98);
  transition: transform 0.15s;
}

.consult-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  padding: 36rpx 32rpx;
  display: flex;
  align-items: center;
  min-height: 140rpx;
}

.card-bg {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0.12;
  border-radius: 24rpx;
}

.card-content {
  flex: 1;
  position: relative;
  z-index: 1;
}

.card-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 4rpx;
}

.card-subtitle {
  font-size: 24rpx;
  color: #666;
}

.card-arrow {
  font-size: 36rpx;
  color: #C8A97E;
  position: relative;
  z-index: 1;
}

.consult-card:active {
  transform: scale(0.98);
  transition: transform 0.15s;
}

/* 新手提示 */
.beginner-tip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 32rpx 32rpx 0;
  padding: 20rpx 24rpx;
  background: rgba(200, 169, 126, 0.1);
  border-radius: 16rpx;
}

.tip-badge {
  background: #C8A97E;
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #8B7355;
  line-height: 1.5;
}

.tip-arrow {
  font-size: 28rpx;
  color: #C8A97E;
  flex-shrink: 0;
}

/* 历史记录 */
.history-section {
  margin-top: 40rpx;
  padding: 0 32rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  display: flex;
  align-items: stretch;
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 24rpx;
  gap: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
  position: relative;
}

.history-item.card-accept::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: #27ae60;
  border-radius: 0 3rpx 3rpx 0;
}

.history-item.card-reject::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: #e74c3c;
  border-radius: 0 3rpx 3rpx 0;
}

.history-thumb-wrap {
  width: 108rpx;
  height: 108rpx;
  flex-shrink: 0;
}

.history-thumb {
  width: 108rpx;
  height: 108rpx;
  border-radius: 16rpx;
  background: #eee;
}

.history-thumb-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f5f7, #eaeaea);
}

.history-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.history-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.history-info {
  flex: 1;
  min-width: 0;
}

.history-verdict {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}

.verdict-positive {
  color: #27ae60;
}

.verdict-negative {
  color: #e74c3c;
}

.type-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.tag-single {
  background: rgba(200, 169, 126, 0.1);
  color: #C8A97E;
}

.tag-compare {
  background: rgba(139, 115, 85, 0.1);
  color: #8B7355;
}

.history-score-ring {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ring-positive {
  background: rgba(39, 174, 96, 0.08);
  border: 3rpx solid rgba(39, 174, 96, 0.25);
}

.ring-negative {
  background: rgba(231, 76, 60, 0.08);
  border: 3rpx solid rgba(231, 76, 60, 0.25);
}

.history-score-ring .score-num {
  font-size: 32rpx;
  font-weight: 800;
}

.ring-positive .score-num {
  color: #27ae60;
}

.ring-negative .score-num {
  color: #e74c3c;
}

.history-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
}

.history-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.history-arrow {
  font-size: 32rpx;
  color: var(--text-hint);
  font-weight: 300;
}
