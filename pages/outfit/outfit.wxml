<!--pages/outfit/outfit.wxml-->
<view class="page-outfit">
  <!-- 顶部标题 -->
  <view class="page-header">
    <view class="header-title">穿搭决策</view>
    <view class="header-subtitle">上传衣物照片，AI帮你评分对比</view>
  </view>

  <!-- 统一入口卡片 -->
  <view class="unified-card" bindtap="onStartConsult">
    <view class="card-bg" style="background: linear-gradient(135deg, #667eea, #764ba2)"></view>
    <view class="card-content">
      <view class="card-icon icon icon-dress" style="font-size:56rpx;"></view>
      <view class="card-info">
        <view class="card-title">开始穿搭决策</view>
        <view class="card-subtitle">1张图片 → 评分评估 | 多张图片 → 对比排名</view>
      </view>
    </view>
    <view class="card-arrow">→</view>
  </view>

  <!-- 新手提示 -->
  <view class="beginner-tip" wx:if="{{!hasReport}}" bindtap="onGoDiagnose">
    <view class="tip-badge">新</view>
    <text class="tip-text">完成AI形象诊断后，穿搭决策将更精准匹配你的风格</text>
    <text class="tip-arrow">→</text>
  </view>

  <!-- 历史记录 -->
  <view class="history-section" wx:if="{{showHistory}}">
    <view class="section-header">
      <view class="section-title">最近咨询</view>
    </view>
    <view class="history-list">
      <view class="history-item card {{item.verdict === '建议退货' || item.verdict === '建议不买' ? 'card-reject' : 'card-accept'}}" wx:for="{{recentConsults}}" wx:key="id"
        data-id="{{item.id}}" bindtap="onViewResult">
        <view class="history-thumb-wrap">
          <image class="history-thumb" wx:if="{{item.images && item.images.length && (item.images[0].localPath || item.images[0].imageUrl)}}"
            src="{{item.images[0].localPath || item.images[0].imageUrl}}" mode="aspectFill" binderror="onThumbError" data-index="{{index}}"></image>
          <view class="history-thumb history-thumb-placeholder" wx:else>
            <view class="icon icon-dress" style="font-size:36rpx;color:#ccc;"></view>
          </view>
        </view>
        <view class="history-info">
          <view class="history-type">
            <text class="type-tag {{item.type === 'compare' ? 'tag-compare' : 'tag-single'}}">
              {{item.type === 'compare' ? '多款对比' : '单品评估'}}
            </text>
          </view>
          <view class="history-verdict {{item.verdict === '建议退货' || item.verdict === '建议不买' ? 'verdict-negative' : 'verdict-positive'}}">{{item.verdict || item.finalChoiceLabel || ''}}</view>
          <view class="history-time">{{item.createTime}}</view>
        </view>
        <view class="history-score">
          <text class="score-num {{item.verdict === '建议退货' || item.verdict === '建议不买' ? 'score-negative' : 'score-positive'}}">{{item.totalScore || '--'}}</text>
          <text class="score-unit">分</text>
        </view>
      </view>
    </view>
  </view>
</view>
