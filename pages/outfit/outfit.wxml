<!--pages/outfit/outfit.wxml-->
<view class="page-outfit">
  <!-- 顶部标题 -->
  <view class="page-header">
    <view class="header-title">穿搭决策</view>
    <view class="header-subtitle">AI帮你做最明智的穿搭选择</view>
  </view>

  <!-- 三大功能卡片 -->
  <view class="consult-cards">
    <view class="consult-card" wx:for="{{consultCards}}" wx:key="type"
      data-type="{{item.type}}" bindtap="onCardTap">
      <view class="card-bg" style="background: {{item.gradient}}"></view>
      <view class="card-content">
        <view class="card-icon">{{item.icon}}</view>
        <view class="card-title">{{item.title}}</view>
        <view class="card-subtitle">{{item.subtitle}}</view>
      </view>
      <view class="card-arrow">→</view>
    </view>
  </view>

  <!-- 新手提示 -->
  <view class="beginner-tip" wx:if="{{!hasReport}}" bindtap="onGoDiagnose">
    <view class="tip-badge">新</view>
    <text class="tip-text">完成AI形象诊断后，穿搭决策将更精准匹配你的风格</text>
    <text class="tip-arrow">→</text>
  </view>

  <!-- 历史记录 -->
  <view class="history-section" wx:if="{{showHistory}}">
    <view class="section-header">
      <view class="section-title">最近咨询</view>
    </view>
    <view class="history-list">
      <view class="history-item card" wx:for="{{recentConsults}}" wx:key="id"
        data-id="{{item.id}}" bindtap="onViewResult">
        <view class="history-info">
          <view class="history-type">
            <text class="type-tag {{item.type === 'compare' ? 'tag-compare' : 'tag-single'}}">
              {{item.type === 'buy' ? '买不买' : item.type === 'keep' ? '留不留' : '选哪个'}}
            </text>
          </view>
          <view class="history-verdict">{{item.verdict || item.finalChoiceLabel || ''}}</view>
          <view class="history-time">{{item.createTime}}</view>
        </view>
        <view class="history-score">
          <text class="score-num">{{item.totalScore || '--'}}</text>
          <text class="score-unit">分</text>
        </view>
      </view>
    </view>
  </view>
</view>
