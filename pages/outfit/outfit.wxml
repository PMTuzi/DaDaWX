<!--pages/outfit/outfit.wxml-->
<wxs src="../../utils/helpers.wxs" module="h" />
<import src="../../templates/task-bars.wxml" />
<view class="page-outfit">
  <!-- 顶部后台任务进度条（形象诊断 / 穿搭决策） -->
  <template is="task-bars" data="{{diagnoseTask, consultTask}}" />

  <!-- 顶部标题（参考首页已诊断态品牌区） -->
  <view class="page-header">
    <view class="ph-logo">
      <text class="ph-logo-zh">穿搭决策</text>
      <text class="ph-logo-sep"></text>
      <text class="ph-logo-en">Meeta</text>
    </view>
  </view>

  <!-- 你的风格标签卡片：把诊断结果带入决策场景 -->
  <view class="style-tags-card" wx:if="{{hasReport && latestReport}}">
    <view class="style-tags-head" bindtap="onToggleStyleTags">
      <view class="style-tags-title">
        <text class="style-tags-icon">✦</text>
        <text class="style-tags-label">你的风格标签</text>
      </view>
      <text class="style-tags-toggle">{{styleTagsExpanded ? '收起 ︿' : '展开 ﹀'}}</text>
    </view>
    <scroll-view class="style-tags-chips" scroll-x="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}" bindtap="onToggleStyleTags">
      <text class="style-chip" wx:if="{{latestReport.modules.style.mainStyle}}">{{latestReport.modules.style.mainStyle}}</text>
      <text class="style-chip" wx:if="{{latestReport.modules.style.season}}">{{latestReport.modules.style.season}}</text>
      <text class="style-chip" wx:if="{{latestReport.modules.style.skinType}}">{{latestReport.modules.style.skinType}}</text>
      <text class="style-chip" wx:if="{{latestReport.modules.dna.faceType}}">{{latestReport.modules.dna.faceType}}</text>
    </scroll-view>

    <!-- 展开区：报告关键字段 -->
    <view class="style-tags-detail" wx:if="{{styleTagsExpanded}}">
      <view class="detail-row" wx:if="{{latestReport.modules.dna.faceType || latestReport.modules.dna.boneType}}">
        <text class="detail-key">面部 · 骨相</text>
        <text class="detail-val">{{latestReport.modules.dna.faceType}}{{latestReport.modules.dna.faceType && latestReport.modules.dna.boneType ? ' · ' : ''}}{{latestReport.modules.dna.boneType}}</text>
      </view>
      <view class="detail-row" wx:if="{{latestReport.modules.style.season || latestReport.modules.style.skinType}}">
        <text class="detail-key">皮肤 · 色彩季</text>
        <text class="detail-val">{{latestReport.modules.style.skinType}}{{latestReport.modules.style.skinType && latestReport.modules.style.season ? ' · ' : ''}}{{latestReport.modules.style.season}}</text>
      </view>
      <view class="detail-row" wx:if="{{latestReport.modules.style.mainStyle}}">
        <text class="detail-key">主风格</text>
        <text class="detail-val">{{latestReport.modules.style.mainStyle}}</text>
      </view>
      <view class="detail-row" wx:if="{{latestReport.modules.style.styleFeatures.mass || latestReport.modules.style.styleFeatures.curve || latestReport.modules.style.styleFeatures.movement}}">
        <text class="detail-key">量感 · 曲直 · 动静</text>
        <text class="detail-val">{{latestReport.modules.style.styleFeatures.mass || '-'}} · {{latestReport.modules.style.styleFeatures.curve || '-'}} · {{latestReport.modules.style.styleFeatures.movement || '-'}}</text>
      </view>
      <view class="detail-row detail-row-multi" wx:if="{{latestReport.modules.optimize.coreConclusion}}">
        <text class="detail-key">核心结论</text>
        <text class="detail-val">{{latestReport.modules.optimize.coreConclusion}}</text>
      </view>
      <view class="detail-cta" bindtap="onViewFullReport">
        <text>查看完整报告</text>
        <text class="detail-cta-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 统一入口卡片（仅有历史时显示在顶部，空列表时移入视频内） -->
  <view class="unified-card" wx:if="{{showHistory}}" bindtap="onStartConsult">
    <view class="card-icon icon icon-dress"></view>
    <view class="card-info">
      <view class="card-title">开始「反种草」</view>
      <view class="card-subtitle">1张图片 → 评分评估 | 多张图片 → 对比排名</view>
    </view>
    <view class="card-arrow">→</view>
  </view>

  <!-- 新手提示 -->
  <view class="beginner-tip" wx:if="{{!hasReport}}" bindtap="onGoDiagnose">
    <view class="tip-icon icon icon-chart"></view>
    <text class="tip-text">完成AI形象诊断后，穿搭决策将更精准匹配你的风格</text>
    <text class="tip-arrow">→</text>
  </view>

  <!-- 空列表占位视频（整块可点击） -->
  <view class="empty-video-wrap" wx:if="{{!showHistory}}" bindtap="onStartConsult">
    <video
      class="empty-video"
      src="cloud://dada-d9gw8x8fb426caba5.6461-dada-d9gw8x8fb426caba5-1435078506/outfit-decision.mp4"
      object-fit="cover"
      autoplay="{{true}}"
      loop="{{true}}"
      muted="{{true}}"
      controls="{{false}}"
      show-center-play-btn="{{false}}"
      show-play-btn="{{false}}"
      show-fullscreen-btn="{{false}}"
      enable-progress-gesture="{{false}}"
      show-progress="{{false}}"
    ></video>
    <!-- 透明点击层，捕获视频区域的点击（兼容原生组件） -->
    <view class="empty-video-tap" catchtap="onStartConsult"></view>
    <!-- 酷炫科技风文字引导覆盖层 -->
    <view class="tech-overlay" catchtap="onStartConsult">
      <view class="tech-cta">
        <view class="tech-cta-main">
          <text class="tech-arrow">▸</text>
          <text class="tech-cta-text">点击开启 · 穿搭反种草</text>
          <text class="tech-arrow tech-arrow-rev">◂</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 历史记录 -->
  <view class="history-section" wx:if="{{showHistory}}">
    <view class="section-header">
      <view class="section-title">最近咨询</view>
      <view class="section-tip">点击查看多维分析
       </view>
    </view>
    <view class="history-list">
      <view class="history-item {{item.type === 'compare' ? 'card-compare' : (item.verdict === '建议购买' || item.verdict === '建议自留' || item.verdict === '建议入手' ? 'card-accept' : 'card-reject')}}" wx:for="{{recentConsults}}" wx:key="id"
        data-id="{{item.id}}" bindtap="onViewResult">
        <view class="history-thumb-wrap">
          <image class="history-thumb" wx:if="{{item.images && item.images.length && h.getThumbUrl(item.images, item.recommendedIndex)}}"
            src="{{h.getThumbUrl(item.images, item.recommendedIndex)}}" mode="aspectFill" binderror="onThumbError" data-index="{{index}}"></image>
          <view class="history-thumb history-thumb-placeholder" wx:else>
            <view class="icon icon-dress" style="font-size:32rpx;color:#C9A45C;"></view>
          </view>
        </view>
        <view class="history-body">
          <view class="history-top">
            <view class="history-info">
              <view class="history-verdict {{item.type === 'compare' ? 'verdict-compare' : (item.verdict === '建议购买' || item.verdict === '建议自留' || item.verdict === '建议入手' ? 'verdict-positive' : 'verdict-negative')}}">{{item.verdict || item.finalChoiceLabel || ''}}</view>
              <text class="type-tag {{item.type === 'compare' ? 'tag-compare' : (item.verdict === '建议购买' || item.verdict === '建议自留' || item.verdict === '建议入手' ? 'tag-accept' : 'tag-reject')}}">{{item.type === 'compare' ? '对比' : '单品'}}</text>
            </view>
            <view class="history-score-ring {{item.type === 'compare' ? 'ring-compare' : (item.verdict === '建议购买' || item.verdict === '建议自留' || item.verdict === '建议入手' ? 'ring-positive' : 'ring-negative')}}">
              <text class="score-num">{{h.toFixed1(item.totalScore)}}</text>
            </view>
          </view>
          <view class="history-summary" wx:if="{{item.personalReason}}">{{item.personalReason}}</view>
          <view class="history-bottom">
            <text class="history-time">{{item.createTime}}</text>
            <text class="history-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部分享Banner -->
  <view class="invite-banner">
    <button class="invite-banner-inner" open-type="share">
      <view class="invite-left">
        <view class="invite-title">分享好友，一起决策</view>
        <view class="invite-desc"></view>
      </view>
      <view class="invite-action">
        <text class="invite-action-text">去邀请</text>
        <text class="invite-arrow">→</text>
      </view>
    </button>
  </view>
</view>
