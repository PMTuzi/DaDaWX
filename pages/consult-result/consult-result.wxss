/* pages/consult-result/consult-result.wxss */
.page-result {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* Tab 导航 */
.cr-tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #DCE5EF;
  position: sticky;
  top: 0;
  z-index: 50;
  margin: 0 24rpx 16rpx;
  border-radius: 16rpx 16rpx 0 0;
  box-shadow: 0 4rpx 12rpx rgba(31, 26, 23, 0.04);
}
.cr-tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 4rpx;
  position: relative;
}
.cr-tab-label {
  font-size: 28rpx;
  color: #8A8580;
  font-weight: 500;
  letter-spacing: 1rpx;
}
.cr-tab-item.active .cr-tab-label {
  color: #1F1A17;
  font-weight: 600;
}
.cr-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 56rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #C9A45C 0%, #E5C589 100%);
  border-radius: 3rpx;
}
.tab-pane { padding: 0; }
.echo-row-incard { margin: 0; padding: 0; }
.style-block-incard { margin: 0; padding: 0; background: transparent; }
.insight-grid-incard { margin: 0; padding: 0; }

/* 顶部决策结论 */
.verdict-section {
  position: relative;
  padding: 0;
  margin: 24rpx 24rpx 0;
  border-radius: 28rpx;
  overflow: hidden;
}

.verdict-bg-glow {
  position: absolute;
  top: -80rpx;
  right: -40rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  opacity: 0.15;
  pointer-events: none;
}

.verdict-bg-glow-2 {
  position: absolute;
  bottom: -60rpx;
  left: -30rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  opacity: 0.08;
  pointer-events: none;
}

/* ===== 推荐 (Accept) - 樱粉，主品牌 ===== */
.verdict-accept {
  background: var(--brand-soft);
  border: 2rpx solid rgba(241, 132, 155, 0.22);
}

.verdict-accept .verdict-bg-glow {
  background: radial-gradient(circle, #F1849B 0%, transparent 65%);
}

.verdict-accept .verdict-bg-glow-2 {
  background: radial-gradient(circle, #D96A85 0%, transparent 65%);
}

/* ===== 不推荐 (Reject) - 警示红 ===== */
.verdict-reject {
  background: #F0F7FF;
  border: 2rpx solid rgba(91, 176, 255, 0.22);
}

.verdict-reject .verdict-bg-glow {
  background: radial-gradient(circle, #5BB0FF 0%, transparent 65%);
}

.verdict-reject .verdict-bg-glow-2 {
  background: radial-gradient(circle, #1A6FB8 0%, transparent 65%);
}

/* ===== 多图对比 (Compare) - 高级金 ===== */
.verdict-compare {
  background: var(--gold-soft);
  border: 2rpx solid rgba(201, 164, 92, 0.28);
}

.verdict-compare .verdict-bg-glow {
  background: radial-gradient(circle, #C9A45C 0%, transparent 65%);
}

.verdict-compare .verdict-bg-glow-2 {
  background: radial-gradient(circle, #B8935A 0%, transparent 65%);
}

/* ===== 商品图片陈列区（独立区块） ===== */
.product-gallery {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: center;
  padding: 20rpx 28rpx 4rpx;
  position: relative;
  z-index: 2;
}

.pg-item {
  position: relative;
  border-radius: 18rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 16rpx rgba(31, 26, 23, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.85);
}

.pg-item.count-1 { width: 220rpx; height: 220rpx; }
.pg-item.count-2 { width: 180rpx; height: 180rpx; }
.pg-item.count-3 { width: 150rpx; height: 150rpx; }
.pg-item.count-4 { width: 130rpx; height: 130rpx; }
.pg-item.count-5,
.pg-item.count-6 { width: 110rpx; height: 110rpx; }

.pg-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* A/B/C/D 角标（对比模式） */
.pg-tag {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, var(--gold), #B8935A);
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  text-align: center;
  line-height: 36rpx;
  box-shadow: 0 2rpx 8rpx rgba(74, 59, 38, 0.3);
}

/* 用户上传图片 - 左侧 */
.user-images {
  display: none; /* DEPRECATED: 由 .product-gallery 接管 */
}

/* ===== 分数区域 - 紧凑横向 ===== */
.score-ring-wrap {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 2;
}

.score-ring-outer {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.score-ring-outer::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  padding: 5rpx;
  background: var(--ring-gradient);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}

.score-ring-inner-wrap {
  position: relative;
  width: 105rpx;
  height: 105rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-ring-glass {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  pointer-events: none;
}

/* 推荐分数环 - 粉 */
.ring-accept {
  --ring-gradient: linear-gradient(135deg, #F1849B, #D96A85);
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 4rpx 24rpx rgba(241, 132, 155, 0.18);
}

.ring-accept .score-ring-glass {
  background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.9) 0%, transparent 60%);
}

.ring-accept .score-ring-inner-wrap {
  background: rgba(255, 255, 255, 0.5);
}

/* 不推荐分数环 - 红 */
.ring-reject {
  --ring-gradient: linear-gradient(135deg, #5BB0FF, #1A6FB8);
  background: rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 24rpx rgba(91, 176, 255, 0.14);
}

.ring-reject .score-ring-glass {
  background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.8) 0%, transparent 60%);
}

.ring-reject .score-ring-inner-wrap {
  background: rgba(255, 255, 255, 0.4);
}

/* 多图对比分数环 - 金 */
.ring-compare {
  --ring-gradient: linear-gradient(135deg, #C9A45C, #B8935A);
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 4rpx 24rpx rgba(201, 164, 92, 0.2);
}

.ring-compare .score-ring-glass {
  background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.9) 0%, transparent 60%);
}

.ring-compare .score-ring-inner-wrap {
  background: rgba(255, 255, 255, 0.5);
}

.score-ring-inner {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 2rpx;
  position: relative;
  z-index: 1;
}

.score-big {
  font-size: 42rpx;
  font-weight: 200;
  letter-spacing: -2rpx;
  line-height: 1;
}

.ring-accept .score-big {
  background: linear-gradient(135deg, #D96A85, #F1849B);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.ring-reject .score-big {
  background: linear-gradient(135deg, #1A6FB8, #5BB0FF);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.ring-compare .score-big {
  background: linear-gradient(135deg, #B8935A, #C9A45C);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.score-max {
  font-size: 22rpx;
  font-weight: 300;
  position: relative;
  z-index: 1;
}

.ring-accept .score-max {
  color: rgba(217, 106, 133, 0.5);
}

.ring-reject .score-max {
  color: rgba(26, 111, 184, 0.5);
}

.ring-compare .score-max {
  color: rgba(184, 147, 90, 0.5);
}

.score-ring-label {
  font-size: 18rpx;
  font-weight: 500;
  letter-spacing: 3rpx;
  margin-top: 2rpx;
  position: relative;
  z-index: 1;
}

.ring-accept .score-ring-label {
  color: rgba(217, 106, 133, 0.55);
}

.ring-reject .score-ring-label {
  color: rgba(26, 111, 184, 0.55);
}

.ring-compare .score-ring-label {
  color: rgba(184, 147, 90, 0.55);
}

/* ===== 右侧信息区 ===== */
.verdict-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-left: 24rpx;
  min-width: 0;
}

/* ===== 决策印章 - 实心大徽章（强结论） ===== */
.verdict-stamp {
  display: inline-flex;
  position: relative;
  z-index: 2;
  margin-bottom: 14rpx;
  transform: rotate(-1.5deg);
}

.stamp-border {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 14rpx 26rpx;
  border-radius: 999rpx;
  position: relative;
  overflow: hidden;
}

.stamp-border::after {
  content: '';
  position: absolute;
  left: 0; right: 0; top: 0;
  height: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.28) 0%, rgba(255,255,255,0) 100%);
  pointer-events: none;
}

.stamp-accept .stamp-border {
  background: linear-gradient(135deg, #F1849B 0%, #D96A85 100%);
  box-shadow: 0 8rpx 22rpx rgba(217, 106, 133, 0.42),
              inset 0 -2rpx 0 rgba(0,0,0,0.06);
}

.stamp-reject .stamp-border {
  background: linear-gradient(135deg, #5BB0FF 0%, #1A6FB8 100%);
  box-shadow: 0 8rpx 22rpx rgba(26, 111, 184, 0.42),
              inset 0 -2rpx 0 rgba(0,0,0,0.06);
}

.stamp-compare .stamp-border {
  background: linear-gradient(135deg, #F5D28A 0%, #C9A45C 100%);
  box-shadow: 0 8rpx 22rpx rgba(201, 164, 92, 0.45),
              inset 0 -2rpx 0 rgba(0,0,0,0.06);
}

.stamp-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.12);
}

.stamp-accept .stamp-icon {
  color: #D96A85;
}

.stamp-reject .stamp-icon {
  color: #1A6FB8;
}

.stamp-compare .stamp-icon {
  color: #B8893A;
}

.stamp-text {
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.18);
  position: relative;
  z-index: 1;
}

/* ===== 个人化理由摘要 ===== */
.personal-reason {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 4rpx;
  padding: 10rpx 16rpx;
  border-radius: 14rpx;
  width: auto;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
  text-align: left;
}

.reason-accept {
  background: rgba(241, 132, 155, 0.08);
  border: 1rpx solid rgba(241, 132, 155, 0.22);
}

.reason-reject {
  background: rgba(91, 176, 255, 0.08);
  border: 1rpx solid rgba(91, 176, 255, 0.22);
}

.reason-compare {
  background: rgba(201, 164, 92, 0.08);
  border: 1rpx solid rgba(201, 164, 92, 0.22);
}

.reason-icon {
  flex-shrink: 0;
  margin-top: 4rpx;
}

.reason-accept .reason-icon {
  color: rgba(217, 106, 133, 0.75);
}

.reason-reject .reason-icon {
  color: rgba(26, 111, 184, 0.75);
}

.reason-compare .reason-icon {
  color: rgba(201, 164, 92, 0.75);
}

.reason-text {
  font-size: 24rpx;
  line-height: 1.7;
  letter-spacing: 0.5rpx;
}

.reason-accept .reason-text {
  color: rgba(160, 70, 90, 0.9);
}

.reason-reject .reason-text {
  color: rgba(20, 90, 150, 0.9);
}

.reason-compare .reason-text {
  color: var(--gold-deep);
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

/* 雷达图 */
.radar-card {
  text-align: center;
}

.radar-canvas {
  width: 600rpx;
  height: 400rpx;
  margin: 0 auto;
}

/* 维度详情 */
.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.dimension-item {
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dimension-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.dim-name-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dim-icon-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(201, 164, 92, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--gold);
}

.dim-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.dim-score-badge {
  display: flex;
  align-items: baseline;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(201, 164, 92, 0.1);
}

.dim-score {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--gold-deep);
}

.dim-score-max {
  font-size: 20rpx;
  color: rgba(74, 59, 38, 0.45);
}

.dim-detail {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-pros, .detail-cons {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  line-height: 1.6;
}

.detail-pros {
  background: rgba(80, 184, 150, 0.06);
  border: 1rpx solid rgba(80, 184, 150, 0.18);
}

.detail-cons {
  background: rgba(91, 176, 255, 0.05);
  border: 1rpx solid rgba(91, 176, 255, 0.16);
}

.detail-icon-bubble {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.bubble-pros {
  background: rgba(80, 184, 150, 0.15);
  color: var(--c-success);
}

.bubble-cons {
  background: rgba(91, 176, 255, 0.12);
  color: var(--c-danger);
}

.detail-text-wrap {
  flex: 1;
  min-width: 0;
}

.detail-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.detail-pros .detail-label {
  color: rgba(58, 130, 108, 0.85);
}

.detail-cons .detail-label {
  color: rgba(20, 90, 150, 0.85);
}

.detail-content {
  font-size: 24rpx;
  line-height: 1.65;
}

.detail-pros .detail-content {
  color: rgba(58, 130, 108, 0.9);
}

.detail-cons .detail-content {
  color: rgba(20, 90, 150, 0.9);
}

/* 评分进度条颜色区分 */
.bar-positive {
  background: linear-gradient(90deg, #50B896, #6FCFA8) !important;
}

.bar-negative {
  background: linear-gradient(90deg, #5BB0FF, #1A6FB8) !important;
}

/* 穿搭优化建议 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(201, 164, 92, 0.15);
  color: var(--gold-deep);
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 最终推荐 */
.final-choice-card {
  background: linear-gradient(135deg, var(--gold-soft), #fff);
  border: 2rpx solid rgba(201, 164, 92, 0.25);
}

.final-choice {
  text-align: center;
}

.choice-label {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--gold-deep);
  margin-bottom: 12rpx;
}

.choice-reason {
  font-size: 26rpx;
  color: #666;
}

/* 排名 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.rank-item.rank-top {
  background: rgba(201, 164, 92, 0.1);
}

.rank-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-top .rank-badge {
  background: var(--gold);
}

/* 对比模式：A/B/C/D 字母标 */
.rank-letter {
  width: 36rpx;
  height: 36rpx;
  border-radius: 10rpx;
  background: linear-gradient(135deg, var(--gold), #B8935A);
  color: #fff;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 36rpx;
  text-align: center;
  flex-shrink: 0;
  box-shadow: 0 2rpx 6rpx rgba(74, 59, 38, 0.25);
}

.comp-letter {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, var(--gold), #B8935A);
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 44rpx;
  text-align: center;
  flex-shrink: 0;
  letter-spacing: 1rpx;
  box-shadow: 0 2rpx 8rpx rgba(74, 59, 38, 0.28);
}

.rank-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.rank-score {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--gold-deep);
}

/* 对比表格 */
.compare-table {
  overflow-x: auto;
}

.table-header, .table-row {
  display: flex;
  min-width: 100%;
}

.table-cell {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.cell-dim {
  flex: 1.5;
  text-align: left;
  font-weight: 600;
  color: #333;
}

.table-header .table-cell {
  font-weight: 700;
  color: #999;
  font-size: 22rpx;
}

/* 各款优缺点 */
.comparison-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.comparison-item {
  padding: 24rpx;
  border-radius: 18rpx;
  background: rgba(201, 164, 92, 0.04);
  border: 1rpx solid rgba(201, 164, 92, 0.14);
}

.comp-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.comp-icon-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(201, 164, 92, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--gold);
}

.comp-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.comp-detail {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.comp-pros {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: rgba(80, 184, 150, 0.06);
  border: 1rpx solid rgba(80, 184, 150, 0.18);
  line-height: 1.6;
}

.comp-cons {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: rgba(91, 176, 255, 0.05);
  border: 1rpx solid rgba(91, 176, 255, 0.16);
  line-height: 1.6;
}

.comp-icon-bubble {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.comp-text-wrap {
  flex: 1;
  min-width: 0;
}

.comp-detail-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.comp-pros .comp-detail-label {
  color: rgba(58, 130, 108, 0.85);
}

.comp-cons .comp-detail-label {
  color: rgba(20, 90, 150, 0.85);
}

.comp-detail-content {
  font-size: 24rpx;
  line-height: 1.65;
}

.comp-pros .comp-detail-content {
  color: rgba(58, 130, 108, 0.9);
}

.comp-cons .comp-detail-content {
  color: rgba(20, 90, 150, 0.9);
}

/* 最佳场景 */
.scenario-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scenario-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(201, 164, 92, 0.04);
  border: 1rpx solid rgba(201, 164, 92, 0.12);
}

.scenario-icon-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(201, 164, 92, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--gold);
  flex-shrink: 0;
  margin-top: 2rpx;
}

.scenario-text-wrap {
  flex: 1;
  min-width: 0;
}

.scenario-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.scenario-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 哒哒说 - 金色温馨风格 */
.dada-comment-card {
  background: linear-gradient(135deg, var(--gold-soft), #fff);
  border: 2rpx solid rgba(201, 164, 92, 0.2);
  position: relative;
}

.dada-avatar {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.dada-comment {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
}

/* 穿搭建议 */
.advice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.advice-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.advice-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.advice-content {
  flex: 1;
}

.advice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 6rpx;
}

.advice-desc {
  font-size: 24rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 4rpx;
}

.advice-reason {
  font-size: 22rpx;
  color: var(--gold-deep);
  line-height: 1.5;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0;
  font-size: 28rpx;
}

.share-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: var(--brand-gradient) !important;
  box-shadow: 0 8rpx 28rpx rgba(241, 132, 155, 0.45);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.share-action-icon {
  font-size: 30rpx;
}

/* ============ 顶部卡片：5 层升级版样式 ============ */

/* L0: 报告头 */
.report-header {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 28rpx 12rpx;
  border-bottom: 1rpx dashed rgba(200, 169, 126, 0.28);
}

.rh-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.rh-brand {
  font-size: 18rpx;
  letter-spacing: 4rpx;
  font-weight: 600;
  color: #C9A45C;
}

.rh-no {
  font-size: 22rpx;
  font-family: 'Courier New', monospace;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 1rpx;
}

.rh-time {
  font-size: 20rpx;
  color: #999;
}

/* L1: 主体（覆盖原 inline style） */
.verdict-section .verdict-main {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 28rpx 16rpx;
  position: relative;
  z-index: 2;
}

.vm-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

/* meta 行：档位 + 置信度 */
.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.tier-pill {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #FAF4E6, #F4E6C7);
  border: 1rpx solid rgba(201, 164, 92, 0.45);
}

.tier-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #C9A45C;
  box-shadow: 0 0 6rpx rgba(201, 164, 92, 0.7);
}

.tier-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #4A3B26;
  letter-spacing: 1rpx;
}

.conf-pill {
  display: inline-flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 6rpx 14rpx;
  border-radius: 24rpx;
  background: rgba(45, 155, 255, 0.08);
  border: 1rpx solid rgba(45, 155, 255, 0.25);
}

.conf-label {
  font-size: 18rpx;
  color: #5A8FB8;
  letter-spacing: 1rpx;
}

.conf-value {
  font-size: 22rpx;
  font-weight: 700;
  color: #2D9BFF;
}

/* 契合度进度条 */
.match-row {
  margin-top: 14rpx;
}

.match-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 6rpx;
}

.match-label {
  font-size: 20rpx;
  color: #888;
  letter-spacing: 1rpx;
}

.match-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #F1849B;
}

.match-bar {
  height: 8rpx;
  border-radius: 4rpx;
  background: rgba(241, 132, 155, 0.12);
  overflow: hidden;
}

.match-bar-inner {
  height: 100%;
  border-radius: 4rpx;
  background: linear-gradient(90deg, #F1849B, #FFB6C8);
  transition: width 0.6s ease;
}

/* L3: echo chips */
.echo-row {
  position: relative;
  z-index: 2;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 4rpx 28rpx 16rpx;
}

.echo-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.55);
  border: 1rpx solid rgba(201, 164, 92, 0.32);
}

.echo-key {
  font-size: 18rpx;
  color: #C9A45C;
  letter-spacing: 1rpx;
}

.echo-key::after {
  content: '·';
  margin: 0 2rpx;
  color: rgba(201, 164, 92, 0.4);
}

.echo-val {
  font-size: 22rpx;
  font-weight: 600;
  color: #1a1a2e;
}

/* L4: 风格定位 + 关键词 + 色调 */
.style-block {
  position: relative;
  z-index: 2;
  padding: 16rpx 28rpx;
  margin: 0 28rpx 14rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.7);
}

.style-tier {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.style-tier-bar {
  display: inline-block;
  width: 6rpx;
  height: 26rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, #C9A45C, #E8C988);
}

.style-tier-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  letter-spacing: 1rpx;
}

.kw-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 10rpx;
}

.kw-tag {
  font-size: 22rpx;
  color: #D96A85;
  background: rgba(241, 132, 155, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.color-tone {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.ct-swatches {
  display: inline-flex;
  gap: 6rpx;
}

.ct-sw {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 600;
}

.ct-sw-main {
  background: rgba(74, 59, 38, 0.08);
  color: #4A3B26;
  border: 1rpx solid rgba(74, 59, 38, 0.18);
}

.ct-sw-accent {
  background: rgba(241, 132, 155, 0.1);
  color: #D96A85;
  border: 1rpx solid rgba(217, 106, 133, 0.25);
}

.ct-mood {
  font-size: 20rpx;
  color: #888;
  font-style: italic;
}

/* L5: 洞察网格 */
.insight-grid {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 0 28rpx 22rpx;
}

.insight-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.45);
  border-left: 4rpx solid #C9A45C;
}

.insight-icon {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  text-align: center;
  line-height: 36rpx;
  font-size: 22rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #C9A45C, #E8C988);
  color: #fff;
}

.insight-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.insight-label {
  font-size: 18rpx;
  color: #C9A45C;
  letter-spacing: 2rpx;
  font-weight: 600;
  margin-bottom: 2rpx;
}

.insight-text {
  font-size: 24rpx;
  color: #1a1a2e;
  line-height: 1.5;
}

.insight-warn {
  border-left-color: #1A6FB8;
  background: rgba(91, 176, 255, 0.06);
}

.insight-warn .insight-icon {
  background: linear-gradient(135deg, #5BB0FF, #1A6FB8);
}

.insight-warn .insight-label {
  color: #1A6FB8;
}

/* personal-reason 在新结构里需要外边距（移出 verdict-main 后） */
.verdict-section > .personal-reason {
  margin: 0 28rpx 14rpx;
  position: relative;
  z-index: 2;
}
