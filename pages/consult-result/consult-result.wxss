/* pages/consult-result/consult-result.wxss */
.page-result {
  min-height: 100vh;
  background: #FAFAF5;
  padding-bottom: 160rpx;
}

/* 顶部决策结论 */
.verdict-section {
  position: relative;
  padding: 60rpx 32rpx 72rpx;
  text-align: center;
  overflow: hidden;
}

.verdict-bg-glow {
  position: absolute;
  top: -120rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 700rpx;
  height: 700rpx;
  border-radius: 50%;
  opacity: 0.18;
  pointer-events: none;
}

.verdict-bg-glow-2 {
  position: absolute;
  bottom: -80rpx;
  right: -60rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  opacity: 0.08;
  pointer-events: none;
}

/* ===== 推荐 (Accept) - 清新绿，自然生机感 ===== */
.verdict-accept {
  background: linear-gradient(168deg, #f2faf6 0%, #e0f4ea 30%, #e8f7f0 60%, #f0faf5 100%);
}

.verdict-accept .verdict-bg-glow {
  background: radial-gradient(circle, #50b896 0%, transparent 65%);
}

.verdict-accept .verdict-bg-glow-2 {
  background: radial-gradient(circle, #3a9a7a 0%, transparent 65%);
}

/* ===== 不推荐 (Reject) - 冷浅蓝，克制清醒 ===== */
.verdict-reject {
  background: linear-gradient(168deg, #eef3f9 0%, #dfe8f3 30%, #e4ecf5 60%, #eef2f8 100%);
}

.verdict-reject .verdict-bg-glow {
  background: radial-gradient(circle, #8aaccc 0%, transparent 65%);
}

.verdict-reject .verdict-bg-glow-2 {
  background: radial-gradient(circle, #7a9ab8 0%, transparent 65%);
}

/* 用户上传图片 */
.user-images {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 2;
}

.user-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

/* ===== 分数环 - 大尺寸，毛玻璃质感 ===== */
.score-ring-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 36rpx;
  position: relative;
  z-index: 2;
}

.score-ring-outer {
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.score-ring-outer::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  padding: 6rpx;
  background: var(--ring-gradient);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}

.score-ring-outer::after {
  content: '';
  position: absolute;
  inset: -4rpx;
  border-radius: 50%;
  padding: 2rpx;
  background: var(--ring-gradient-outer);
  opacity: 0.3;
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}

.score-ring-inner-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-ring-glass {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  pointer-events: none;
}

/* 推荐分数环 */
.ring-accept {
  --ring-gradient: linear-gradient(135deg, #50b896, #3a9a7a, #50b896);
  --ring-gradient-outer: linear-gradient(135deg, #50b896, #3a9a7a);
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 4rpx 40rpx rgba(80, 184, 150, 0.2), 0 0 80rpx rgba(80, 184, 150, 0.08), inset 0 1rpx 0rpx rgba(255, 255, 255, 0.8);
}

.ring-accept .score-ring-glass {
  background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.9) 0%, transparent 60%);
}

.ring-accept .score-ring-inner-wrap {
  background: rgba(255, 255, 255, 0.5);
}

/* 不推荐分数环 */
.ring-reject {
  --ring-gradient: linear-gradient(135deg, #8aaccc, #7a9ab8, #8aaccc);
  --ring-gradient-outer: linear-gradient(135deg, #8aaccc, #7a9ab8);
  background: rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 40rpx rgba(138, 172, 204, 0.15), 0 0 80rpx rgba(138, 172, 204, 0.06), inset 0 1rpx 0rpx rgba(255, 255, 255, 0.7);
}

.ring-reject .score-ring-glass {
  background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.8) 0%, transparent 60%);
}

.ring-reject .score-ring-inner-wrap {
  background: rgba(255, 255, 255, 0.4);
}

.score-ring-inner {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 2rpx;
  position: relative;
  z-index: 1;
}

.score-big {
  font-size: 80rpx;
  font-weight: 200;
  letter-spacing: -4rpx;
  line-height: 1;
}

.ring-accept .score-big {
  background: linear-gradient(135deg, #3a9a7a, #50b896);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.ring-reject .score-big {
  background: linear-gradient(135deg, #7a9ab8, #8aaccc);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.score-max {
  font-size: 28rpx;
  font-weight: 300;
  position: relative;
  z-index: 1;
}

.ring-accept .score-max {
  color: rgba(58, 154, 122, 0.45);
}

.ring-reject .score-max {
  color: rgba(122, 154, 184, 0.45);
}

.score-ring-label {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
  margin-top: 4rpx;
  position: relative;
  z-index: 1;
}

.ring-accept .score-ring-label {
  color: rgba(58, 154, 122, 0.5);
}

.ring-reject .score-ring-label {
  color: rgba(122, 154, 184, 0.5);
}

/* ===== 决策印章 - 推荐与不推荐强区分 ===== */
.verdict-stamp {
  display: inline-flex;
  position: relative;
  z-index: 2;
}

.stamp-border {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 44rpx 20rpx 16rpx;
  border-radius: 56rpx;
  position: relative;
}

.stamp-border::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 56rpx;
  padding: 2rpx;
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}

/* 推荐印章 - 清新绿实底 + 柔光 */
.stamp-accept .stamp-border {
  background: linear-gradient(135deg, #50b896, #3a9a7a);
  box-shadow: 0 6rpx 28rpx rgba(80, 184, 150, 0.35);
}

.stamp-accept .stamp-border::before {
  background: transparent;
}

.stamp-accept {
  filter: none;
}

/* 不推荐印章 - 冷蓝实底 + 克制 */
.stamp-reject .stamp-border {
  background: linear-gradient(135deg, #8aaccc, #7a9ab8);
  box-shadow: 0 6rpx 28rpx rgba(138, 172, 204, 0.25);
}

.stamp-reject .stamp-border::before {
  background: transparent;
}

.stamp-reject {
  filter: none;
}

.stamp-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.stamp-accept .stamp-icon {
  background: rgba(255, 255, 255, 0.25);
  color: #fff;
  box-shadow: none;
}

.stamp-reject .stamp-icon {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  box-shadow: none;
}

.stamp-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
}

.stamp-sub {
  font-size: 18rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.stamp-text {
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 3rpx;
}

.stamp-accept .stamp-sub {
  color: rgba(255, 255, 255, 0.75);
}

.stamp-accept .stamp-text {
  color: #fff;
}

.stamp-reject .stamp-sub {
  color: rgba(255, 255, 255, 0.7);
}

.stamp-reject .stamp-text {
  color: #fff;
}

/* ===== 个人化理由摘要 ===== */
.personal-reason {
  display: inline-flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 24rpx;
  padding: 16rpx 28rpx;
  border-radius: 20rpx;
  max-width: 560rpx;
  position: relative;
  z-index: 2;
  text-align: left;
}

.reason-accept {
  background: rgba(80, 184, 150, 0.08);
  border: 1rpx solid rgba(80, 184, 150, 0.2);
}

.reason-reject {
  background: rgba(138, 172, 204, 0.08);
  border: 1rpx solid rgba(138, 172, 204, 0.15);
}

.reason-icon {
  flex-shrink: 0;
  margin-top: 4rpx;
}

.reason-accept .reason-icon {
  color: rgba(58, 154, 122, 0.7);
}

.reason-reject .reason-icon {
  color: rgba(122, 154, 184, 0.7);
}

.reason-text {
  font-size: 24rpx;
  line-height: 1.7;
  letter-spacing: 0.5rpx;
}

.reason-accept .reason-text {
  color: rgba(58, 130, 108, 0.85);
}

.reason-reject .reason-text {
  color: rgba(100, 130, 160, 0.85);
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

/* 雷达图 */
.radar-card {
  text-align: center;
}

.radar-canvas {
  width: 600rpx;
  height: 400rpx;
  margin: 0 auto;
}

/* 维度详情 */
.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dimension-item {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dimension-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dim-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.dim-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #8B7355;
}

.dim-detail {
  margin-top: 12rpx;
}

.detail-pros, .detail-cons {
  font-size: 24rpx;
  line-height: 1.6;
  padding: 4rpx 0;
}

.detail-pros {
  color: #27ae60;
}

.detail-cons {
  color: #e74c3c;
}

/* 评分进度条颜色区分 */
.bar-positive {
  background: linear-gradient(90deg, #27ae60, #2ecc71) !important;
}

.bar-negative {
  background: linear-gradient(90deg, #e74c3c, #c0392b) !important;
}

/* 穿搭优化建议 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(200, 169, 126, 0.15);
  color: #8B7355;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 最终推荐 */
.final-choice-card {
  background: linear-gradient(135deg, #fff8f0, #fff);
  border: 2rpx solid rgba(200, 169, 126, 0.2);
}

.final-choice {
  text-align: center;
}

.choice-label {
  font-size: 48rpx;
  font-weight: 800;
  color: #8B7355;
  margin-bottom: 12rpx;
}

.choice-reason {
  font-size: 26rpx;
  color: #666;
}

/* 排名 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.rank-item.rank-top {
  background: rgba(200, 169, 126, 0.1);
}

.rank-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-top .rank-badge {
  background: #C8A97E;
}

.rank-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.rank-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #8B7355;
}

/* 对比表格 */
.compare-table {
  overflow-x: auto;
}

.table-header, .table-row {
  display: flex;
  min-width: 100%;
}

.table-cell {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.cell-dim {
  flex: 1.5;
  text-align: left;
  font-weight: 600;
  color: #333;
}

.table-header .table-cell {
  font-weight: 700;
  color: #999;
  font-size: 22rpx;
}

/* 各款优缺点 */
.comparison-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.comparison-item {
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.comp-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
}

.comp-pros {
  font-size: 24rpx;
  color: #27ae60;
  margin-bottom: 4rpx;
}

.comp-cons {
  font-size: 24rpx;
  color: #e74c3c;
}

/* 最佳场景 */
.scenario-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scenario-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.scenario-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  flex-shrink: 0;
}

.scenario-desc {
  font-size: 24rpx;
  color: #666;
}

/* 搭搭评论 */
.dada-comment-card {
  background: linear-gradient(135deg, #f0f4ff, #fff);
  border: 2rpx solid rgba(79, 172, 254, 0.15);
  position: relative;
}

.dada-avatar {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.dada-comment {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
}

/* 穿搭建议 */
.advice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.advice-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.advice-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.advice-content {
  flex: 1;
}

.advice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 6rpx;
}

.advice-desc {
  font-size: 24rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 4rpx;
}

.advice-reason {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 1.5;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0;
  font-size: 28rpx;
}

.share-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #eaacbe, #d4956a) !important;
  box-shadow: 0 8rpx 28rpx rgba(234, 172, 190, 0.45);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.share-action-icon {
  font-size: 30rpx;
}
