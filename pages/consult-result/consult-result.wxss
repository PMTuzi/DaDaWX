/* pages/consult-result/consult-result.wxss */
.page-result {
  min-height: 100vh;
  background: #f5f5f7;
  padding-bottom: 160rpx;
}

/* 顶部决策结论 */
.verdict-section {
  position: relative;
  padding: 48rpx 32rpx 56rpx;
  text-align: center;
  overflow: hidden;
}

.verdict-bg-glow {
  position: absolute;
  top: -60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  opacity: 0.15;
  pointer-events: none;
}

.verdict-accept {
  background: linear-gradient(180deg, #f0faf3 0%, #e8f5ed 40%, #f5f5f7 100%);
}

.verdict-accept .verdict-bg-glow {
  background: radial-gradient(circle, #27ae60 0%, transparent 70%);
}

.verdict-reject {
  background: linear-gradient(180deg, #fdf2f2 0%, #fde8e8 40%, #f5f5f7 100%);
}

.verdict-reject .verdict-bg-glow {
  background: radial-gradient(circle, #e74c3c 0%, transparent 70%);
}

/* 用户上传图片 */
.user-images {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.user-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}

/* 分数环 */
.score-ring-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 28rpx;
}

.score-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.score-ring::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  padding: 8rpx;
  background: linear-gradient(135deg, var(--ring-start), var(--ring-end));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}

.ring-accept {
  --ring-start: #27ae60;
  --ring-end: #2ecc71;
  background: rgba(39, 174, 96, 0.06);
  box-shadow: 0 8rpx 40rpx rgba(39, 174, 96, 0.15), inset 0 2rpx 8rpx rgba(39, 174, 96, 0.08);
}

.ring-reject {
  --ring-start: #e74c3c;
  --ring-end: #c0392b;
  background: rgba(231, 76, 60, 0.06);
  box-shadow: 0 8rpx 40rpx rgba(231, 76, 60, 0.15), inset 0 2rpx 8rpx rgba(231, 76, 60, 0.08);
}

.score-ring-inner {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
}

.score-big {
  font-size: 64rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
}

.ring-accept .score-big {
  color: #27ae60;
}

.ring-reject .score-big {
  color: #e74c3c;
}

.score-max {
  font-size: 24rpx;
  font-weight: 600;
  color: #999;
}

/* 决策徽章 */
.verdict-badge {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 36rpx 16rpx 12rpx;
  border-radius: 48rpx;
  box-shadow: 0 4rpx 24rpx var(--badge-shadow);
}

.badge-accept {
  --badge-shadow: rgba(39, 174, 96, 0.2);
  background: linear-gradient(135deg, #27ae60, #2ecc71);
}

.badge-reject {
  --badge-shadow: rgba(231, 76, 60, 0.2);
  background: linear-gradient(135deg, #e74c3c, #c0392b);
}

.badge-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 900;
  flex-shrink: 0;
}

.badge-content {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 2rpx;
}

.badge-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  font-weight: 500;
  letter-spacing: 1rpx;
}

.badge-verdict {
  font-size: 30rpx;
  color: #fff;
  font-weight: 800;
  letter-spacing: 2rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

/* 雷达图 */
.radar-card {
  text-align: center;
}

.radar-canvas {
  width: 600rpx;
  height: 400rpx;
  margin: 0 auto;
}

/* 维度详情 */
.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dimension-item {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dimension-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dim-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.dim-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #e8a87c;
}

.dim-detail {
  margin-top: 12rpx;
}

.detail-pros, .detail-cons {
  font-size: 24rpx;
  line-height: 1.6;
  padding: 4rpx 0;
}

.detail-pros {
  color: #27ae60;
}

.detail-cons {
  color: #e74c3c;
}

/* 评分进度条颜色区分 */
.bar-positive {
  background: linear-gradient(90deg, #27ae60, #2ecc71) !important;
}

.bar-negative {
  background: linear-gradient(90deg, #e74c3c, #c0392b) !important;
}

/* 穿搭优化建议 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(232, 168, 124, 0.12);
  color: #e8a87c;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 最终推荐 */
.final-choice-card {
  background: linear-gradient(135deg, #fff8f0, #fff);
  border: 2rpx solid rgba(232, 168, 124, 0.2);
}

.final-choice {
  text-align: center;
}

.choice-label {
  font-size: 48rpx;
  font-weight: 800;
  color: #e8a87c;
  margin-bottom: 12rpx;
}

.choice-reason {
  font-size: 26rpx;
  color: #666;
}

/* 排名 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.rank-item.rank-top {
  background: rgba(232, 168, 124, 0.1);
}

.rank-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-top .rank-badge {
  background: #e8a87c;
}

.rank-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.rank-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #e8a87c;
}

/* 对比表格 */
.compare-table {
  overflow-x: auto;
}

.table-header, .table-row {
  display: flex;
  min-width: 100%;
}

.table-cell {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.cell-dim {
  flex: 1.5;
  text-align: left;
  font-weight: 600;
  color: #1a1a2e;
}

.table-header .table-cell {
  font-weight: 700;
  color: #999;
  font-size: 22rpx;
}

/* 各款优缺点 */
.comparison-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.comparison-item {
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.comp-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.comp-pros {
  font-size: 24rpx;
  color: #27ae60;
  margin-bottom: 4rpx;
}

.comp-cons {
  font-size: 24rpx;
  color: #e74c3c;
}

/* 最佳场景 */
.scenario-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scenario-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.scenario-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  flex-shrink: 0;
}

.scenario-desc {
  font-size: 24rpx;
  color: #666;
}

/* 搭搭评论 */
.dada-comment-card {
  background: linear-gradient(135deg, #f0f4ff, #fff);
  border: 2rpx solid rgba(79, 172, 254, 0.15);
  position: relative;
}

.dada-avatar {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.dada-comment {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
}

/* 穿搭建议 */
.advice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.advice-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.advice-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.advice-content {
  flex: 1;
}

.advice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 6rpx;
}

.advice-desc {
  font-size: 24rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 4rpx;
}

.advice-reason {
  font-size: 22rpx;
  color: #e8a87c;
  line-height: 1.5;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0;
  font-size: 28rpx;
}

.share-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #eaacbe, #d4956a) !important;
  box-shadow: 0 8rpx 28rpx rgba(234, 172, 190, 0.45);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.share-action-icon {
  font-size: 30rpx;
}
