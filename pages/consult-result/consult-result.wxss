/* pages/consult-result/consult-result.wxss */
.page-result {
  min-height: 100vh;
  background: #FAFAF5;
  padding-bottom: 160rpx;
}

/* 顶部决策结论 */
.verdict-section {
  position: relative;
  padding: 0;
  margin: 24rpx 24rpx 0;
  border-radius: 28rpx;
  overflow: hidden;
}

.verdict-bg-glow {
  position: absolute;
  top: -80rpx;
  right: -40rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  opacity: 0.15;
  pointer-events: none;
}

.verdict-bg-glow-2 {
  position: absolute;
  bottom: -60rpx;
  left: -30rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  opacity: 0.08;
  pointer-events: none;
}

/* ===== 推荐 (Accept) - 清新绿，自然生机感 ===== */
.verdict-accept {
  background: #F2FAF6;
  border: 2rpx solid rgba(80, 184, 150, 0.2);
}

.verdict-accept .verdict-bg-glow {
  background: radial-gradient(circle, #50b896 0%, transparent 65%);
}

.verdict-accept .verdict-bg-glow-2 {
  background: radial-gradient(circle, #3a9a7a 0%, transparent 65%);
}

/* ===== 不推荐 (Reject) - 柔红系，警示醒目 ===== */
.verdict-reject {
  background: #FFF5F5;
  border: 2rpx solid rgba(204, 120, 120, 0.2);
}

.verdict-reject .verdict-bg-glow {
  background: radial-gradient(circle, #cc7878 0%, transparent 65%);
}

.verdict-reject .verdict-bg-glow-2 {
  background: radial-gradient(circle, #b86060 0%, transparent 65%);
}

/* ===== 多图对比 (Compare) - 金色系，尊贵甄选 ===== */
.verdict-compare {
  background: #FFFBF2;
  border: 2rpx solid rgba(200, 169, 126, 0.25);
}

.verdict-compare .verdict-bg-glow {
  background: radial-gradient(circle, #C9A96E 0%, transparent 65%);
}

.verdict-compare .verdict-bg-glow-2 {
  background: radial-gradient(circle, #B8935A 0%, transparent 65%);
}

/* 用户上传图片 - 左侧 */
.user-images {
  display: flex;
  gap: 10rpx;
  position: relative;
  z-index: 2;
  flex-shrink: 0;
}

.user-image {
  width: 80rpx;
  height: 80rpx;
  border-radius: 14rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* ===== 分数区域 - 紧凑横向 ===== */
.score-ring-wrap {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 2;
}

.score-ring-outer {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.score-ring-outer::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 50%;
  padding: 5rpx;
  background: var(--ring-gradient);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}

.score-ring-inner-wrap {
  position: relative;
  width: 105rpx;
  height: 105rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-ring-glass {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  pointer-events: none;
}

/* 推荐分数环 */
.ring-accept {
  --ring-gradient: linear-gradient(135deg, #50b896, #3a9a7a);
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 4rpx 24rpx rgba(80, 184, 150, 0.15);
}

.ring-accept .score-ring-glass {
  background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.9) 0%, transparent 60%);
}

.ring-accept .score-ring-inner-wrap {
  background: rgba(255, 255, 255, 0.5);
}

/* 不推荐分数环 */
.ring-reject {
  --ring-gradient: linear-gradient(135deg, #cc7878, #b86060);
  background: rgba(255, 255, 255, 0.6);
  box-shadow: 0 4rpx 24rpx rgba(204, 120, 120, 0.12);
}

.ring-reject .score-ring-glass {
  background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.8) 0%, transparent 60%);
}

.ring-reject .score-ring-inner-wrap {
  background: rgba(255, 255, 255, 0.4);
}

/* 多图对比分数环 - 金色 */
.ring-compare {
  --ring-gradient: linear-gradient(135deg, #C9A96E, #B8935A);
  background: rgba(255, 255, 255, 0.7);
  box-shadow: 0 4rpx 24rpx rgba(200, 169, 126, 0.18);
}

.ring-compare .score-ring-glass {
  background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.9) 0%, transparent 60%);
}

.ring-compare .score-ring-inner-wrap {
  background: rgba(255, 255, 255, 0.5);
}

.score-ring-inner {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 2rpx;
  position: relative;
  z-index: 1;
}

.score-big {
  font-size: 42rpx;
  font-weight: 200;
  letter-spacing: -2rpx;
  line-height: 1;
}

.ring-accept .score-big {
  background: linear-gradient(135deg, #3a9a7a, #50b896);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.ring-reject .score-big {
  background: linear-gradient(135deg, #b86060, #cc7878);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.ring-compare .score-big {
  background: linear-gradient(135deg, #B8935A, #C9A96E);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.score-max {
  font-size: 22rpx;
  font-weight: 300;
  position: relative;
  z-index: 1;
}

.ring-accept .score-max {
  color: rgba(58, 154, 122, 0.45);
}

.ring-reject .score-max {
  color: rgba(184, 96, 96, 0.45);
}

.ring-compare .score-max {
  color: rgba(184, 147, 90, 0.45);
}

.score-ring-label {
  font-size: 18rpx;
  font-weight: 500;
  letter-spacing: 3rpx;
  margin-top: 2rpx;
  position: relative;
  z-index: 1;
}

.ring-accept .score-ring-label {
  color: rgba(58, 154, 122, 0.5);
}

.ring-reject .score-ring-label {
  color: rgba(184, 96, 96, 0.5);
}

.ring-compare .score-ring-label {
  color: rgba(184, 147, 90, 0.5);
}

/* ===== 右侧信息区 ===== */
.verdict-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-left: 24rpx;
  min-width: 0;
}

/* ===== 决策印章 - 纯色图标+文字 ===== */
.verdict-stamp {
  display: inline-flex;
  position: relative;
  z-index: 2;
  margin-bottom: 8rpx;
}

.stamp-border {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 0;
}

.stamp-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.stamp-accept .stamp-icon {
  background: #C9A96E;
  color: #fff;
}

.stamp-reject .stamp-icon {
  background: #cc7878;
  color: #fff;
}

.stamp-compare .stamp-icon {
  background: #C9A96E;
  color: #fff;
}

.stamp-text {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.stamp-accept .stamp-text {
  color: #3a7a5a;
}

.stamp-reject .stamp-text {
  color: #b86060;
}

.stamp-compare .stamp-text {
  color: #9A7B4F;
}

/* ===== 个人化理由摘要 ===== */
.personal-reason {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-top: 4rpx;
  padding: 10rpx 16rpx;
  border-radius: 14rpx;
  width: auto;
  box-sizing: border-box;
  position: relative;
  z-index: 2;
  text-align: left;
}

.reason-accept {
  background: rgba(80, 184, 150, 0.08);
  border: 1rpx solid rgba(80, 184, 150, 0.2);
}

.reason-reject {
  background: rgba(204, 120, 120, 0.08);
  border: 1rpx solid rgba(204, 120, 120, 0.2);
}

.reason-compare {
  background: rgba(200, 169, 126, 0.08);
  border: 1rpx solid rgba(200, 169, 126, 0.2);
}

.reason-icon {
  flex-shrink: 0;
  margin-top: 4rpx;
}

.reason-accept .reason-icon {
  color: rgba(58, 154, 122, 0.7);
}

.reason-reject .reason-icon {
  color: rgba(184, 96, 96, 0.7);
}

.reason-compare .reason-icon {
  color: rgba(184, 147, 90, 0.7);
}

.reason-text {
  font-size: 24rpx;
  line-height: 1.7;
  letter-spacing: 0.5rpx;
}

.reason-accept .reason-text {
  color: rgba(58, 130, 108, 0.85);
}

.reason-reject .reason-text {
  color: rgba(160, 80, 80, 0.85);
}

.reason-compare .reason-text {
  color: rgba(154, 123, 79, 0.85);
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
}

/* 雷达图 */
.radar-card {
  text-align: center;
}

.radar-canvas {
  width: 600rpx;
  height: 400rpx;
  margin: 0 auto;
}

/* 维度详情 */
.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.dimension-item {
  padding-bottom: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dimension-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.dim-name-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dim-icon-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(200, 169, 126, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #C9A96E;
}

.dim-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.dim-score-badge {
  display: flex;
  align-items: baseline;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(139, 115, 85, 0.08);
}

.dim-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #8B7355;
}

.dim-score-max {
  font-size: 20rpx;
  color: rgba(139, 115, 85, 0.5);
}

.dim-detail {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.detail-pros, .detail-cons {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  line-height: 1.6;
}

.detail-pros {
  background: rgba(39, 174, 96, 0.05);
  border: 1rpx solid rgba(39, 174, 96, 0.12);
}

.detail-cons {
  background: rgba(231, 76, 60, 0.04);
  border: 1rpx solid rgba(231, 76, 60, 0.1);
}

.detail-icon-bubble {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.bubble-pros {
  background: rgba(39, 174, 96, 0.12);
  color: #27ae60;
}

.bubble-cons {
  background: rgba(231, 76, 60, 0.1);
  color: #e74c3c;
}

.detail-text-wrap {
  flex: 1;
  min-width: 0;
}

.detail-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.detail-pros .detail-label {
  color: rgba(39, 174, 96, 0.7);
}

.detail-cons .detail-label {
  color: rgba(231, 76, 60, 0.7);
}

.detail-content {
  font-size: 24rpx;
  line-height: 1.65;
}

.detail-pros .detail-content {
  color: rgba(39, 130, 90, 0.85);
}

.detail-cons .detail-content {
  color: rgba(180, 60, 50, 0.85);
}

/* 评分进度条颜色区分 */
.bar-positive {
  background: linear-gradient(90deg, #27ae60, #2ecc71) !important;
}

.bar-negative {
  background: linear-gradient(90deg, #e74c3c, #c0392b) !important;
}

/* 穿搭优化建议 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(200, 169, 126, 0.15);
  color: #8B7355;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 最终推荐 */
.final-choice-card {
  background: linear-gradient(135deg, #fff8f0, #fff);
  border: 2rpx solid rgba(200, 169, 126, 0.2);
}

.final-choice {
  text-align: center;
}

.choice-label {
  font-size: 48rpx;
  font-weight: 800;
  color: #8B7355;
  margin-bottom: 12rpx;
}

.choice-reason {
  font-size: 26rpx;
  color: #666;
}

/* 排名 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.rank-item.rank-top {
  background: rgba(200, 169, 126, 0.1);
}

.rank-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-top .rank-badge {
  background: #C8A97E;
}

.rank-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.rank-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #8B7355;
}

/* 对比表格 */
.compare-table {
  overflow-x: auto;
}

.table-header, .table-row {
  display: flex;
  min-width: 100%;
}

.table-cell {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.cell-dim {
  flex: 1.5;
  text-align: left;
  font-weight: 600;
  color: #333;
}

.table-header .table-cell {
  font-weight: 700;
  color: #999;
  font-size: 22rpx;
}

/* 各款优缺点 */
.comparison-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.comparison-item {
  padding: 24rpx;
  border-radius: 18rpx;
  background: rgba(200, 169, 126, 0.04);
  border: 1rpx solid rgba(200, 169, 126, 0.12);
}

.comp-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.comp-icon-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(200, 169, 126, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #C9A96E;
}

.comp-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.comp-detail {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.comp-pros {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: rgba(39, 174, 96, 0.05);
  border: 1rpx solid rgba(39, 174, 96, 0.12);
  line-height: 1.6;
}

.comp-cons {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 14rpx;
  background: rgba(231, 76, 60, 0.04);
  border: 1rpx solid rgba(231, 76, 60, 0.1);
  line-height: 1.6;
}

.comp-icon-bubble {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.comp-text-wrap {
  flex: 1;
  min-width: 0;
}

.comp-detail-label {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  letter-spacing: 1rpx;
}

.comp-pros .comp-detail-label {
  color: rgba(39, 174, 96, 0.7);
}

.comp-cons .comp-detail-label {
  color: rgba(231, 76, 60, 0.7);
}

.comp-detail-content {
  font-size: 24rpx;
  line-height: 1.65;
}

.comp-pros .comp-detail-content {
  color: rgba(39, 130, 90, 0.85);
}

.comp-cons .comp-detail-content {
  color: rgba(180, 60, 50, 0.85);
}

/* 最佳场景 */
.scenario-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scenario-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(200, 169, 126, 0.04);
  border: 1rpx solid rgba(200, 169, 126, 0.1);
}

.scenario-icon-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(200, 169, 126, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #C9A96E;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.scenario-text-wrap {
  flex: 1;
  min-width: 0;
}

.scenario-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.scenario-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 搭搭评论 */
.dada-comment-card {
  background: linear-gradient(135deg, #f0f4ff, #fff);
  border: 2rpx solid rgba(79, 172, 254, 0.15);
  position: relative;
}

.dada-avatar {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.dada-comment {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
}

/* 穿搭建议 */
.advice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.advice-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.advice-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.advice-content {
  flex: 1;
}

.advice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 6rpx;
}

.advice-desc {
  font-size: 24rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 4rpx;
}

.advice-reason {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 1.5;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0;
  font-size: 28rpx;
}

.share-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: linear-gradient(135deg, #eaacbe, #d4956a) !important;
  box-shadow: 0 8rpx 28rpx rgba(234, 172, 190, 0.45);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.share-action-icon {
  font-size: 30rpx;
}
