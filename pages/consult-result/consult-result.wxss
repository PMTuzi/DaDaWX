/* pages/consult-result/consult-result.wxss */
.page-result {
  min-height: 100vh;
  background: #f5f5f7;
  padding-bottom: 160rpx;
}

/* 顶部决策结论 */
.verdict-section {
  padding: 56rpx 32rpx 48rpx;
  text-align: center;
}

.verdict-accept {
  background: linear-gradient(180deg, rgba(39, 174, 96, 0.08) 0%, transparent 100%);
}

.verdict-reject {
  background: linear-gradient(180deg, rgba(231, 76, 60, 0.08) 0%, transparent 100%);
}

.verdict-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.verdict-text {
  font-size: 52rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
}

.verdict-accept .verdict-text {
  color: #27ae60;
}

.verdict-reject .verdict-text {
  color: #e74c3c;
}

/* 用户上传图片 */
.user-images {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.user-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.verdict-score {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
}

.score-big {
  font-size: 72rpx;
  font-weight: 800;
}

.score-accept {
  color: #27ae60;
}

.score-reject {
  color: #e74c3c;
}

.score-max {
  font-size: 28rpx;
  color: #999;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 0 24rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 24rpx;
}

/* 雷达图 */
.radar-card {
  text-align: center;
}

.radar-canvas {
  width: 600rpx;
  height: 400rpx;
  margin: 0 auto;
}

/* 维度详情 */
.dimension-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.dimension-item {
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.dimension-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.dim-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.dim-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.dim-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #e8a87c;
}

.dim-detail {
  margin-top: 12rpx;
}

.detail-pros, .detail-cons {
  font-size: 24rpx;
  line-height: 1.6;
  padding: 4rpx 0;
}

.detail-pros {
  color: #27ae60;
}

.detail-cons {
  color: #e74c3c;
}

/* 评分进度条颜色区分 */
.bar-positive {
  background: linear-gradient(90deg, #27ae60, #2ecc71) !important;
}

.bar-negative {
  background: linear-gradient(90deg, #e74c3c, #c0392b) !important;
}

/* 穿搭优化建议 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-num {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(232, 168, 124, 0.12);
  color: #e8a87c;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 最终推荐 */
.final-choice-card {
  background: linear-gradient(135deg, #fff8f0, #fff);
  border: 2rpx solid rgba(232, 168, 124, 0.2);
}

.final-choice {
  text-align: center;
}

.choice-label {
  font-size: 48rpx;
  font-weight: 800;
  color: #e8a87c;
  margin-bottom: 12rpx;
}

.choice-reason {
  font-size: 26rpx;
  color: #666;
}

/* 排名 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.rank-item.rank-top {
  background: rgba(232, 168, 124, 0.1);
}

.rank-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-top .rank-badge {
  background: #e8a87c;
}

.rank-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.rank-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #e8a87c;
}

/* 对比表格 */
.compare-table {
  overflow-x: auto;
}

.table-header, .table-row {
  display: flex;
  min-width: 100%;
}

.table-cell {
  flex: 1;
  padding: 16rpx 12rpx;
  font-size: 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.cell-dim {
  flex: 1.5;
  text-align: left;
  font-weight: 600;
  color: #1a1a2e;
}

.table-header .table-cell {
  font-weight: 700;
  color: #999;
  font-size: 22rpx;
}

/* 各款优缺点 */
.comparison-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.comparison-item {
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.comp-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.comp-pros {
  font-size: 24rpx;
  color: #27ae60;
  margin-bottom: 4rpx;
}

.comp-cons {
  font-size: 24rpx;
  color: #e74c3c;
}

/* 最佳场景 */
.scenario-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scenario-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.scenario-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  flex-shrink: 0;
}

.scenario-desc {
  font-size: 24rpx;
  color: #666;
}

/* 搭搭评论 */
.dada-comment-card {
  background: linear-gradient(135deg, #f0f4ff, #fff);
  border: 2rpx solid rgba(79, 172, 254, 0.15);
  position: relative;
}

.dada-avatar {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.dada-comment {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
}

/* 穿搭建议 */
.advice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.advice-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
}

.advice-icon {
  font-size: 40rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.advice-content {
  flex: 1;
}

.advice-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 6rpx;
}

.advice-desc {
  font-size: 24rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 4rpx;
}

.advice-reason {
  font-size: 22rpx;
  color: #e8a87c;
  line-height: 1.5;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0;
  font-size: 28rpx;
}
