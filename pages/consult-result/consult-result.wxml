<!--pages/consult-result/consult-result.wxml-->
<view class="page-result" wx:if="{{record}}">
  <!-- 顶部决策结论 -->
  <view class="verdict-section {{record.verdict === '建议购买' || record.verdict === '建议自留' || record.verdict === '建议入手' ? 'verdict-accept' : 'verdict-reject'}}">
    <view class="verdict-bg-glow"></view>
    <view class="verdict-bg-glow-2"></view>
    <!-- 用户上传图片 -->
    <view class="user-images" wx:if="{{record.images && record.images.length}}">
      <image class="user-image" wx:for="{{record.images}}" wx:key="index"
        src="{{item.localPath || item.imageUrl}}" mode="aspectFill" bindtap="onPreviewImage" data-url="{{item.localPath || item.imageUrl}}"
        binderror="onImageError"></image>
    </view>
    <!-- 分数环 -->
    <view class="score-ring-wrap" wx:if="{{record.totalScore}}">
      <view class="score-ring-outer {{record.verdict === '建议购买' || record.verdict === '建议自留' || record.verdict === '建议入手' ? 'ring-accept' : 'ring-reject'}}">
        <view class="score-ring-inner-wrap">
          <view class="score-ring-glass"></view>
          <view class="score-ring-inner">
            <text class="score-big">{{record.totalScore}}</text>
            <text class="score-max">.0</text>
          </view>
          <view class="score-ring-label">综合评分</view>
        </view>
      </view>
    </view>
    <!-- 决策标签 -->
    <view class="verdict-stamp {{record.verdict === '建议购买' || record.verdict === '建议自留' || record.verdict === '建议入手' ? 'stamp-accept' : 'stamp-reject'}}">
      <view class="stamp-border">
        <view class="stamp-icon">{{record.verdict === '建议购买' || record.verdict === '建议自留' || record.verdict === '建议入手' ? '✓' : '✕'}}</view>
        <view class="stamp-content">
          <text class="stamp-sub">{{isCompare ? '最优推荐' : 'AI决策'}}</text>
          <text class="stamp-text">{{record.verdict}}</text>
        </view>
      </view>
    </view>
    <!-- 个人化理由摘要 -->
    <view class="personal-reason {{record.verdict === '建议购买' || record.verdict === '建议自留' || record.verdict === '建议入手' ? 'reason-accept' : 'reason-reject'}}" wx:if="{{record.personalReason}}">
      <view class="reason-icon icon icon-user" style="font-size:22rpx;"></view>
      <text class="reason-text">{{record.personalReason}}</text>
    </view>
  </view>

  <!-- ===== 单品模式 ===== -->
  <block wx:if="{{!isCompare}}">
    <!-- 雷达图 -->
    <view class="card radar-card">
      <view class="card-title">4维评分雷达图</view>
      <canvas type="2d" id="radarCanvas" class="radar-canvas"></canvas>
    </view>

    <!-- 各维度详情 -->
    <view class="card">
      <view class="card-title">各维度分析</view>
      <view class="dimension-list">
        <!-- 版型适合度 -->
        <view class="dimension-item">
          <view class="dim-header">
            <text class="dim-name"><view class="icon icon-scissors" style="font-size:24rpx;margin-right:4rpx;"></view> 版型适合度</text>
            <text class="dim-score">{{record.scores.fitScore}}/10</text>
          </view>
          <view class="score-bar">
            <view class="score-bar-inner {{record.scores.fitScore >= 7 ? 'bar-positive' : record.scores.fitScore < 5 ? 'bar-negative' : ''}}" style="width: {{record.scores.fitScore * 10}}%"></view>
          </view>
          <view class="dim-detail" wx:if="{{record.details && record.details.fitScore}}">
            <view class="detail-pros"><view class="icon icon-good" style="font-size:24rpx;color:var(--success);margin-right:4rpx;"></view> {{record.details.fitScore.pros}}</view>
            <view class="detail-cons"><view class="icon icon-warning" style="font-size:24rpx;color:var(--danger);margin-right:4rpx;"></view> {{record.details.fitScore.cons}}</view>
          </view>
        </view>
        <!-- 颜色匹配度 -->
        <view class="dimension-item">
          <view class="dim-header">
            <text class="dim-name"><view class="icon icon-palette" style="font-size:24rpx;margin-right:4rpx;"></view> 颜色匹配度</text>
            <text class="dim-score">{{record.scores.colorScore}}/10</text>
          </view>
          <view class="score-bar">
            <view class="score-bar-inner {{record.scores.colorScore >= 7 ? 'bar-positive' : record.scores.colorScore < 5 ? 'bar-negative' : ''}}" style="width: {{record.scores.colorScore * 10}}%"></view>
          </view>
          <view class="dim-detail" wx:if="{{record.details && record.details.colorScore}}">
            <view class="detail-pros"><view class="icon icon-good" style="font-size:24rpx;color:var(--success);margin-right:4rpx;"></view> {{record.details.colorScore.pros}}</view>
            <view class="detail-cons"><view class="icon icon-warning" style="font-size:24rpx;color:var(--danger);margin-right:4rpx;"></view> {{record.details.colorScore.cons}}</view>
          </view>
        </view>
        <!-- 质感做工 -->
        <view class="dimension-item">
          <view class="dim-header">
            <text class="dim-name"><view class="icon icon-gem" style="font-size:24rpx;margin-right:4rpx;"></view> 质感做工</text>
            <text class="dim-score">{{record.scores.qualityScore}}/10</text>
          </view>
          <view class="score-bar">
            <view class="score-bar-inner {{record.scores.qualityScore >= 7 ? 'bar-positive' : record.scores.qualityScore < 5 ? 'bar-negative' : ''}}" style="width: {{record.scores.qualityScore * 10}}%"></view>
          </view>
          <view class="dim-detail" wx:if="{{record.details && record.details.qualityScore}}">
            <view class="detail-pros"><view class="icon icon-good" style="font-size:24rpx;color:var(--success);margin-right:4rpx;"></view> {{record.details.qualityScore.pros}}</view>
            <view class="detail-cons"><view class="icon icon-warning" style="font-size:24rpx;color:var(--danger);margin-right:4rpx;"></view> {{record.details.qualityScore.cons}}</view>
          </view>
        </view>
        <!-- 性价比 -->
        <view class="dimension-item">
          <view class="dim-header">
            <text class="dim-name"><view class="icon icon-money" style="font-size:24rpx;margin-right:4rpx;"></view> 性价比</text>
            <text class="dim-score">{{record.scores.valueScore}}/10</text>
          </view>
          <view class="score-bar">
            <view class="score-bar-inner {{record.scores.valueScore >= 7 ? 'bar-positive' : record.scores.valueScore < 5 ? 'bar-negative' : ''}}" style="width: {{record.scores.valueScore * 10}}%"></view>
          </view>
          <view class="dim-detail" wx:if="{{record.details && record.details.valueScore}}">
            <view class="detail-pros"><view class="icon icon-good" style="font-size:24rpx;color:var(--success);margin-right:4rpx;"></view> {{record.details.valueScore.pros}}</view>
            <view class="detail-cons"><view class="icon icon-warning" style="font-size:24rpx;color:var(--danger);margin-right:4rpx;"></view> {{record.details.valueScore.cons}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 穿搭优化建议 -->
    <view class="card" wx:if="{{record.tips && record.tips.length > 0}}">
      <view class="card-title">穿搭优化建议</view>
      <view class="tips-list">
        <view class="tip-item" wx:for="{{record.tips}}" wx:key="*this">
          <text class="tip-num">{{index + 1}}</text>
          <text class="tip-text">{{item}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- ===== 对比模式 ===== -->
  <block wx:if="{{isCompare}}">
    <!-- 最终推荐 -->
    <view class="card final-choice-card" wx:if="{{record.finalChoice}}">
      <view class="card-title"><view class="icon icon-trophy" style="font-size:28rpx;margin-right:4rpx;"></view> 最终推荐</view>
      <view class="final-choice">
        <view class="choice-label">{{record.finalChoice.label}}</view>
        <view class="choice-reason">{{record.finalChoice.reason}}</view>
      </view>
    </view>

    <!-- 雷达图 -->
    <view class="card radar-card">
      <view class="card-title">6维评分雷达图（{{record.rankings[0].label}}）</view>
      <canvas type="2d" id="radarCanvas" class="radar-canvas"></canvas>
    </view>

    <!-- 排名 -->
    <view class="card">
      <view class="card-title">综合排名</view>
      <view class="rank-list">
        <view class="rank-item {{index === 0 ? 'rank-top' : ''}}" wx:for="{{record.rankings}}" wx:key="index">
          <view class="rank-badge">{{index + 1}}</view>
          <text class="rank-label">{{item.label}}</text>
          <text class="rank-score">{{item.totalScore}}分</text>
        </view>
      </view>
    </view>

    <!-- 横向对比表格 -->
    <view class="card">
      <view class="card-title">6维横向对比</view>
      <view class="compare-table">
        <view class="table-header">
          <view class="table-cell cell-dim" wx:for="{{compareHeaders}}" wx:key="*this">
            {{item}}
          </view>
        </view>
        <view class="table-row" wx:for="{{compareRows}}" wx:key="dimension">
          <view class="table-cell cell-dim">{{item.dimension}}</view>
          <view class="table-cell" wx:for="{{item.values}}" wx:key="*this"
            style="color: {{item >= 8 ? '#27ae60' : item >= 6 ? '#f39c12' : '#e74c3c'}}">
            {{item}}
          </view>
        </view>
      </view>
    </view>

    <!-- 各款优缺点 -->
    <view class="card" wx:if="{{record.comparisons}}">
      <view class="card-title">各款优缺点</view>
      <view class="comparison-list">
        <view class="comparison-item" wx:for="{{record.comparisons}}" wx:key="index">
          <view class="comp-label">{{item.label}}</view>
          <view class="comp-pros"><view class="icon icon-good" style="font-size:24rpx;color:var(--success);margin-right:4rpx;"></view> {{item.pros}}</view>
          <view class="comp-cons"><view class="icon icon-warning" style="font-size:24rpx;color:var(--danger);margin-right:4rpx;"></view> {{item.cons}}</view>
        </view>
      </view>
    </view>

    <!-- 最佳场景 -->
    <view class="card" wx:if="{{record.bestScenarios}}">
      <view class="card-title">最佳使用场景</view>
      <view class="scenario-list">
        <view class="scenario-item" wx:for="{{record.bestScenarios}}" wx:key="index">
          <text class="scenario-label">{{item.label}}</text>
          <text class="scenario-desc">{{item.scenario}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- ===== 搭搭评论（通用） ===== -->
  <view class="card dada-comment-card" wx:if="{{record.dadaComment}}">
    <view class="card-title"><view class="icon icon-chat" style="font-size:28rpx;margin-right:4rpx;"></view> 搭搭说</view>
    <view class="dada-avatar icon icon-cat" style="font-size:48rpx;"></view>
    <view class="dada-comment">{{record.dadaComment}}</view>
  </view>

  <!-- ===== 穿搭建议（通用） ===== -->
  <view class="card" wx:if="{{record.outfitAdvice && record.outfitAdvice.length > 0}}">
    <view class="card-title"><view class="icon icon-dress" style="font-size:28rpx;margin-right:4rpx;"></view> 搭配建议</view>
    <view class="advice-list">
      <view class="advice-item" wx:for="{{record.outfitAdvice}}" wx:key="type">
        <view class="advice-icon icon icon-{{item.icon}}" style="font-size:36rpx;"></view>
        <view class="advice-content">
          <view class="advice-title">{{item.title}}</view>
          <view class="advice-desc">{{item.description}}</view>
          <view class="advice-reason">{{item.reason}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions safe-bottom">
    <button class="btn-outline action-btn" bindtap="onConsultAgain">再次咨询</button>
    <button class="btn-primary action-btn share-action-btn" open-type="share">
      <text class="share-action-icon">↗</text>
      <text>分享给好友</text>
    </button>
  </view>
</view>