/* pages/mine/mine.wxss */
.page-mine {
  min-height: 100vh;
  background: #f5f5f7;
}

.user-header {
  background: #F1849B;
  padding: 60rpx 32rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  background: transparent !important;
  border-radius: 50%;
  z-index: 1;
  opacity: 0;
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-default-icon {
  font-size: 56rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-name-input {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
  background: transparent;
  border: none;
  padding: 0;
  height: 48rpx;
  line-height: 48rpx;
}

.user-stat {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.user-login {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
}

.avatar-placeholder-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.login-text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}

.stats-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  margin: -20rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
  z-index: 10;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a2e;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eeeeee;
}

.menu-section {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.menu-badge {
  background: #e8a87c;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
  font-weight: 600;
}

.menu-item.logout {
  justify-content: center;
}

.menu-item.logout .menu-text {
  text-align: center;
  color: #e74c3c;
}

/* 浮动「蜕变」FAB */
.beauty-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB6C1 0%, #F1849B 60%, #E5739A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(241, 132, 155, 0.45),
              0 0 0 6rpx rgba(255, 255, 255, 0.85);
  z-index: 99;
}
.beauty-fab-hover {
  transform: scale(0.94);
}
.beauty-fab-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}
