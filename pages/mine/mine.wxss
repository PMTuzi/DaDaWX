/* pages/mine/mine.wxss —— 金色天蓝混合风（与首页对齐） */
.page-mine {
  min-height: 100vh;
  background: #FFFFFF;
}

/* 任务进度条：放在 user-header 之后，sticky 时避开胶囊菜单 */
.page-mine .task-bars {
  position: relative;
  top: 0;
  margin-top: -32rpx;
}

/* 头部：浅天蓝渐变 + 金色装饰光晕 */
.user-header {
  background: linear-gradient(135deg, #E8F4FC 0%, #C7E4F5 50%, #9FCFEC 100%);
  padding: calc(env(safe-area-inset-top) + 200rpx) 32rpx 56rpx;
  position: relative;
  overflow: hidden;
}
.user-header::before {
  content: '';
  position: absolute;
  top: -40rpx; right: -40rpx;
  width: 240rpx; height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245, 230, 184, 0.7) 0%, transparent 70%);
}
.user-header::after {
  content: '';
  position: absolute;
  bottom: -60rpx; left: -30rpx;
  width: 180rpx; height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.5) 0%, transparent 70%);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.avatar-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(184, 153, 104, 0.3),
              0 0 0 3rpx rgba(212, 184, 131, 0.45),
              inset 0 0 0 2rpx rgba(255, 255, 255, 0.4);
}

.avatar-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  background: transparent !important;
  border-radius: 50%;
  z-index: 1;
  opacity: 0;
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-default-icon {
  font-size: 56rpx;
  color: #B89968;
}

.user-detail {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-name-input {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1F1A17;
  margin-bottom: 8rpx;
  background: transparent;
  border: none;
  padding: 0;
  height: 48rpx;
  line-height: 48rpx;
  letter-spacing: 2rpx;
}

.user-stat {
  font-size: 24rpx;
  color: #8C7340;
  letter-spacing: 1rpx;
}

.user-login {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(184, 153, 104, 0.25);
}

.avatar-placeholder-text {
  font-size: 22rpx;
  color: #B89968;
}

.login-text {
  font-size: 32rpx;
  color: #1F1A17;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 统计卡：白底 + 金色数字 + 天蓝阴影 */
.stats-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  margin: -28rpx 24rpx 0;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(95, 158, 200, 0.18),
              0 2rpx 8rpx rgba(184, 153, 104, 0.1);
  border: 1rpx solid rgba(212, 184, 131, 0.35);
  position: relative;
  z-index: 10;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #D4B883 0%, #B89968 60%, #8C6E3A 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  letter-spacing: 1rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #8C7340;
  margin-top: 6rpx;
  letter-spacing: 1rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent, rgba(184, 153, 104, 0.4), transparent);
}

/* 菜单：白底 + 金色图标 + 天蓝细描边 */
.menu-section {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(95, 158, 200, 0.1),
              0 2rpx 6rpx rgba(184, 153, 104, 0.06);
  border: 1rpx solid rgba(212, 184, 131, 0.28);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 28rpx;
  border-bottom: 1rpx solid rgba(159, 207, 236, 0.22);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
  color: #B89968;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1F1A17;
  letter-spacing: 1rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #C9A45C;
}

.menu-badge {
  background: linear-gradient(135deg, #F5E6B8 0%, #D4B883 50%, #B89968 100%);
  color: #1F1A17;
  font-size: 20rpx;
  padding: 2rpx 14rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  box-shadow: 0 2rpx 6rpx rgba(184, 153, 104, 0.35);
}

.menu-item.logout {
  justify-content: center;
}

.menu-item.logout .menu-text {
  text-align: center;
  color: #8C7340;
  font-weight: 500;
}
