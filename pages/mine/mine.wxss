/* pages/mine/mine.wxss */
.page-mine {
  min-height: 100vh;
  background: #FFFFFF;
}

.user-header {
  background: linear-gradient(135deg, #E8F4FC 0%, #C7E4F5 50%, #9FCFEC 100%);
  padding: 60rpx 32rpx 56rpx;
  position: relative;
  overflow: hidden;
}
.user-header::before {
  content: '';
  position: absolute;
  top: -40rpx; right: -40rpx;
  width: 220rpx; height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.55) 0%, transparent 70%);
}
.user-header::after {
  content: '';
  position: absolute;
  bottom: -60rpx; left: -30rpx;
  width: 180rpx; height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.4) 0%, transparent 70%);
}

.user-info {
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.avatar-wrapper {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid rgba(255, 255, 255, 0.85);
  box-shadow: 0 4rpx 16rpx rgba(95, 158, 200, 0.25), inset 0 0 0 2rpx rgba(255, 255, 255, 0.4);
}

.avatar-btn {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  padding: 0 !important;
  margin: 0 !important;
  border: none !important;
  background: transparent !important;
  border-radius: 50%;
  z-index: 1;
  opacity: 0;
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-default-icon {
  font-size: 56rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.user-name-input {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2A5878;
  margin-bottom: 8rpx;
  background: transparent;
  border: none;
  padding: 0;
  height: 48rpx;
  line-height: 48rpx;
  letter-spacing: 2rpx;
}

.user-stat {
  font-size: 24rpx;
  color: #5F92B5;
  letter-spacing: 1rpx;
}

.user-login {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.85);
}

.avatar-placeholder-text {
  font-size: 22rpx;
  color: #5F92B5;
}

.login-text {
  font-size: 32rpx;
  color: #2A5878;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.stats-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  margin: -28rpx 24rpx 0;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(95, 158, 200, 0.16);
  border: 1rpx solid rgba(159, 207, 236, 0.4);
  position: relative;
  z-index: 10;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #2A5878;
  letter-spacing: 1rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #5F92B5;
  margin-top: 6rpx;
  letter-spacing: 1rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: linear-gradient(180deg, transparent, rgba(95, 158, 200, 0.4), transparent);
}

.menu-section {
  margin: 24rpx 24rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(95, 158, 200, 0.1);
  border: 1rpx solid rgba(159, 207, 236, 0.3);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 28rpx;
  border-bottom: 1rpx solid rgba(159, 207, 236, 0.25);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  width: 40rpx;
  text-align: center;
  color: #5F92B5;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #2A5878;
  letter-spacing: 1rpx;
}

.menu-arrow {
  font-size: 32rpx;
  color: #9FCFEC;
}

.menu-badge {
  background: linear-gradient(135deg, #C7E4F5, #5F92B5);
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 14rpx;
  border-radius: 16rpx;
  margin-right: 12rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  box-shadow: 0 2rpx 6rpx rgba(95, 158, 200, 0.3);
}

.menu-item.logout {
  justify-content: center;
}

.menu-item.logout .menu-text {
  text-align: center;
  color: #5F92B5;
  font-weight: 500;
}

/* 浮动「蜕变」FAB */
.beauty-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8F4FC 0%, #9FCFEC 50%, #5F92B5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(95, 158, 200, 0.45),
              0 0 0 6rpx rgba(255, 255, 255, 0.85);
  z-index: 99;
}
.beauty-fab-hover {
  transform: scale(0.94);
}
.beauty-fab-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(42, 88, 120, 0.4);
}
