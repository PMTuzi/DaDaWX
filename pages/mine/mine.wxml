<!--pages/mine/mine.wxml-->
<import src="../../templates/task-bars.wxml" />
<view class="page-mine">
  <!-- 用户信息 -->
  <view class="user-header">
    <!-- 已登录：显示头像 + 昵称（可编辑） -->
    <view class="user-info" wx:if="{{isLoggedIn}}">
      <view class="avatar-wrapper">
        <image wx:if="{{userInfo.avatarUrl}}" class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" binderror="onAvatarError" />
        <view wx:else class="avatar-default">
          <text class="avatar-default-icon">👤</text>
        </view>
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" />
      </view>
      <view class="user-detail">
        <input class="user-name-input" type="nickname" value="{{userInfo.nickName || '搭搭用户'}}" 
               bindblur="onNicknameInput" placeholder="点击设置昵称" />
        <text class="user-stat">已进行 {{reportCount + consultCount}} 次决策</text>
      </view>
    </view>
    <!-- 未登录：点击登录 -->
    <view class="user-login" wx:else bindtap="onTapUserHeader">
      <view class="avatar-placeholder">
        <text class="avatar-placeholder-text">未登录</text>
      </view>
      <text class="login-text">点击登录</text>
    </view>
  </view>

  <!-- 统计 -->
  <view class="stats-bar">
    <view class="stat-item" bindtap="onGoReports">
      <text class="stat-num">{{reportCount}}</text>
      <text class="stat-label">形象分析</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item" bindtap="onGoConsultHistory">
      <text class="stat-num">{{consultCount}}</text>
      <text class="stat-label">穿搭决策</text>
    </view>
  </view>

  <!-- 顶部后台任务进度条（形象诊断 / 穿搭决策） -->
  <template is="task-bars" data="{{diagnoseTask, consultTask}}" />

  <!-- 功能列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onAbout">
      <view class="menu-icon icon icon-info" style="font-size:36rpx;"></view>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onPrivacy">
      <view class="menu-icon icon icon-lock" style="font-size:36rpx;"></view>
      <text class="menu-text">隐私协议</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-section" wx:if="{{isLoggedIn}}">
    <view class="menu-item logout" bindtap="onLogout">
      <text class="menu-text">退出登录</text>
    </view>
  </view>

  <!-- 浮动 蜕变 入口（仅已诊断态，与首页逻辑一致） -->
  <view class="beauty-fab" wx:if="{{hasReport}}" bindtap="onGoBeautyPlan" hover-class="beauty-fab-hover">
    <text class="beauty-fab-text">蜕变</text>
  </view>
</view>
