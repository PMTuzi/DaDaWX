/* pages/report/report.wxss - 中转页占位 */
.redirect-loading {
  position: fixed;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #EEF3F8;
  gap: 32rpx;
}
.redirect-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #DCE5EF;
  border-top-color: #B89968;
  border-radius: 50%;
  animation: redirect-spin 0.9s linear infinite;
}
.redirect-text {
  font-size: 26rpx;
  color: #8B7355;
  letter-spacing: 1rpx;
}
@keyframes redirect-spin {
  to { transform: rotate(360deg); }
}
