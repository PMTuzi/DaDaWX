/* pages/report/report.wxss */
.page-report {
  height: 100vh;
  background: #f5f5f7;
  display: flex;
  flex-direction: column;
}

/* Tab导航 */
.tab-bar {
  flex-shrink: 0;
  background: #ffffff;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  z-index: 10;
}

.tab-scroll {
  white-space: nowrap;
  padding: 0 16rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 28rpx;
  position: relative;
}

.tab-label {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
  transition: all 0.3s;
}

.tab-item.active .tab-label {
  color: #1a1a2e;
  font-weight: 700;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #e8a87c;
  border-radius: 3rpx;
}

/* 综合评分头部 */
.report-header {
  background: linear-gradient(135deg, #1a1a2e, #2d2d4a);
  padding: 40rpx 32rpx;
  text-align: center;
  flex-shrink: 0;
}

.score-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 8rpx;
}

.score-number {
  font-size: 88rpx;
  font-weight: 800;
  color: #e8a87c;
  line-height: 1;
}

.score-max {
  font-size: 28rpx;
  color: rgba(255,255,255,0.5);
  margin-left: 4rpx;
}

.score-level {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.score-tags {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.score-tags .tag {
  background: rgba(232,168,124,0.2);
  color: #e8a87c;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

.score-desc {
  max-width: 600rpx;
  margin: 0 auto;
}

.desc-advantage {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.6;
}

/* Swiper */
.module-swiper {
  flex: 1;
  height: 0;
}

.module-scroll {
  height: 100%;
}

.module-content {
  padding: 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 通用卡片 */
.section-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.section-card.danger {
  border-left: 6rpx solid #e74c3c;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 16rpx;
}

.card-header .card-title {
  margin-bottom: 0;
}

.card-title.danger {
  color: #e74c3c;
}

.card-score-wrap {
  display: flex;
  align-items: baseline;
}

.card-score {
  font-size: 48rpx;
  font-weight: 800;
  color: #e8a87c;
}

.card-score-max {
  font-size: 22rpx;
  color: #999;
}

.card-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 12rpx;
}

/* 海报 */
.poster-card {
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.poster-img {
  width: 100%;
  height: 600rpx;
}

/* 脸型 */
.face-type-badge {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.face-type-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.face-type-bone {
  font-size: 24rpx;
  background: rgba(232,168,124,0.12);
  color: #e8a87c;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

/* 三庭五眼 */
.court-list {
  margin-bottom: 20rpx;
}

.court-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.court-item:last-child {
  border-bottom: none;
}

.court-label {
  width: 100rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.court-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.court-item.highlight .court-value {
  color: #e8a87c;
  font-weight: 600;
}

.five-eyes {
  background: rgba(232,168,124,0.06);
  border-radius: 16rpx;
  padding: 20rpx;
}

.fe-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-bottom: 8rpx;
  display: block;
}

.fe-desc {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.fe-suggestion {
  font-size: 24rpx;
  color: #e8a87c;
  display: block;
  margin-top: 8rpx;
}

/* 特征评分 */
.feature-list {
  margin-top: 8rpx;
}

.feature-item {
  padding: 10rpx 0;
}

.fi-name {
  font-size: 26rpx;
  color: #666;
  display: block;
}

.fi-bar-wrap {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin: 8rpx 0;
  overflow: hidden;
}

.fi-bar {
  height: 100%;
  background: linear-gradient(90deg, #e8a87c, #d4a574);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.fi-score {
  font-size: 24rpx;
  font-weight: 600;
  color: #e8a87c;
  margin-right: 12rpx;
}

.fi-desc {
  font-size: 22rpx;
  color: #999;
  margin-left: 8rpx;
}

/* 发型列表 */
.haircut-list {
  margin-top: 8rpx;
}

.haircut-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.haircut-item:last-child {
  border-bottom: none;
}

.hi-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hi-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.hi-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #27ae60;
}

.hi-detail {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.hi-reason {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 避雷列表 */
.avoid-list {
  margin-top: 8rpx;
}

.avoid-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.avoid-item:last-child {
  border-bottom: none;
}

.avoid-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e74c3c;
  display: block;
}

.avoid-reason {
  font-size: 24rpx;
  color: #999;
  padding-left: 24rpx;
}

/* 洞察卡 */
.insight-card {
  background: linear-gradient(135deg, rgba(232,168,124,0.1), rgba(232,168,124,0.05));
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(232,168,124,0.2);
}

.insight-text {
  font-size: 28rpx;
  color: #1a1a2e;
  line-height: 1.8;
  font-style: italic;
}

/* 皮肤模块 */
.skin-type-badge {
  font-size: 26rpx;
  background: rgba(232,168,124,0.12);
  color: #e8a87c;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.skin-scores {
  margin-top: 12rpx;
}

.skin-score-item {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.ss-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.ss-val {
  width: 60rpx;
  text-align: right;
  font-size: 26rpx;
  font-weight: 600;
  color: #e8a87c;
  flex-shrink: 0;
}

/* 皮肤问题 */
.problem-list {
  margin-top: 8rpx;
}

.problem-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.problem-item:last-child {
  border-bottom: none;
}

.pm-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.pm-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.pm-level {
  font-size: 24rpx;
  color: #e8a87c;
  font-weight: 500;
}

.pm-level.good {
  color: #27ae60;
}

.pm-area, .pm-advice {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

/* 四季色彩 */
.season-box {
  background: rgba(232,168,124,0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.season-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #e8a87c;
  display: block;
  margin-bottom: 8rpx;
}

.season-detail {
  font-size: 24rpx;
  color: #999;
}

/* 色卡 */
.color-palette {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  width: 80rpx;
}

.color-swatch {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  border: 2rpx solid rgba(0,0,0,0.06);
}

.color-name {
  font-size: 20rpx;
  color: #666;
  text-align: center;
}

.color-usage, .color-reason {
  font-size: 18rpx;
  color: #999;
  text-align: center;
}

.color-reason {
  color: #e74c3c;
}

.color-palette.bad .color-swatch {
  opacity: 0.6;
}

/* 护肤建议 */
.tips-list {
  margin-top: 8rpx;
}

.tip-item {
  display: flex;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.tip-bullet {
  font-size: 28rpx;
  color: #e8a87c;
  flex-shrink: 0;
  font-weight: bold;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
}

/* 风格模块 */
.main-style-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  display: block;
  margin-bottom: 8rpx;
}

.sub-styles {
  margin-top: 16rpx;
}

.sub-style {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.ss-name {
  width: 120rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.ss-score {
  width: 60rpx;
  text-align: right;
  font-size: 26rpx;
  font-weight: 600;
  color: #e8a87c;
  flex-shrink: 0;
}

.style-features {
  display: flex;
  gap: 20rpx;
}

.sf-item {
  flex: 1;
  background: rgba(232,168,124,0.06);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.sf-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.sf-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

/* 色彩方案 */
.palette-group {
  margin-bottom: 16rpx;
}

.pg-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
  display: block;
}

.pg-colors {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.pg-color {
  font-size: 24rpx;
  background: rgba(232,168,124,0.08);
  color: #666;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.pg-color.accent {
  background: rgba(232,168,124,0.15);
  color: #e8a87c;
}

/* 穿搭建议 */
.advice-list {
  margin-top: 8rpx;
}

.advice-item {
  display: flex;
  margin-bottom: 12rpx;
}

.ad-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.ad-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  line-height: 1.6;
}

/* 场景方案 */
.scene-list {
  margin-top: 8rpx;
}

.scene-item {
  background: rgba(232,168,124,0.06);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
}

.scene-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #e8a87c;
  margin-bottom: 6rpx;
}

.scene-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: block;
}

.scene-key {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

/* 推荐单品 */
.outfit-list {
  margin-top: 8rpx;
}

.outfit-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.outfit-item:last-child {
  border-bottom: none;
}

.oi-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.oi-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.oi-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #e8a87c;
}

.oi-tags .tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 8rpx;
  background: rgba(0,0,0,0.04);
  color: #666;
}

.oi-tags .tag.warm {
  background: rgba(232,168,124,0.12);
  color: #e8a87c;
}

.oi-tags .tag.cool {
  background: rgba(52,152,219,0.1);
  color: #3498db;
}

.tag.small {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* TOP发型 */
.top-hair-list {
  margin-top: 8rpx;
}

.top-hair-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.top-hair-item:last-child {
  border-bottom: none;
}

.th-rank {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #e8a87c, #d4a574);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 800;
  color: #fff;
  flex-shrink: 0;
}

.th-info {
  flex: 1;
}

.th-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.th-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.th-score {
  font-size: 26rpx;
  font-weight: 700;
  color: #27ae60;
}

.th-detail {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

/* 妆容 */
.makeup-grid {
  margin-top: 8rpx;
}

.mu-section {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.mu-section:last-child {
  border-bottom: none;
}

.mu-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
}

.mu-value {
  font-size: 26rpx;
  color: #333;
  display: block;
  line-height: 1.5;
}

/* 身形 */
.body-result {
  display: flex;
  gap: 20rpx;
  margin-top: 8rpx;
}

.body-attr {
  flex: 1;
  background: rgba(232,168,124,0.06);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.ba-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.ba-value {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a2e;
}

/* 总结 */
.summary-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  display: block;
  margin-bottom: 12rpx;
}

.priority-text {
  font-size: 26rpx;
  color: #e8a87c;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

/* 底部栏 */
.share-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #ffffff;
  padding: 16rpx 32rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  gap: 16rpx;
  z-index: 10;
}

.share-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  border-radius: 48rpx;
  background: rgba(232,168,124,0.1);
  font-size: 28rpx;
  color: #e8a87c;
  font-weight: 600;
  border: none;
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 32rpx;
}

.rediagnose-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-radius: 48rpx;
  background: linear-gradient(135deg, #e8a87c, #d4a574);
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
  border: none;
}

.rediagnose-btn::after {
  border: none;
}

.safe-bottom {
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
