/* pages/report/report.wxss */
/* 新架构：数据驱动报告页 */

.page-report {
  min-height: 100vh;
  background: #FAFAF5;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

/* Tab导航 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-label {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.tab-item.active .tab-label {
  color: #333;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #F1849B;
  border-radius: 3rpx;
}

/* 综合评分头部 */
.report-header {
  position: relative;
  overflow: hidden;
  margin: 24rpx 32rpx 0;
  border-radius: 28rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FDF6F0;
  border: 2rpx solid rgba(201, 169, 110, 0.25);
  z-index: 0;
}

.header-bg::before {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(201, 169, 110, 0.12) 0%, transparent 70%);
  border-radius: 50%;
}

.header-bg::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(183, 110, 121, 0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 36rpx 32rpx 20rpx;
  gap: 28rpx;
}

/* 大头像 */
.avatar-main {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(201, 169, 110, 0.35);
  box-shadow: 0 6rpx 24rpx rgba(201, 169, 110, 0.2);
  background: #FDF6F0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 0;
}

.avatar-main-img {
  width: 100%;
  height: 100%;
}

.avatar-main-fallback {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
}

/* 右侧信息 */
.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  gap: 12rpx;
}

/* 分数行 */
.score-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.score-num-group {
  display: flex;
  align-items: baseline;
}

.score-row .htag-age {
  flex-shrink: 0;
}

.score-big {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  line-height: 1;
  color: #E20C0C;
  text-shadow: 0 2rpx 12rpx rgba(226, 12, 12, 0.25);
}

.score-suffix {
  font-size: 28rpx;
  color: #B8935A;
  margin-left: 4rpx;
  font-weight: 700;
}

/* 标签 */
.header-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.htag {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE4EC 100%);
  color: #E58FA1;
  font-weight: 600;
  border: 1rpx solid rgba(233, 30, 99, 0.18);
  box-shadow: 0 2rpx 6rpx rgba(233, 30, 99, 0.08);
  flex-shrink: 0;
  white-space: nowrap;
}

/* 视觉年龄标签强化 - 核心展示（金色奖章风） */
.htag-age {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #FFD86F 0%, #E8A87C 50%, #C38D9E 100%);
  box-shadow: 0 6rpx 18rpx rgba(200, 133, 110, 0.5),
              inset 0 1rpx 0 rgba(255, 255, 255, 0.6),
              inset 0 -1rpx 0 rgba(0, 0, 0, 0.08);
  border: 2rpx solid rgba(255, 255, 255, 0.7);
}

.htag-age-icon {
  font-size: 24rpx;
  color: #FFFBE6;
  line-height: 1;
  text-shadow: 0 1rpx 2rpx rgba(184, 102, 60, 0.6);
}

.htag-age-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  line-height: 1;
  text-shadow: 0 1rpx 2rpx rgba(184, 102, 60, 0.5);
}

/* 头部摘要 - 撑满卡片宽度 */
.header-summary {
  position: relative;
  z-index: 1;
  margin: 0 32rpx 28rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.55);
  border-radius: 16rpx;
  width: auto;
  box-sizing: border-box;
  border: 1rpx solid rgba(201, 169, 110, 0.15);
  backdrop-filter: blur(8px);
}

.summary-text {
  font-size: 22rpx;
  color: #9B5A6E;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.info-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #F9E6EC;
  color: #D46A8A;
}

.info-tag.accent {
  background: #F0EBF5;
  color: #7B5EA7;
}

.info-tag.accent2 {
  background: #EBF5F0;
  color: #5EA77B;
}

/* 模块内容 */
.module-content {
  padding: 24rpx 32rpx;
  margin-bottom: 160rpx;
}

/* 通用卡片 */
.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #F1849B;
}

.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

/* 子区块 */
.sub-section {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F5F0EB;
}

.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #555;
  margin-bottom: 16rpx;
}

.sub-title.warn {
  color: #E74C3C;
}

/* 雷达图 */
.radar-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
  margin: 16rpx 0;
}

.radar-canvas {
  width: 560rpx;
  height: 400rpx;
}

/* 三庭五眼比例条 */
.proportion-bar {
  display: flex;
  border-radius: 12rpx;
  overflow: hidden;
  height: 64rpx;
  margin-bottom: 16rpx;
}

.prop-segment {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.prop-segment.upper {
  background: #F5ECD7;
}

.prop-segment.middle {
  background: #F0EBE5;
}

.prop-segment.lower {
  background: #E8E5E0;
}

.prop-label {
  font-size: 20rpx;
  color: #999;
}

.prop-val {
  font-size: 22rpx;
  font-weight: 600;
  color: #666;
}

/* 洞察文字 */
.insight-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  margin-top: 8rpx;
}

.body-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
}

/* 评分条 */
.score-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.score-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.score-name {
  font-size: 24rpx;
  color: #666;
  width: 80rpx;
  flex-shrink: 0;
}

.score-bar-wrap {
  flex: 1;
}

.score-bar-bg {
  height: 16rpx;
  background: #F5F0EB;
  border-radius: 8rpx;
  overflow: hidden;
}

.score-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #F1849B, #F9E6EC);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.score-val {
  font-size: 24rpx;
  color: #F1849B;
  font-weight: 600;
  width: 40rpx;
  text-align: right;
}

/* 属性网格 */
.attr-grid {
  display: flex;
  gap: 20rpx;
}

.attr-item {
  flex: 1;
  background: #FAFAF5;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.attr-label {
  font-size: 22rpx;
  color: #999;
  display: block;
}

.attr-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #F1849B;
  display: block;
  margin-top: 4rpx;
}

/* 色卡 */
.color-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.color-item {
  width: calc(25% - 12rpx);
  text-align: center;
}

.color-swatch {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.color-swatch.hair {
  background: linear-gradient(135deg, #4A3728, #8B6914, #2C1810);
}

.color-name {
  font-size: 20rpx;
  color: #333;
  font-weight: 600;
  display: block;
}

.color-usage {
  font-size: 18rpx;
  color: #999;
  display: block;
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.color-grid.warn .color-swatch {
  border: 3rpx solid #FFCDD2;
}

/* 色彩搭配方案 */
.palette-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.palette-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.palette-label {
  font-size: 24rpx;
  color: #999;
  width: 80rpx;
  flex-shrink: 0;
}

.palette-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.palette-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #F5F0EB;
  color: #D46A8A;
}

/* 穿搭建议 */
.advice-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.advice-item {
  display: flex;
  gap: 12rpx;
}

.advice-label {
  font-size: 24rpx;
  color: #F1849B;
  font-weight: 600;
  flex-shrink: 0;
  width: 64rpx;
}

.advice-text {
  font-size: 24rpx;
  color: #555;
  line-height: 1.6;
}

/* 发型列表 */
.hair-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hair-card {
  display: flex;
  gap: 16rpx;
  background: #FAFAF5;
  border-radius: 16rpx;
  padding: 20rpx;
}

.hair-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F1849B, #F9E6EC);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.hair-info {
  flex: 1;
  min-width: 0;
}

.hair-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hair-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.hair-score {
  font-size: 24rpx;
  color: #F1849B;
  font-weight: 600;
}

.hair-detail {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.hair-reason {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-top: 8rpx;
  line-height: 1.5;
}

/* 避雷列表 */
.avoid-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.avoid-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: #FFF5F5;
  border-radius: 12rpx;
  padding: 16rpx;
}

.avoid-x {
  color: #E74C3C;
  font-weight: 700;
  font-size: 28rpx;
  flex-shrink: 0;
}

.avoid-info {
  flex: 1;
}

.avoid-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #E74C3C;
  display: block;
}

.avoid-reason {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

/* 妆容网格 */
.makeup-grid {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.makeup-item {
  display: flex;
  gap: 16rpx;
}

.makeup-label {
  font-size: 24rpx;
  color: #D4A574;
  font-weight: 600;
  flex-shrink: 0;
  width: 72rpx;
}

.makeup-text {
  font-size: 24rpx;
  color: #555;
  line-height: 1.6;
}

/* 优化列表 */
.optimize-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.optimize-item {
  display: flex;
  gap: 16rpx;
}

.optimize-priority {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

.optimize-priority.high {
  background: #E74C3C;
}

.optimize-priority.mid {
  background: #F39C12;
}

.optimize-priority.low {
  background: #95A5A6;
}

.optimize-info {
  flex: 1;
  min-width: 0;
}

.optimize-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.optimize-area {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.optimize-timeline {
  font-size: 22rpx;
  color: #F1849B;
  background: #FAFAF5;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.optimize-problem {
  font-size: 24rpx;
  color: #E74C3C;
  display: block;
  margin-top: 4rpx;
}

.optimize-plan {
  font-size: 24rpx;
  color: #555;
  display: block;
  margin-top: 4rpx;
  line-height: 1.5;
}

/* 路线图 */
.roadmap {
  display: flex;
  flex-direction: column;
}

.roadmap-item {
  display: flex;
  position: relative;
  padding-bottom: 24rpx;
}

.roadmap-item:last-child {
  padding-bottom: 0;
}

.roadmap-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #F1849B;
  flex-shrink: 0;
  margin-top: 8rpx;
  margin-right: 16rpx;
  position: relative;
  z-index: 1;
}

.roadmap-line {
  position: absolute;
  left: 9rpx;
  top: 28rpx;
  width: 2rpx;
  height: calc(100% - 28rpx);
  background: #F9E6EC;
}

.roadmap-content {
  flex: 1;
}

.roadmap-month {
  font-size: 26rpx;
  font-weight: 600;
  color: #F1849B;
  display: block;
}

.roadmap-desc {
  font-size: 24rpx;
  color: #555;
  display: block;
  margin-top: 4rpx;
  line-height: 1.6;
}

/* 洞察卡片 */
.insight-card {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #FAFAF5, #F5F0EB);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}

.insight-icon {
  font-size: 28rpx;
  color: #F1849B;
  flex-shrink: 0;
}

.insight-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 底部分享栏 */
.share-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 10;
}

.share-bar button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.share-btn {
  background: #F1849B;
  color: #ffffff;
  flex-direction: row;
  gap: 6rpx;
  position: relative;
}

.share-btn.shared {
  background: #E8F5E9;
  color: #4CAF50;
}

.share-icon {
  font-size: 28rpx;
}

.save-all-btn {
  background: #333;
  color: #fff;
}

.rediagnose-btn {
  background: #FAFAF5;
  color: #666;
  flex: 0.8;
}

/* 锁定状态 */
.save-all-btn.locked,
.rediagnose-btn.locked {
  opacity: 0.4;
  position: relative;
}

.safe-bottom {
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

/* 隐藏的保存图片Canvas */
.report-card-canvas {
  position: fixed;
  left: -9999rpx;
  width: 680rpx;
  height: 1200rpx;
}
