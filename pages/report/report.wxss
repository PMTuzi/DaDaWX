/* pages/report/report.wxss */

.page-report {
  min-height: 100vh;
  background: #FAFAF5;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

/* Tab导航 */
.tab-bar {
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-scroll {
  white-space: nowrap;
  padding: 0 16rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 28rpx;
  margin: 0 8rpx;
  position: relative;
}

.tab-label {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.tab-item.active .tab-label {
  color: #333;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #C8A97E;
  border-radius: 3rpx;
}

/* 综合评分头部 */
.report-header {
  display: flex;
  align-items: center;
  padding: 32rpx 40rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 28rpx;
}

.user-avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 4rpx solid #F0EBE5;
  box-shadow: 0 4rpx 16rpx rgba(200, 169, 126, 0.15);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.header-right {
  flex: 1;
  display: flex;
  align-items: center;
  min-width: 0;
}

.score-display {
  display: flex;
  align-items: baseline;
  margin-right: 24rpx;
}

.score-number {
  font-size: 56rpx;
  font-weight: 700;
  color: #333;
  line-height: 1;
}

.score-unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
  font-weight: 500;
}

.score-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.score-tags .tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #F5F0EB;
  color: #8B7355;
}

/* 模块内容 */
.module-content {
  padding: 24rpx 32rpx;
  margin-bottom: 160rpx;
}

/* 图片卡片 */
.image-card {
  width: 100%;
  border-radius: 24rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.module-image {
  width: 100%;
  display: block;
}

/* 图片加载失败 */
.image-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 600rpx;
  background: #fff;
  border-radius: 24rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部分享栏 */
.share-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 10;
}

.share-bar button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

.share-btn {
  background: #C8A97E;
  color: #ffffff;
  flex-direction: row;
  gap: 6rpx;
  position: relative;
}

.share-btn.shared {
  background: #E8F5E9;
  color: #4CAF50;
}

.share-hint {
  font-size: 18rpx;
  opacity: 0.7;
  font-weight: 400;
}

.share-icon {
  font-size: 28rpx;
}

.save-all-btn {
  background: #333;
  color: #fff;
}

.rediagnose-btn {
  background: #FAFAF5;
  color: #666;
  flex: 0.8;
}

/* 锁定状态 */
.save-all-btn.locked,
.rediagnose-btn.locked {
  opacity: 0.4;
  position: relative;
}

.lock-icon {
  font-size: 20rpx;
  margin-right: 4rpx;
}

.safe-bottom {
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}
