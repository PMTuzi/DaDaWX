<!--pages/report/report.wxml-->
<view class="page-report" wx:if="{{report}}">
  <!-- 综合评分头部 -->
  <view class="report-header">
    <view class="score-display">
      <view class="score-big">
        <text class="score-number">{{report.basic.overallScore}}</text>
        <text class="score-max">/10</text>
      </view>
      <view class="score-level" style="color: {{scoreLevel.color}}">{{scoreLevel.text}}</view>
    </view>
    <view class="score-tags">
      <text class="tag tag-warm" wx:for="{{report.basic.tags}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="score-desc">
      <view class="desc-item advantage">✅ {{report.basic.advantages}}</view>
      <view class="desc-item weakness" wx:if="{{report.basic.weaknesses}}">⚠️ {{report.basic.weaknesses}}</view>
    </view>
  </view>

  <!-- 板块导航 -->
  <scroll-view class="section-nav" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="nav-item {{currentSection === index ? 'active' : ''}}"
      wx:for="{{sections}}" wx:key="key"
      data-index="{{index}}" bindtap="onSectionTap">
      <text class="nav-icon">{{item.icon}}</text>
      <text class="nav-name">{{item.name}}</text>
    </view>
  </scroll-view>

  <!-- 板块内容 -->
  <swiper class="section-content" current="{{currentSection}}" bindchange="onSwiperChange">

    <!-- 板块1: 综合评分 -->
    <swiper-item>
      <view class="section-body">
        <view class="card">
          <view class="card-title">综合形象评分</view>
          <view class="score-breakdown">
            <view class="breakdown-item">
              <text class="bd-label">面部</text>
              <view class="score-bar"><view class="score-bar-inner" style="width: 87%"></view></view>
              <text class="bd-score">35%</text>
            </view>
            <view class="breakdown-item">
              <text class="bd-label">肤色</text>
              <view class="score-bar"><view class="score-bar-inner" style="width: 75%"></view></view>
              <text class="bd-score">30%</text>
            </view>
            <view class="breakdown-item">
              <text class="bd-label">风格</text>
              <view class="score-bar"><view class="score-bar-inner" style="width: 67%"></view></view>
              <text class="bd-score">20%</text>
            </view>
            <view class="breakdown-item">
              <text class="bd-label">身形</text>
              <view class="score-bar"><view class="score-bar-inner" style="width: 50%"></view></view>
              <text class="bd-score">15%</text>
            </view>
          </view>
        </view>
      </view>
    </swiper-item>

    <!-- 板块2: 脸型分析 -->
    <swiper-item>
      <view class="section-body">
        <view class="card">
          <view class="card-title">脸型判定: {{report.faceShape.type}}</view>
          <view class="shape-score">
            <text class="shape-score-num">{{report.faceShape.score}}</text>
            <text class="shape-score-max">/10</text>
          </view>
          <view class="divider"></view>
          <view class="card-subtitle">脸型特征</view>
          <view class="feature-bars">
            <view class="feature-item">
              <text class="fi-label">线条流畅度</text>
              <view class="score-bar"><view class="score-bar-inner" style="width: {{report.faceShape.features.smoothness * 10}}%"></view></view>
              <text class="fi-score">{{report.faceShape.features.smoothness}}</text>
            </view>
            <view class="feature-item">
              <text class="fi-label">骨骼感</text>
              <view class="score-bar"><view class="score-bar-inner" style="width: {{report.faceShape.features.boneStructure * 10}}%"></view></view>
              <text class="fi-score">{{report.faceShape.features.boneStructure}}</text>
            </view>
            <view class="feature-item">
              <text class="fi-label">面部比例</text>
              <view class="score-bar"><view class="score-bar-inner" style="width: {{report.faceShape.features.proportion * 10}}%"></view></view>
              <text class="fi-score">{{report.faceShape.features.proportion}}</text>
            </view>
          </view>
        </view>

        <view class="card">
          <view class="card-title">适配发型</view>
          <view class="haircut-list">
            <view class="haircut-item" wx:for="{{report.faceShape.suitableHaircuts}}" wx:key="name">
              <view class="haircut-main">
                <text class="haircut-name">{{item.name}}</text>
                <text class="haircut-score" style="color: {{item.score >= 9 ? '#27ae60' : '#f39c12'}}">{{item.score}}分</text>
              </view>
              <view class="haircut-detail">
                <text wx:if="{{item.length}}">长度: {{item.length}}</text>
                <text wx:if="{{item.outline}}"> | 轮廓: {{item.outline}}</text>
                <text wx:if="{{item.bangs}}"> | 刘海: {{item.bangs}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="card">
          <view class="card-title danger-title">避雷发型</view>
          <view class="avoid-list">
            <view class="avoid-item" wx:for="{{report.faceShape.avoidHaircuts}}" wx:key="name">
              <text class="avoid-name">❌ {{item.name}}</text>
              <text class="avoid-reason">{{item.reason}}</text>
            </view>
          </view>
        </view>

        <view class="card">
          <view class="card-title">适配领型</view>
          <view class="collar-list">
            <view class="collar-item" wx:for="{{report.faceShape.suitableCollars}}" wx:key="type">
              <text class="collar-name">{{item.type}}</text>
              <view class="score-bar" style="flex:1;margin:0 16rpx"><view class="score-bar-inner" style="width: {{item.score * 10}}%"></view></view>
              <text class="collar-score">{{item.score}}</text>
            </view>
          </view>
        </view>
      </view>
    </swiper-item>

    <!-- 板块3: 肤色诊断 -->
    <swiper-item>
      <view class="section-body">
        <view class="card">
          <view class="card-title">肤色属性: {{report.skinColor.type}}</view>
          <view class="skin-attrs">
            <view class="attr-item">
              <text class="attr-label">明度</text>
              <view class="score-bar" style="flex:1;margin:0 16rpx"><view class="score-bar-inner" style="width: {{report.skinColor.brightness * 10}}%"></view></view>
              <text class="attr-score">{{report.skinColor.brightness}}</text>
            </view>
            <view class="attr-item">
              <text class="attr-label">纯度</text>
              <view class="score-bar" style="flex:1;margin:0 16rpx"><view class="score-bar-inner" style="width: {{report.skinColor.purity * 10}}%"></view></view>
              <text class="attr-score">{{report.skinColor.purity}}</text>
            </view>
          </view>
          <view class="season-badge">
            <text class="season-name">{{report.skinColor.season}}</text>
            <text class="season-detail">{{report.skinColor.seasonDetail}}</text>
          </view>
        </view>

        <view class="card">
          <view class="card-title">本命色盘</view>
          <view class="color-palette">
            <view class="color-item" wx:for="{{report.skinColor.goodColors}}" wx:key="name">
              <view class="color-swatch" style="background: {{item.hex}}"></view>
              <text class="color-name">{{item.name}}</text>
              <text class="color-hex">{{item.hex}}</text>
            </view>
          </view>
        </view>

        <view class="card">
          <view class="card-title danger-title">避雷色盘</view>
          <view class="color-palette bad">
            <view class="color-item" wx:for="{{report.skinColor.badColors}}" wx:key="name">
              <view class="color-swatch" style="background: {{item.hex}}"></view>
              <text class="color-name">{{item.name}}</text>
              <text class="color-reason">{{item.reason}}</text>
            </view>
          </view>
        </view>

        <view class="card">
          <view class="card-title">适配发色</view>
          <view class="haircolor-list">
            <view class="haircolor-item" wx:for="{{report.skinColor.goodHairColors}}" wx:key="name">
              <text class="hc-name">✅ {{item.name}}</text>
              <text class="hc-detail">{{item.detail}}</text>
            </view>
          </view>
          <view class="divider"></view>
          <view class="haircolor-list bad">
            <view class="haircolor-item" wx:for="{{report.skinColor.badHairColors}}" wx:key="name">
              <text class="hc-name">❌ {{item.name}}</text>
              <text class="hc-detail">{{item.reason}}</text>
            </view>
          </view>
        </view>
      </view>
    </swiper-item>

    <!-- 板块4: 风格基因 -->
    <swiper-item>
      <view class="section-body">
        <view class="card">
          <view class="card-title">核心风格: {{report.style.mainStyle}}</view>
          <view class="style-score-display">
            <text class="ss-num">{{report.style.mainScore}}</text>
            <text class="ss-max">/10</text>
          </view>
          <view class="sub-styles">
            <view class="sub-style" wx:for="{{report.style.subStyles}}" wx:key="name">
              <text class="ss-name">{{item.name}}</text>
              <view class="score-bar" style="flex:1;margin:0 16rpx"><view class="score-bar-inner" style="width: {{item.score * 10}}%"></view></view>
              <text class="ss-score">{{item.score}}</text>
            </view>
          </view>
        </view>

        <view class="card">
          <view class="card-title">风格特征</view>
          <view class="style-features">
            <view class="sf-item">
              <text class="sf-label">量感</text>
              <text class="sf-value">{{report.style.features.mass}}</text>
            </view>
            <view class="sf-item">
              <text class="sf-label">直曲</text>
              <text class="sf-value">{{report.style.features.curve}}</text>
            </view>
            <view class="sf-item">
              <text class="sf-label">动静</text>
              <text class="sf-value">{{report.style.features.movement}}</text>
            </view>
          </view>
        </view>

        <view class="card" wx:if="{{report.style.clothingAdvice}}">
          <view class="card-title">适配穿搭建议</view>
          <view class="advice-list">
            <view class="advice-item" wx:if="{{report.style.clothingAdvice.silhouette}}">
              <text class="ad-label">版型:</text>
              <text class="ad-value">{{report.style.clothingAdvice.silhouette}}</text>
            </view>
            <view class="advice-item" wx:if="{{report.style.clothingAdvice.material}}">
              <text class="ad-label">材质:</text>
              <text class="ad-value">{{report.style.clothingAdvice.material}}</text>
            </view>
            <view class="advice-item" wx:if="{{report.style.clothingAdvice.pattern}}">
              <text class="ad-label">图案:</text>
              <text class="ad-value">{{report.style.clothingAdvice.pattern}}</text>
            </view>
          </view>
        </view>

        <view class="card" wx:if="{{report.style.sceneAdvice && report.style.sceneAdvice.length}}">
          <view class="card-title">场景穿搭方案</view>
          <view class="scene-list">
            <view class="scene-item" wx:for="{{report.style.sceneAdvice}}" wx:key="scene">
              <view class="scene-name">{{item.scene}}</view>
              <view class="scene-desc">{{item.desc}}</view>
            </view>
          </view>
        </view>
      </view>
    </swiper-item>

    <!-- 板块5: 身形适配 -->
    <swiper-item>
      <view class="section-body">
        <view class="card">
          <view class="card-title">身形推导结果</view>
          <view class="body-result">
            <view class="body-attr">
              <text class="ba-label">肩型</text>
              <text class="ba-value">{{report.bodyShape.shoulderType}}</text>
            </view>
            <view class="body-attr">
              <text class="ba-label">身形比例</text>
              <text class="ba-value">{{report.bodyShape.bodyRatio}}</text>
            </view>
          </view>
        </view>

        <view class="card">
          <view class="card-title">适配上衣版型</view>
          <view class="fit-list">
            <view class="fit-item" wx:for="{{report.bodyShape.suitableTop}}" wx:key="type">
              <text class="fit-name">{{item.type}}</text>
              <view class="score-bar" style="flex:1;margin:0 16rpx"><view class="score-bar-inner" style="width: {{item.score * 10}}%"></view></view>
              <text class="fit-score">{{item.score}}</text>
            </view>
          </view>
        </view>

        <view class="card">
          <view class="card-title">适配下装版型</view>
          <view class="fit-list">
            <view class="fit-item" wx:for="{{report.bodyShape.suitableBottom}}" wx:key="type">
              <text class="fit-name">{{item.type}}</text>
              <view class="score-bar" style="flex:1;margin:0 16rpx"><view class="score-bar-inner" style="width: {{item.score * 10}}%"></view></view>
              <text class="fit-score">{{item.score}}</text>
            </view>
          </view>
        </view>

        <view class="card" wx:if="{{report.bodyShape.avoidStyles && report.bodyShape.avoidStyles.length}}">
          <view class="card-title danger-title">避雷版型</view>
          <view class="avoid-list">
            <view class="avoid-item" wx:for="{{report.bodyShape.avoidStyles}}" wx:key="type">
              <text class="avoid-name">❌ {{item.type}}</text>
              <text class="avoid-reason">{{item.reason}}</text>
            </view>
          </view>
        </view>

        <view class="card" wx:if="{{report.bodyShape.tips && report.bodyShape.tips.length}}">
          <view class="card-title">比例优化技巧</view>
          <view class="tips-list">
            <view class="tip-item" wx:for="{{report.bodyShape.tips}}" wx:key="*this">
              <text class="tip-bullet">💡</text>
              <text class="tip-text">{{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </swiper-item>

    <!-- 板块6: 穿搭推荐 -->
    <swiper-item>
      <view class="section-body">
        <view class="card">
          <view class="card-title">适配基础款</view>
          <view class="item-list">
            <view class="outfit-item" wx:for="{{report.outfitItems.recommended}}" wx:key="name">
              <view class="oi-header">
                <text class="oi-name">{{item.name}}</text>
                <text class="oi-score" style="color: {{item.score >= 9 ? '#27ae60' : '#f39c12'}}">{{item.score}}分</text>
              </view>
              <view class="oi-tags">
                <text class="tag tag-primary">{{item.type}}</text>
                <text class="tag tag-warm">{{item.color}}</text>
                <text class="tag tag-cool">{{item.scene}}</text>
              </view>
              <view class="oi-detail" wx:if="{{item.material}}">
                <text>材质: {{item.material}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="card" wx:if="{{report.outfitItems.avoidItems && report.outfitItems.avoidItems.length}}">
          <view class="card-title danger-title">避雷单品</view>
          <view class="avoid-list">
            <view class="avoid-item" wx:for="{{report.outfitItems.avoidItems}}" wx:key="name">
              <text class="avoid-name">❌ {{item.name}}</text>
              <text class="avoid-reason">{{item.reason}}</text>
            </view>
          </view>
        </view>
      </view>
    </swiper-item>

    <!-- 板块7: 发型推荐 -->
    <swiper-item>
      <view class="section-body">
        <view class="card">
          <view class="card-title">TOP 推荐发型</view>
          <view class="top-hair-list">
            <view class="top-hair-item" wx:for="{{report.hairRecommend.top3}}" wx:key="name" wx:for-index="idx">
              <view class="th-rank">{{idx + 1}}</view>
              <view class="th-info">
                <view class="th-header">
                  <text class="th-name">{{item.name}}</text>
                  <text class="th-score">{{item.score}}分</text>
                </view>
                <view class="th-detail">
                  <text wx:if="{{item.length}}">长度: {{item.length}}</text>
                  <text wx:if="{{item.layers}}"> | {{item.layers}}</text>
                </view>
                <view class="th-detail" wx:if="{{item.bangs}}">
                  <text>刘海: {{item.bangs}}</text>
                </view>
                <view class="th-detail" wx:if="{{item.care}}">
                  <text>打理: {{item.care}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <view class="card">
          <view class="card-title">备选发型</view>
          <view class="alt-hair-list">
            <view class="alt-hair-item" wx:for="{{report.hairRecommend.alternatives}}" wx:key="name">
              <text class="ah-name">{{item.name}}</text>
              <text class="ah-style">{{item.style}}</text>
              <text class="ah-score">{{item.score}}分</text>
            </view>
          </view>
        </view>

        <view class="card">
          <view class="card-title">适配发色</view>
          <view class="haircolor-list">
            <view class="haircolor-item" wx:for="{{report.hairRecommend.hairColors}}" wx:key="name">
              <text class="hc-name">✅ {{item.name}}</text>
              <text class="hc-detail">{{item.detail}}</text>
            </view>
          </view>
        </view>

        <view class="card" wx:if="{{report.hairRecommend.avoidHair && report.hairRecommend.avoidHair.length}}">
          <view class="card-title danger-title">发型避雷</view>
          <view class="avoid-list">
            <view class="avoid-item" wx:for="{{report.hairRecommend.avoidHair}}" wx:key="name">
              <text class="avoid-name">❌ {{item.name}}</text>
              <text class="avoid-reason">{{item.reason}}</text>
            </view>
          </view>
        </view>
      </view>
    </swiper-item>

    <!-- 板块8: 妆容指南 -->
    <swiper-item>
      <view class="section-body">
        <view class="card">
          <view class="card-title">适配妆容: {{report.makeup.style}}</view>
        </view>

        <view class="card" wx:if="{{report.makeup.foundation}}">
          <view class="card-title">底妆建议</view>
          <view class="makeup-section">
            <view class="mu-item" wx:if="{{report.makeup.foundation.tone}}">
              <text class="mu-label">粉底色调</text>
              <text class="mu-value">{{report.makeup.foundation.tone}}</text>
            </view>
            <view class="mu-item" wx:if="{{report.makeup.foundation.shade}}">
              <text class="mu-label">色号选择</text>
              <text class="mu-value">{{report.makeup.foundation.shade}}</text>
            </view>
            <view class="mu-item" wx:if="{{report.makeup.foundation.concealer}}">
              <text class="mu-label">遮瑕重点</text>
              <text class="mu-value">{{report.makeup.foundation.concealer}}</text>
            </view>
          </view>
        </view>

        <view class="card" wx:if="{{report.makeup.eyeBrow}}">
          <view class="card-title">眉眼妆容</view>
          <view class="makeup-section">
            <view class="mu-item" wx:if="{{report.makeup.eyeBrow.shape}}">
              <text class="mu-label">眉形</text>
              <text class="mu-value">{{report.makeup.eyeBrow.shape}}</text>
            </view>
            <view class="mu-item" wx:if="{{report.makeup.eyeBrow.shadow}}">
              <text class="mu-label">眼影色调</text>
              <text class="mu-value">{{report.makeup.eyeBrow.shadow}}</text>
            </view>
            <view class="mu-item" wx:if="{{report.makeup.eyeBrow.eyeliner}}">
              <text class="mu-label">眼线风格</text>
              <text class="mu-value">{{report.makeup.eyeBrow.eyeliner}}</text>
            </view>
          </view>
        </view>

        <view class="card" wx:if="{{report.makeup.lipRecommend}}">
          <view class="card-title">唇妆推荐</view>
          <view class="makeup-section">
            <view class="mu-item" wx:if="{{report.makeup.lipRecommend.destiny}}">
              <text class="mu-label">本命色</text>
              <text class="mu-value">{{report.makeup.lipRecommend.destiny}}</text>
            </view>
            <view class="mu-item" wx:if="{{report.makeup.lipRecommend.daily}}">
              <text class="mu-label">日常色</text>
              <text class="mu-value">{{report.makeup.lipRecommend.daily}}</text>
            </view>
          </view>
        </view>

        <view class="card" wx:if="{{report.makeup.avoidMakeup && report.makeup.avoidMakeup.length}}">
          <view class="card-title danger-title">避雷妆容</view>
          <view class="avoid-list">
            <view class="avoid-item" wx:for="{{report.makeup.avoidMakeup}}" wx:key="*this">
              <text class="avoid-name">❌ {{item}}</text>
            </view>
          </view>
        </view>
      </view>
    </swiper-item>

    <!-- 板块9: 总结建议 -->
    <swiper-item>
      <view class="section-body">
        <view class="card summary-card">
          <view class="card-title">核心结论</view>
          <text class="summary-text">{{report.summary.coreConclusion}}</text>
        </view>

        <view class="card summary-card">
          <view class="card-title">改造优先级</view>
          <text class="summary-text">{{report.summary.priorityAdvice}}</text>
        </view>

        <view class="card summary-card" wx:if="{{report.summary.dailyTips && report.summary.dailyTips.length}}">
          <view class="card-title">日常小贴士</view>
          <view class="tips-list">
            <view class="tip-item" wx:for="{{report.summary.dailyTips}}" wx:key="*this">
              <text class="tip-bullet">💡</text>
              <text class="tip-text">{{item}}</text>
            </view>
          </view>
        </view>

        <!-- 重新诊断 -->
        <view class="card">
          <button class="btn-primary" bindtap="onReDiagnose">重新诊断</button>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <!-- 底部分享栏 -->
  <view class="share-bar safe-bottom">
    <button class="share-btn" open-type="share">
      <text class="share-icon">🔗</text>
      <text>分享</text>
    </button>
    <view class="share-btn" bindtap="onShare">
      <text class="share-icon">🖼️</text>
      <text>海报</text>
    </view>
  </view>
</view>
