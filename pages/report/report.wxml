<!--pages/report/report.wxml-->
<view class="page-report" wx:if="{{report}}">
  <!-- 顶部Tab导航 -->
  <view class="tab-bar">
    <scroll-view class="tab-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="tab-item {{activeTab === 'dna' ? 'active' : ''}}" data-tab="dna" bindtap="onTabTap">
        <text class="tab-label">面部&骨相</text>
      </view>
      <view class="tab-item {{activeTab === 'style' ? 'active' : ''}}" data-tab="style" bindtap="onTabTap">
        <text class="tab-label">皮肤&风格</text>
      </view>
      <view class="tab-item {{activeTab === 'hairmakeup' ? 'active' : ''}}" data-tab="hairmakeup" bindtap="onTabTap">
        <text class="tab-label">发型&妆容</text>
      </view>
      <view class="tab-item {{activeTab === 'optimize' ? 'active' : ''}}" data-tab="optimize" bindtap="onTabTap">
        <text class="tab-label">颜值&蜕变</text>
      </view>
    </scroll-view>
  </view>

  <!-- 综合评分头部 -->
  <view class="report-header">
    <view class="user-avatar" wx:if="{{report.photoUrl}}">
      <image class="avatar-img" src="{{report.photoUrl}}" mode="aspectFill" />
    </view>
    <view class="header-right">
      <view class="score-display">
      <text class="score-number">{{report.basic.overallScore}}</text>
      <text class="score-unit">分</text>
      </view>
      <view class="score-tags">
        <text class="tag" wx:for="{{report.basic.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 模块图片 -->
  <view class="module-content">
    <view class="image-card" wx:if="{{images[activeTab]}}">
      <image class="module-image" src="{{images[activeTab]}}" mode="widthFix" bindtap="onImagePreview" data-url="{{images[activeTab]}}"></image>
    </view>
    <view class="image-loading" wx:else>
      <text class="loading-text">图片生成失败，请重新诊断</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="share-bar safe-bottom">
    <button class="save-all-btn {{shared ? '' : 'locked'}}" bindtap="onSaveAllImages">
      <text>保存图片</text>
    </button>
    <button class="share-btn {{shared ? 'shared' : ''}}" open-type="share">
      <text class="share-icon">{{shared ? '✓' : '↗'}}</text>
      <text>{{shared ? '已分享' : '分享解锁'}}</text>
    </button>
    <button class="rediagnose-btn {{shared ? '' : 'locked'}}" bindtap="onReDiagnose">
      重新诊断
    </button>
  </view>
</view>
