<!--pages/report/report.wxml-->
<view class="page-report" wx:if="{{report}}">
  <!-- 顶部Tab导航 -->
  <view class="tab-bar">
    <scroll-view class="tab-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="tab-item {{activeTab === 'bone' ? 'active' : ''}}" data-tab="bone" bindtap="onTabTap">
        <text class="tab-label">骨相分析</text>
      </view>
      <view class="tab-item {{activeTab === 'skin' ? 'active' : ''}}" data-tab="skin" bindtap="onTabTap">
        <text class="tab-label">皮肤状态</text>
      </view>
      <view class="tab-item {{activeTab === 'colorStyle' ? 'active' : ''}}" data-tab="colorStyle" bindtap="onTabTap">
        <text class="tab-label">色彩风格</text>
      </view>
      <view class="tab-item {{activeTab === 'outfit' ? 'active' : ''}}" data-tab="outfit" bindtap="onTabTap">
        <text class="tab-label">穿搭风格</text>
      </view>
    </scroll-view>
  </view>

  <!-- 综合评分头部 -->
  <view class="report-header">
    <view class="score-display">
      <text class="score-number">{{report.basic.overallScore}}</text>
      <text class="score-max">/10</text>
    </view>
    <view class="score-level" style="color: {{scoreLevel.color}}">{{scoreLevel.text}}</view>
    <view class="score-tags">
      <text class="tag" wx:for="{{report.basic.tags}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="score-desc" wx:if="{{report.basic.advantages}}">
      <text class="desc-advantage">{{report.basic.advantages}}</text>
    </view>
  </view>

  <!-- 模块内容（swipe切换） -->
  <swiper class="module-swiper" current="{{tabIndex}}" bindchange="onSwiperChange">
    <!-- 骨相分析 -->
    <swiper-item>
      <scroll-view class="module-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="module-content">
          <!-- 三庭五眼标注图（Canvas在用户原图上绘制） -->
          <view class="annotation-card" wx:if="{{report.photoUrl}}">
            <view class="card-title">三庭五眼标注</view>
            <view class="canvas-wrap">
              <canvas type="2d" id="faceAnnotation" class="face-canvas"></canvas>
            </view>
          </view>

          <view class="section-card">
            <view class="card-header">
              <text class="card-title">脸型判定</text>
              <view class="card-score-wrap">
                <text class="card-score">{{bone.faceScore}}</text>
                <text class="card-score-max">/10</text>
              </view>
            </view>
            <view class="face-type-badge">
              <text class="face-type-name">{{bone.faceType}}</text>
              <text class="face-type-bone">{{bone.boneType}}</text>
            </view>
            <text class="card-desc" wx:if="{{bone.boneDesc}}">{{bone.boneDesc}}</text>
          </view>

          <view class="section-card" wx:if="{{bone.threeCourts}}">
            <view class="card-title">三庭五眼</view>
            <view class="court-list">
              <view class="court-item">
                <text class="court-label">上庭</text>
                <text class="court-value">{{bone.threeCourts.upper}}</text>
              </view>
              <view class="court-item">
                <text class="court-label">中庭</text>
                <text class="court-value">{{bone.threeCourts.middle}}</text>
              </view>
              <view class="court-item">
                <text class="court-label">下庭</text>
                <text class="court-value">{{bone.threeCourts.lower}}</text>
              </view>
              <view class="court-item highlight">
                <text class="court-label">总体</text>
                <text class="court-value">{{bone.threeCourts.balance}}</text>
              </view>
            </view>
            <view class="five-eyes" wx:if="{{bone.fiveEyes}}">
              <text class="fe-title">五眼分析</text>
              <text class="fe-desc">{{bone.fiveEyes.analysis}}</text>
              <text class="fe-suggestion" wx:if="{{bone.fiveEyes.suggestion}}">{{bone.fiveEyes.suggestion}}</text>
            </view>
          </view>

          <!-- 面部特征雷达图 -->
          <view class="section-card" wx:if="{{bone.faceFeatures.length >= 3}}">
            <view class="card-title">面部特征雷达图</view>
            <view class="radar-wrap">
              <canvas type="2d" id="radarChart" class="radar-canvas"></canvas>
            </view>
          </view>

          <view class="section-card" wx:if="{{bone.faceFeatures.length}}">
            <view class="card-title">特征评分明细</view>
            <view class="feature-list">
              <view class="feature-item" wx:for="{{bone.faceFeatures}}" wx:key="name">
                <text class="fi-name">{{item.name}}</text>
                <view class="fi-bar-wrap">
                  <view class="fi-bar" style="width: {{item.score * 10}}%"></view>
                </view>
                <text class="fi-score">{{item.score}}</text>
                <text class="fi-desc">{{item.desc}}</text>
              </view>
            </view>
          </view>

          <view class="section-card" wx:if="{{bone.suitableHaircuts.length}}">
            <view class="card-title">适配发型</view>
            <view class="haircut-list">
              <view class="haircut-item" wx:for="{{bone.suitableHaircuts}}" wx:key="name">
                <view class="hi-main">
                  <text class="hi-name">{{item.name}}</text>
                  <text class="hi-score">{{item.score}}分</text>
                </view>
                <view class="hi-detail">
                  <text wx:if="{{item.length}}">{{item.length}}</text>
                  <text wx:if="{{item.bangs}}"> · 刘海: {{item.bangs}}</text>
                </view>
                <text class="hi-reason" wx:if="{{item.reason}}">{{item.reason}}</text>
              </view>
            </view>
          </view>

          <view class="section-card danger" wx:if="{{bone.avoidHaircuts.length}}">
            <view class="card-title">避雷发型</view>
            <view class="avoid-list">
              <view class="avoid-item" wx:for="{{bone.avoidHaircuts}}" wx:key="name">
                <text class="avoid-name">{{item.name}}</text>
                <text class="avoid-reason">{{item.reason}}</text>
              </view>
            </view>
          </view>

          <view class="insight-card" wx:if="{{bone.keyInsight}}">
            <text class="insight-text">{{bone.keyInsight}}</text>
          </view>
        </view>
      </scroll-view>
    </swiper-item>

    <!-- 皮肤状态 -->
    <swiper-item>
      <scroll-view class="module-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="module-content">
          <view class="poster-card" wx:if="{{posters.skin}}">
            <image class="poster-img" src="{{posters.skin}}" mode="aspectFill"></image>
          </view>

          <!-- 色彩三维诊断 -->
          <view class="section-card" wx:if="{{skin.brightness || skin.purity}}">
            <view class="card-title">色彩三维诊断</view>
            <view class="color-triangle-wrap">
              <canvas type="2d" id="colorTriangle" class="color-triangle-canvas"></canvas>
            </view>
            <view class="color-three-desc">
              <text class="ctd-item">明度 <text class="ctd-val">{{skin.brightness}}/10</text></text>
              <text class="ctd-item">纯度 <text class="ctd-val">{{skin.purity}}/10</text></text>
              <text class="ctd-item">量感 <text class="ctd-val">{{colorStyle.styleFeatures.mass || '中'}}</text></text>
            </view>
          </view>

          <view class="section-card">
            <view class="card-header">
              <text class="card-title">肤色属性</text>
              <text class="skin-type-badge">{{skin.skinType}}</text>
            </view>
            <view class="skin-scores">
              <view class="skin-score-item">
                <text class="ss-label">明度</text>
                <view class="fi-bar-wrap"><view class="fi-bar" style="width: {{skin.brightness * 10}}%"></view></view>
                <text class="ss-val">{{skin.brightness}}</text>
              </view>
              <view class="skin-score-item">
                <text class="ss-label">纯度</text>
                <view class="fi-bar-wrap"><view class="fi-bar" style="width: {{skin.purity * 10}}%"></view></view>
                <text class="ss-val">{{skin.purity}}</text>
              </view>
            </view>
            <text class="card-desc" wx:if="{{skin.overallDesc}}">{{skin.overallDesc}}</text>
          </view>

          <view class="section-card" wx:if="{{skin.problems.length}}">
            <view class="card-title">皮肤问题</view>
            <view class="problem-list">
              <view class="problem-item" wx:for="{{skin.problems}}" wx:key="name">
                <view class="pm-header">
                  <text class="pm-name">{{item.name}}</text>
                  <text class="pm-level {{item.level === '无' ? 'good' : ''}}">{{item.level}}</text>
                </view>
                <text class="pm-area" wx:if="{{item.area}}">位置: {{item.area}}</text>
                <text class="pm-advice" wx:if="{{item.advice}}">{{item.advice}}</text>
              </view>
            </view>
          </view>

          <view class="section-card">
            <view class="card-title">四季色彩季型</view>
            <view class="season-box">
              <text class="season-name">{{skin.season}}</text>
              <text class="season-detail" wx:if="{{skin.seasonDetail}}">{{skin.seasonDetail}}</text>
            </view>
          </view>

          <view class="section-card" wx:if="{{skin.goodColors.length}}">
            <view class="card-title">本命色盘</view>
            <view class="color-palette">
              <view class="color-item" wx:for="{{skin.goodColors}}" wx:key="name">
                <view class="color-swatch" style="background: {{item.hex}}"></view>
                <text class="color-name">{{item.name}}</text>
                <text class="color-usage" wx:if="{{item.usage}}">{{item.usage}}</text>
              </view>
            </view>
          </view>

          <view class="section-card danger" wx:if="{{skin.badColors.length}}">
            <view class="card-title">避雷色盘</view>
            <view class="color-palette bad">
              <view class="color-item" wx:for="{{skin.badColors}}" wx:key="name">
                <view class="color-swatch" style="background: {{item.hex}}"></view>
                <text class="color-name">{{item.name}}</text>
                <text class="color-reason">{{item.reason}}</text>
              </view>
            </view>
          </view>

          <view class="section-card" wx:if="{{skin.skincareAdvice.length}}">
            <view class="card-title">护肤建议</view>
            <view class="tips-list">
              <view class="tip-item" wx:for="{{skin.skincareAdvice}}" wx:key="*this">
                <text class="tip-bullet">·</text>
                <text class="tip-text">{{item}}</text>
              </view>
            </view>
          </view>

          <view class="insight-card" wx:if="{{skin.keyInsight}}">
            <text class="insight-text">{{skin.keyInsight}}</text>
          </view>
        </view>
      </scroll-view>
    </swiper-item>

    <!-- 色彩风格 -->
    <swiper-item>
      <scroll-view class="module-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="module-content">
          <view class="poster-card" wx:if="{{posters.colorStyle}}">
            <image class="poster-img" src="{{posters.colorStyle}}" mode="aspectFill"></image>
          </view>

          <view class="section-card">
            <view class="card-header">
              <text class="card-title">核心风格</text>
              <view class="card-score-wrap">
                <text class="card-score">{{colorStyle.mainScore}}</text>
                <text class="card-score-max">/10</text>
              </view>
            </view>
            <text class="main-style-name">{{colorStyle.mainStyle}}</text>
            <text class="card-desc" wx:if="{{colorStyle.styleDesc}}">{{colorStyle.styleDesc}}</text>
            <view class="sub-styles" wx:if="{{colorStyle.subStyles.length}}">
              <view class="sub-style" wx:for="{{colorStyle.subStyles}}" wx:key="name">
                <text class="ss-name">{{item.name}}</text>
                <view class="fi-bar-wrap"><view class="fi-bar" style="width: {{item.score * 10}}%"></view></view>
                <text class="ss-score">{{item.score}}</text>
              </view>
            </view>
          </view>

          <view class="section-card" wx:if="{{colorStyle.styleFeatures}}">
            <view class="card-title">风格特征</view>
            <view class="style-features">
              <view class="sf-item">
                <text class="sf-label">量感</text>
                <text class="sf-value">{{colorStyle.styleFeatures.mass}}</text>
              </view>
              <view class="sf-item">
                <text class="sf-label">直曲</text>
                <text class="sf-value">{{colorStyle.styleFeatures.curve}}</text>
              </view>
              <view class="sf-item">
                <text class="sf-label">动静</text>
                <text class="sf-value">{{colorStyle.styleFeatures.movement}}</text>
              </view>
            </view>
          </view>

          <view class="section-card" wx:if="{{colorStyle.colorPalette}}">
            <view class="card-title">色彩搭配方案</view>
            <view class="palette-group" wx:if="{{colorStyle.colorPalette.primary.length}}">
              <text class="pg-label">主色调</text>
              <view class="pg-colors">
                <text class="pg-color" wx:for="{{colorStyle.colorPalette.primary}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
            <view class="palette-group" wx:if="{{colorStyle.colorPalette.secondary.length}}">
              <text class="pg-label">辅助色</text>
              <view class="pg-colors">
                <text class="pg-color" wx:for="{{colorStyle.colorPalette.secondary}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
            <view class="palette-group" wx:if="{{colorStyle.colorPalette.accent.length}}">
              <text class="pg-label">点缀色</text>
              <view class="pg-colors">
                <text class="pg-color accent" wx:for="{{colorStyle.colorPalette.accent}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
          </view>

          <view class="section-card" wx:if="{{colorStyle.clothingAdvice}}">
            <view class="card-title">穿搭建议</view>
            <view class="advice-list">
              <view class="advice-item" wx:if="{{colorStyle.clothingAdvice.silhouette}}">
                <text class="ad-label">版型</text>
                <text class="ad-value">{{colorStyle.clothingAdvice.silhouette}}</text>
              </view>
              <view class="advice-item" wx:if="{{colorStyle.clothingAdvice.material}}">
                <text class="ad-label">材质</text>
                <text class="ad-value">{{colorStyle.clothingAdvice.material}}</text>
              </view>
              <view class="advice-item" wx:if="{{colorStyle.clothingAdvice.pattern}}">
                <text class="ad-label">图案</text>
                <text class="ad-value">{{colorStyle.clothingAdvice.pattern}}</text>
              </view>
            </view>
          </view>

          <view class="section-card" wx:if="{{colorStyle.sceneAdvice.length}}">
            <view class="card-title">场景穿搭方案</view>
            <view class="scene-list">
              <view class="scene-item" wx:for="{{colorStyle.sceneAdvice}}" wx:key="scene">
                <text class="scene-name">{{item.scene}}</text>
                <text class="scene-desc">{{item.desc}}</text>
                <text class="scene-key" wx:if="{{item.keyItems}}">关键单品: {{item.keyItems}}</text>
              </view>
            </view>
          </view>

          <view class="section-card" wx:if="{{colorStyle.outfitItems.length}}">
            <view class="card-title">推荐单品</view>
            <view class="outfit-list">
              <view class="outfit-item" wx:for="{{colorStyle.outfitItems}}" wx:key="name">
                <view class="oi-main">
                  <text class="oi-name">{{item.name}}</text>
                  <text class="oi-score">{{item.score}}分</text>
                </view>
                <view class="oi-tags">
                  <text class="tag small">{{item.type}}</text>
                  <text class="tag small warm">{{item.color}}</text>
                  <text class="tag small cool" wx:if="{{item.scene}}">{{item.scene}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="insight-card" wx:if="{{colorStyle.keyInsight}}">
            <text class="insight-text">{{colorStyle.keyInsight}}</text>
          </view>
        </view>
      </scroll-view>
    </swiper-item>

    <!-- 穿搭风格 -->
    <swiper-item>
      <scroll-view class="module-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="module-content">
          <view class="poster-card" wx:if="{{posters.outfit}}">
            <image class="poster-img" src="{{posters.outfit}}" mode="aspectFill"></image>
          </view>

          <!-- 发型推荐 -->
          <view class="section-card" wx:if="{{outfit.hairRecommend.top3.length}}">
            <view class="card-title">TOP 推荐发型</view>
            <view class="top-hair-list">
              <view class="top-hair-item" wx:for="{{outfit.hairRecommend.top3}}" wx:key="name" wx:for-index="idx">
                <view class="th-rank">{{idx + 1}}</view>
                <view class="th-info">
                  <view class="th-header">
                    <text class="th-name">{{item.name}}</text>
                    <text class="th-score">{{item.score}}分</text>
                  </view>
                  <text class="th-detail" wx:if="{{item.length}}">长度: {{item.length}}</text>
                  <text class="th-detail" wx:if="{{item.bangs}}">刘海: {{item.bangs}}</text>
                  <text class="th-detail" wx:if="{{item.care}}">打理: {{item.care}}</text>
                </view>
              </view>
            </view>
          </view>

          <view class="section-card" wx:if="{{outfit.hairRecommend.avoidHair.length}}">
            <view class="card-title danger">发型避雷</view>
            <view class="avoid-list">
              <view class="avoid-item" wx:for="{{outfit.hairRecommend.avoidHair}}" wx:key="name">
                <text class="avoid-name">{{item.name}}</text>
                <text class="avoid-reason">{{item.reason}}</text>
              </view>
            </view>
          </view>

          <!-- 妆容 -->
          <view class="section-card" wx:if="{{outfit.makeup.style}}">
            <view class="card-title">适配妆容: {{outfit.makeup.style}}</view>
            <view class="makeup-grid">
              <view class="mu-section" wx:if="{{outfit.makeup.foundation.tone}}">
                <text class="mu-label">底妆</text>
                <text class="mu-value">{{outfit.makeup.foundation.tone}}</text>
                <text class="mu-value" wx:if="{{outfit.makeup.foundation.concealer}}">遮瑕: {{outfit.makeup.foundation.concealer}}</text>
              </view>
              <view class="mu-section" wx:if="{{outfit.makeup.eyeBrow.shape}}">
                <text class="mu-label">眉眼</text>
                <text class="mu-value">{{outfit.makeup.eyeBrow.shape}}</text>
                <text class="mu-value" wx:if="{{outfit.makeup.eyeBrow.shadow}}">{{outfit.makeup.eyeBrow.shadow}}</text>
              </view>
              <view class="mu-section" wx:if="{{outfit.makeup.lipRecommend.destiny}}">
                <text class="mu-label">唇妆</text>
                <text class="mu-value">本命: {{outfit.makeup.lipRecommend.destiny}}</text>
                <text class="mu-value" wx:if="{{outfit.makeup.lipRecommend.daily}}">日常: {{outfit.makeup.lipRecommend.daily}}</text>
              </view>
            </view>
          </view>

          <!-- 身形 -->
          <view class="section-card" wx:if="{{outfit.bodyShape.shoulderType}}">
            <view class="card-title">身形适配</view>
            <view class="body-result">
              <view class="body-attr">
                <text class="ba-label">肩型</text>
                <text class="ba-value">{{outfit.bodyShape.shoulderType}}</text>
              </view>
              <view class="body-attr">
                <text class="ba-label">身形比例</text>
                <text class="ba-value">{{outfit.bodyShape.bodyRatio}}</text>
              </view>
            </view>
          </view>

          <!-- 总结 -->
          <view class="section-card" wx:if="{{outfit.summary.coreConclusion}}">
            <view class="card-title">行动建议</view>
            <text class="summary-text">{{outfit.summary.coreConclusion}}</text>
            <text class="priority-text" wx:if="{{outfit.summary.priorityAdvice}}">{{outfit.summary.priorityAdvice}}</text>
            <view class="tips-list" wx:if="{{outfit.summary.dailyTips.length}}">
              <view class="tip-item" wx:for="{{outfit.summary.dailyTips}}" wx:key="*this">
                <text class="tip-bullet">·</text>
                <text class="tip-text">{{item}}</text>
              </view>
            </view>
          </view>

          <view class="insight-card" wx:if="{{outfit.keyInsight}}">
            <text class="insight-text">{{outfit.keyInsight}}</text>
          </view>
        </view>
      </scroll-view>
    </swiper-item>
  </swiper>

  <!-- 底部分享栏 -->
  <view class="share-bar safe-bottom">
    <button class="share-btn" open-type="share">
      <text class="share-icon">↗</text>
      <text>分享</text>
    </button>
    <button class="rediagnose-btn" bindtap="onReDiagnose">重新诊断</button>
  </view>
</view>
