<!--pages/reports/reports.wxml-->
<view class="page-reports">
  <view class="reports-list" wx:if="{{reports.length > 0}}">
    <view class="report-item" wx:for="{{reports}}" wx:key="id">
      <view class="report-main" data-id="{{item.id}}" bindtap="onViewReport">
        <view class="report-score-ring">
          <text class="score-num">{{item.basic.overallScore}}</text>
          <text class="score-label">综合评分</text>
        </view>
        <view class="report-info">
          <view class="report-tags">
            <block wx:for="{{item.basic.tags}}" wx:for-item="tag" wx:key="*this" wx:for-index="ti">
              <text class="tag tag-gold" wx:if="{{tag && tag.indexOf('视龄') !== 0 && ti !== item.basic.tags.length - 1}}">{{tag}}</text>
            </block>
          </view>
          <view class="report-meta">
            <text class="report-time">{{item.createTime}}</text>
            <text class="report-arrow">›</text>
          </view>
        </view>
      </view>
      <view class="report-divider"></view>
      <view class="report-actions">
        <text class="action-delete" data-id="{{item.id}}" bindtap="onDeleteReport">删除报告</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <view class="empty-icon icon icon-chart" style="font-size:120rpx;"></view>
    <text class="empty-text">还没有诊断报告</text>
    <button class="btn-primary" bindtap="onGoDiagnose" style="margin-top: 32rpx;">开始诊断</button>
  </view>

  <!-- 底部重新诊断入口 -->
  <view class="rediagnose-bar safe-bottom">
    <button class="rd-share-btn {{shared ? 'shared' : ''}}" open-type="share">
      <text class="rd-share-icon">{{shared ? '✓' : '↗'}}</text>
      <text>{{shared ? '已分享' : '分享解锁'}}</text>
      <text class="rd-share-hint" wx:if="{{!shared}}">分享后可重测</text>
    </button>
    <button class="rd-action-btn {{shared ? '' : 'locked'}}" bindtap="onReDiagnose">
      <text class="rd-lock-icon" wx:if="{{!shared}}"></text>
      <text>重新诊断</text>
    </button>
  </view>
</view>