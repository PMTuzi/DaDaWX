/* pages/reports/reports.wxss */
.page-reports {
  min-height: 100vh;
  background: #FAF6F0;
  padding: 24rpx;
}

.report-item {
  background: #FFFCF7;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(200, 169, 126, 0.1);
  border: 2rpx solid rgba(200, 169, 126, 0.12);
  overflow: hidden;
}

.report-main {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx 28rpx;
  gap: 32rpx;
}

.report-score-ring {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(200, 169, 126, 0.12), rgba(200, 169, 126, 0.04));
  border: 3rpx solid rgba(200, 169, 126, 0.3);
  flex-shrink: 0;
}

.score-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #9A7B4F;
  line-height: 1.1;
}

.score-label {
  font-size: 18rpx;
  color: rgba(154, 123, 79, 0.5);
  margin-top: 4rpx;
}

.report-info {
  flex: 1;
  min-width: 0;
}

.report-tags {
  margin-bottom: 12rpx;
}

.report-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.report-time {
  font-size: 22rpx;
  color: rgba(154, 123, 79, 0.45);
}

.report-arrow {
  font-size: 36rpx;
  color: rgba(200, 169, 126, 0.5);
  font-weight: 300;
  line-height: 1;
}

.report-divider {
  height: 1rpx;
  background: rgba(200, 169, 126, 0.12);
  margin: 0 32rpx;
}

.report-actions {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 32rpx 20rpx;
}

.action-delete {
  font-size: 24rpx;
  color: rgba(154, 123, 79, 0.4);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 底部重新诊断栏 */
.rediagnose-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: #FFFCF7;
  box-shadow: 0 -4rpx 20rpx rgba(200, 169, 126, 0.1);
}

.rd-share-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #C9A96E;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 0 24rpx;
  border-radius: 40rpx;
  height: 80rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.rd-share-btn.shared {
  background: rgba(200, 169, 126, 0.12);
  color: #9A7B4F;
}

.rd-share-icon {
  font-size: 28rpx;
}

.rd-share-hint {
  font-size: 18rpx;
  opacity: 0.7;
  font-weight: 400;
}

.rd-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #C9A96E, #B8935A);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(200, 169, 126, 0.35);
}

.rd-action-btn.locked {
  opacity: 0.4;
  background: #999;
  box-shadow: none;
}

.rd-lock-icon {
  font-size: 24rpx;
}
