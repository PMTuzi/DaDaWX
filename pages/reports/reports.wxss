/* pages/reports/reports.wxss */
.page-reports {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 24rpx;
}

.report-item {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.report-main {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx 28rpx;
  gap: 32rpx;
}

.report-score-ring {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(232, 168, 124, 0.12), rgba(232, 168, 124, 0.04));
  border: 3rpx solid rgba(232, 168, 124, 0.25);
  flex-shrink: 0;
}

.score-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--accent);
  line-height: 1.1;
}

.score-label {
  font-size: 18rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

.report-info {
  flex: 1;
  min-width: 0;
}

.report-tags {
  margin-bottom: 12rpx;
}

.report-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.report-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.report-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
  font-weight: 300;
  line-height: 1;
}

.report-divider {
  height: 1rpx;
  background: var(--border);
  margin: 0 32rpx;
}

.report-actions {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 32rpx 20rpx;
}

.action-delete {
  font-size: 24rpx;
  color: var(--text-hint);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
