/* pages/reports/reports.wxss */
.page-reports {
  min-height: 100vh;
  background: #FFFFFF;
  padding: 24rpx 24rpx calc(180rpx + env(safe-area-inset-bottom));
}

/* ===== 列表卡片 ===== */
.report-item {
  position: relative;
  background: #ffffff;
  border-radius: 28rpx;
  margin-bottom: 24rpx;
  box-shadow:
    0 6rpx 28rpx rgba(183, 110, 121, 0.10),
    0 2rpx 8rpx rgba(183, 110, 121, 0.06);
  border: 1rpx solid rgba(183, 110, 121, 0.10);
  overflow: hidden;
}

/* 顶部装饰条 */
.report-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #B76E79 0%, #C38D9E 50%, #E8A87C 100%);
}

.report-main {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx 24rpx;
  gap: 28rpx;
}

/* 分数环 - 玫瑰金渐变 */
.report-score-ring {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE4EC 100%);
  flex-shrink: 0;
  box-shadow:
    0 4rpx 16rpx rgba(183, 110, 121, 0.15),
    inset 0 0 0 3rpx rgba(255, 255, 255, 0.9);
}

.report-score-ring::before {
  content: '';
  position: absolute;
  inset: -3rpx;
  border-radius: 50%;
  padding: 3rpx;
  background: linear-gradient(135deg, #B76E79, #C38D9E, #E8A87C);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
}

.score-num {
  font-size: 46rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #B76E79 0%, #8B4F58 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  line-height: 1.1;
}

.score-label {
  font-size: 18rpx;
  color: #B89E8F;
  margin-top: 4rpx;
  letter-spacing: 1rpx;
}

.report-info {
  flex: 1;
  min-width: 0;
}

/* 标签 - 浅粉渐变 */
.report-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.report-tags .tag {
  margin: 0;
  padding: 6rpx 16rpx;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE4EC 100%);
  color: #E58FA1;
  border: 1rpx solid rgba(233, 30, 99, 0.15);
  box-shadow: 0 1rpx 4rpx rgba(233, 30, 99, 0.06);
}

/* 视龄标签（最后一个，特殊样式） */
.report-tags .tag.tag-age {
  background: linear-gradient(135deg, #FFD86F 0%, #E8A87C 50%, #C38D9E 100%);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 2rpx 8rpx rgba(200, 133, 110, 0.4);
}

.report-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.report-time {
  font-size: 22rpx;
  color: #B89E8F;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.report-time::before {
  content: '✦';
  color: #E8A87C;
  font-size: 18rpx;
}

.report-arrow {
  font-size: 36rpx;
  color: #C38D9E;
  font-weight: 300;
  line-height: 1;
}

.report-divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, rgba(183, 110, 121, 0.15), transparent);
  margin: 0 28rpx;
}

.report-actions {
  display: flex;
  justify-content: flex-end;
  padding: 14rpx 28rpx 18rpx;
}

.action-delete {
  font-size: 22rpx;
  color: #B89E8F;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(183, 110, 121, 0.06);
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  color: rgba(183, 110, 121, 0.3);
}

.empty-text {
  font-size: 28rpx;
  color: #B89E8F;
  margin-top: 24rpx;
}

/* ===== 底部重新诊断栏 ===== */
.rediagnose-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -6rpx 24rpx rgba(183, 110, 121, 0.10);
  z-index: 10;
}

.rd-share-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #F1849B;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 0 24rpx;
  border-radius: 40rpx;
  height: 80rpx;
  flex-shrink: 0;
  white-space: nowrap;
  box-shadow: 0 6rpx 16rpx rgba(241, 132, 155, 0.35);
}

.rd-share-btn.shared {
  background: rgba(183, 110, 121, 0.12);
  color: #B76E79;
  box-shadow: none;
}

.rd-share-icon {
  font-size: 28rpx;
}

.rd-share-hint {
  font-size: 18rpx;
  opacity: 0.7;
  font-weight: 400;
}

.rd-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #F1849B 0%, #FF9EB0 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(241, 132, 155, 0.4);
}

.rd-action-btn.locked {
  opacity: 0.4;
  background: #999;
  box-shadow: none;
}

.rd-lock-icon {
  font-size: 24rpx;
}
