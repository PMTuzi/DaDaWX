/* pages/reports/reports.wxss */
.page-reports {
  min-height: 100vh;
  background: #f5f5f7;
  padding: 24rpx;
}

.report-item {
  background: var(--card-bg);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.report-main {
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx 28rpx;
  gap: 32rpx;
}

.report-score-ring {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(232, 168, 124, 0.12), rgba(232, 168, 124, 0.04));
  border: 3rpx solid rgba(232, 168, 124, 0.25);
  flex-shrink: 0;
}

.score-num {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--accent);
  line-height: 1.1;
}

.score-label {
  font-size: 18rpx;
  color: var(--text-hint);
  margin-top: 4rpx;
}

.report-info {
  flex: 1;
  min-width: 0;
}

.report-tags {
  margin-bottom: 12rpx;
}

.report-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.report-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.report-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
  font-weight: 300;
  line-height: 1;
}

.report-divider {
  height: 1rpx;
  background: var(--border);
  margin: 0 32rpx;
}

.report-actions {
  display: flex;
  justify-content: flex-end;
  padding: 16rpx 32rpx 20rpx;
}

.action-delete {
  font-size: 24rpx;
  color: var(--text-hint);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 底部重新诊断栏 */
.rediagnose-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.rd-share-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #F1849B;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 500;
  padding: 0 24rpx;
  border-radius: 40rpx;
  height: 80rpx;
  flex-shrink: 0;
  white-space: nowrap;
}

.rd-share-btn.shared {
  background: #E8F5E9;
  color: #4CAF50;
}

.rd-share-icon {
  font-size: 28rpx;
}

.rd-share-hint {
  font-size: 18rpx;
  opacity: 0.7;
  font-weight: 400;
}

.rd-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 80rpx;
  background: #C8A97E;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
}

.rd-action-btn.locked {
  opacity: 0.4;
  background: #999;
}

.rd-lock-icon {
  font-size: 24rpx;
}
