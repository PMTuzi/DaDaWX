/* pages/consult-publish/consult-publish.wxss */
/* 清新简洁风：白底 + 单一玫瑰粉 #F1849B 主色，与形象诊断页保持一致 */

.page-publish {
  position: relative;
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  color: #1a1a1a;
  overflow: hidden;
}

/* ============ 顶部品牌头 ============ */
.scene-header {
  position: relative;
  padding: 32rpx 32rpx 8rpx;
}

.scene-header::before {
  content: '';
  position: absolute;
  top: -120rpx;
  right: -160rpx;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(241, 132, 155, 0.25) 0%, transparent 70%);
  filter: blur(80rpx);
  pointer-events: none;
  z-index: 0;
}

.scene-title {
  position: relative;
  font-size: 48rpx;
  font-weight: 800;
  color: #1a1a1a;
  letter-spacing: 3rpx;
  margin-bottom: 12rpx;
  z-index: 1;
}

.scene-desc {
  position: relative;
  font-size: 24rpx;
  color: #999;
  letter-spacing: 1rpx;
  line-height: 1.6;
  z-index: 1;
}

/* ============ 表单区块 ============ */
.section {
  position: relative;
  margin: 0 32rpx 28rpx;
  z-index: 1;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}

.label-required {
  font-size: 28rpx;
  color: #F1849B;
}

.ai-badge {
  font-size: 20rpx;
  color: #F1849B;
  background: rgba(241, 132, 155, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
  font-weight: 500;
}

.label-hint {
  font-size: 22rpx;
  color: #b8b8b8;
}

/* ============ 图片上传 ============ */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #fafafa;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 6rpx 0;
  background: rgba(241, 132, 155, 0.85);
  color: #fff;
  font-size: 22rpx;
  text-align: center;
  letter-spacing: 1rpx;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  border: 2rpx dashed rgba(241, 132, 155, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #fff;
}

.image-add:active {
  border-color: #F1849B;
  background: rgba(241, 132, 155, 0.05);
}

.add-icon {
  font-size: 48rpx;
  color: #F1849B;
  font-weight: 300;
}

.add-text {
  font-size: 22rpx;
  color: #888;
}

/* ============ 模式提示 ============ */
.mode-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 14rpx 20rpx;
  background: rgba(241, 132, 155, 0.08);
  border-radius: 12rpx;
}

.mode-tag {
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: #F1849B;
  color: #fff;
  flex-shrink: 0;
  letter-spacing: 1rpx;
}

.mode-text {
  font-size: 24rpx;
  color: #666;
}

/* ============ 选择器 ============ */
.picker-value {
  background: #fafafa;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid #f0f0f0;
}

.picker-value.small {
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  flex: 1;
  margin-left: 16rpx;
}

.picker-value.placeholder {
  color: #c0c0c0;
}

.picker-arrow {
  font-size: 18rpx;
  color: #F1849B;
}

/* ============ 类别 tab + 胶囊宫格 ============ */
.cat-tabs {
  display: flex;
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
  border-radius: 14rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
}

.cat-tab {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #888;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.cat-tab.active {
  background: #F1849B;
  color: #fff;
  font-weight: 600;
}

.cat-tab-hover {
  opacity: 0.8;
}

.cat-chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.cat-chip {
  padding: 14rpx 26rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
  transition: all 0.2s;
}

.cat-chip.active {
  background: rgba(241, 132, 155, 0.1);
  color: #F1849B;
  border-color: rgba(241, 132, 155, 0.5);
  font-weight: 600;
}

/* ============ 标签多选 ============ */
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag-option {
  padding: 14rpx 26rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
  transition: all 0.2s;
}

.tag-option.active {
  background: rgba(241, 132, 155, 0.1);
  color: #F1849B;
  border-color: rgba(241, 132, 155, 0.5);
  font-weight: 600;
}

.tag-option-hover {
  opacity: 0.7;
  transform: scale(0.96);
}

/* ============ 价格列表 ============ */
.price-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.price-row {
  display: flex;
  align-items: center;
}

.price-label {
  font-size: 26rpx;
  color: #F1849B;
  flex-shrink: 0;
  width: 80rpx;
  font-weight: 600;
}

/* ============ 提交区域 ============ */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #fff 30%);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  font-size: 32rpx;
  background: #F1849B !important;
  border-radius: 48rpx;
  color: #fff !important;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none !important;
  box-shadow: 0 12rpx 32rpx rgba(241, 132, 155, 0.4);
}

.submit-btn::after {
  border: none !important;
}

.submit-btn[disabled] {
  opacity: 0.4;
  box-shadow: none;
}

.submit-btn:active {
  transform: scale(0.98);
}
