/* pages/consult-publish/consult-publish.wxss */
.page-publish {
  min-height: 100vh;
  background: #f5f5f7;
  padding-bottom: 160rpx;
}

.scene-header {
  padding: 36rpx 32rpx 24rpx;
}

.scene-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #1a1a2e;
  margin-bottom: 8rpx;
}

.scene-desc {
  font-size: 26rpx;
  color: #999;
}

.section {
  margin: 0 32rpx 28rpx;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
}

.label-required {
  font-size: 28rpx;
  color: #e74c3c;
}

.label-hint {
  font-size: 22rpx;
  color: #999;
}

/* 图片上传 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 6rpx 0;
  background: rgba(26, 26, 46, 0.7);
  color: #fff;
  font-size: 22rpx;
  text-align: center;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #ccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #fff;
}

.image-add:active {
  border-color: #e8a87c;
  background: rgba(232, 168, 124, 0.05);
}

.add-icon {
  font-size: 48rpx;
  color: #ccc;
}

.add-text {
  font-size: 22rpx;
  color: #999;
}

/* 模式提示 */
.mode-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: rgba(79, 172, 254, 0.08);
  border-radius: 12rpx;
}

.mode-tag {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: rgba(79, 172, 254, 0.15);
  color: #4facfe;
  flex-shrink: 0;
}

.mode-text {
  font-size: 24rpx;
  color: #666;
}

/* 选择器 */
.picker-value {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #1a1a2e;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-value.small {
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  flex: 1;
  margin-left: 16rpx;
}

.picker-value.placeholder {
  color: #ccc;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999;
}

/* 标签多选 */
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-option {
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  border: 2rpx solid #eee;
  transition: all 0.2s;
}

.tag-option.active {
  background: rgba(232, 168, 124, 0.12);
  color: #e8a87c;
  border-color: #e8a87c;
  font-weight: 600;
}

.tag-option-hover {
  opacity: 0.7;
  transform: scale(0.96);
}

/* 价格列表 */
.price-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.price-row {
  display: flex;
  align-items: center;
}

.price-label {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
  width: 80rpx;
}

/* 提交区域 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: #fff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  font-size: 32rpx;
}

.submit-btn[disabled] {
  opacity: 0.6;
}
