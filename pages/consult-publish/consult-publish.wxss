/* pages/consult-publish/consult-publish.wxss */
/* 全屏一屏一步式 · 樱粉 #F1849B */

page {
  height: 100%;
  background: linear-gradient(180deg, #fff 0%, #fff5f7 100%);
}

.page-publish {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  color: #1a1a1a;
}

/* ============ 顶部进度 ============ */
.topbar {
  flex-shrink: 0;
  padding: calc(20rpx + env(safe-area-inset-top)) 32rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.dots {
  display: flex;
  gap: 8rpx;
  flex: 1;
}

.dot {
  height: 6rpx;
  flex: 1;
  background: #f0e0e4;
  border-radius: 3rpx;
  transition: background 240ms ease;
}

.dot-active { background: #F1849B; }
.dot-now { background: linear-gradient(90deg, #F1849B, #ff9eb0); box-shadow: 0 2rpx 8rpx rgba(241,132,155,0.4); }

.step-counter {
  font-size: 22rpx;
  color: #b8a0a8;
  font-family: "SF Mono", monospace;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

/* ============ Swiper 主体 ============ */
.slider {
  flex: 1;
  width: 100%;
  height: auto;
}

.slide {
  height: 100%;
  padding: 60rpx 48rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.slide-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1a1a1a;
  letter-spacing: 2rpx;
  line-height: 1.3;
  margin-bottom: 14rpx;
}

.req {
  font-size: 36rpx;
  color: #F1849B;
  margin-left: 8rpx;
}

.slide-sub {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 56rpx;
  letter-spacing: 0.5rpx;
  line-height: 1.5;
}

.ai-badge {
  display: inline-block;
  font-size: 18rpx;
  color: #F1849B;
  background: rgba(241, 132, 155, 0.1);
  border: 1rpx solid rgba(241, 132, 155, 0.4);
  padding: 0 10rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  vertical-align: 2rpx;
}

/* ============ 上传 slide ============ */
.slide-upload {
  align-items: center;
  text-align: center;
}

.upload-stage {
  width: 100%;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  margin: 40rpx 0;
}

.upload-empty {
  position: relative;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(241,132,155,0.08), rgba(241,132,155,0.02));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed rgba(241,132,155,0.5);
}

.upload-empty:active { transform: scale(0.97); }

.upload-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #F1849B;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(241,132,155,0.45);
}

.upload-plus {
  font-size: 96rpx;
  color: #fff;
  font-weight: 200;
  line-height: 1;
}

.upload-empty-text {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: #F1849B;
  letter-spacing: 2rpx;
  font-weight: 600;
}

.upload-pulse {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(241,132,155,0.5);
  animation: upPulse 2.2s ease-out infinite;
  pointer-events: none;
}
.upload-pulse-2 { animation-delay: 1.1s; }

@keyframes upPulse {
  0% { transform: scale(0.95); opacity: 0.8; }
  100% { transform: scale(1.18); opacity: 0; }
}

.upload-thumbs {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  justify-content: center;
}

.image-item {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 8rpx 24rpx rgba(241,132,155,0.12);
}

.image-thumb { width: 100%; height: 100%; }

.image-label {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 8rpx 0;
  background: #F1849B;
  color: #fff;
  font-size: 22rpx;
  text-align: center;
  letter-spacing: 2rpx;
  font-weight: 700;
}

.image-remove {
  position: absolute;
  top: 8rpx; right: 8rpx;
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 30rpx;
  line-height: 40rpx;
  text-align: center;
}

.image-add {
  width: 220rpx;
  height: 220rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(241,132,155,0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: rgba(241,132,155,0.03);
}

.add-icon { font-size: 56rpx; color: #F1849B; font-weight: 200; line-height: 1; }
.add-text { font-size: 22rpx; color: #888; letter-spacing: 1rpx; }

/* ============ 模式徽章 ============ */
.mode-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 32rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.mode-pill-buy {
  background: rgba(241,132,155,0.08);
  color: #F1849B;
}

.mode-pill-compare {
  background: linear-gradient(90deg, #F1849B, #ff9eb0);
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(241,132,155,0.35);
}

.pill-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

/* ============ Chip ============ */
.chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 18rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #555;
  background: #fff;
  border: 1rpx solid #ececec;
  letter-spacing: 1rpx;
  transition: all 180ms ease;
}

.chip:active { transform: scale(0.95); }

.chip-active {
  background: rgba(241,132,155,0.1);
  color: #F1849B;
  border-color: #F1849B;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(241,132,155,0.2);
}

.chip-ai {
  background: linear-gradient(135deg, rgba(241,132,155,0.18), rgba(241,132,155,0.08));
  border-color: #F1849B;
  position: relative;
}

.chip-ai::after {
  content: '✨';
  position: absolute;
  top: -10rpx;
  right: -4rpx;
  font-size: 22rpx;
}

.chip-group-lg .chip {
  padding: 26rpx 40rpx;
  font-size: 30rpx;
}

.chip-other {
  border-style: dashed;
  color: #888;
}

.other-input {
  margin-top: 20rpx;
  background: #fff;
  border: 1rpx solid #ececec;
  border-radius: 12rpx;
  height: 84rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1a1a1a;
}

.other-input-ph { color: #c0c0c0; font-size: 28rpx; }

/* ============ 补充 slide ============ */
.extra-block { margin-bottom: 40rpx; }

.extra-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #555;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.extra-hint {
  font-size: 20rpx;
  color: #b8b8b8;
  font-weight: 400;
  margin-left: 8rpx;
}

/* ============ 价格行 ============ */
.price-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.price-row { display: flex; align-items: center; }

.price-label {
  font-size: 26rpx;
  color: #F1849B;
  flex-shrink: 0;
  width: 60rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.picker-value {
  background: #fff;
  border: 1rpx solid #ececec;
  border-radius: 10rpx;
  height: 72rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #1a1a1a;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1;
}

.picker-value.placeholder { color: #c0c0c0; }
.picker-arrow { font-size: 18rpx; color: #F1849B; }

/* ============ 底部导航 ============ */
.footer {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(8px);
  border-top: 1rpx solid #f5e6ea;
}

.summary-bar {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  margin-bottom: 12rpx;
  background: rgba(241,132,155,0.06);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #888;
}

.summary-icon { color: #F1849B; font-weight: 700; flex-shrink: 0; }
.summary-text { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.footer-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-back, .btn-next, .btn-submit {
  height: 92rpx;
  line-height: 92rpx;
  padding: 0;
  font-size: 30rpx;
  border-radius: 48rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none !important;
}

.btn-back::after, .btn-next::after, .btn-submit::after { border: none !important; }

.btn-back {
  width: 200rpx;
  background: #fff !important;
  color: #888 !important;
  border: 1rpx solid #e8e8e8 !important;
  flex-shrink: 0;
  transition: opacity 200ms ease;
}

.btn-back-hidden {
  opacity: 0;
  pointer-events: none;
  width: 0;
  margin-right: -16rpx;
}

.btn-next, .btn-submit {
  flex: 1;
  background: #F1849B !important;
  color: #fff !important;
  box-shadow: 0 12rpx 32rpx rgba(241,132,155,0.4);
}

.btn-submit[disabled] {
  background: #e5e5e5 !important;
  opacity: 0.7;
  box-shadow: none;
}

.btn-next:active, .btn-submit:active, .btn-back:active { transform: scale(0.98); }
