/* pages/consult-publish/consult-publish.wxss */
/* 风格与首页一致：暖棕色系 #8B7355 / #C8A97E / #FAFAF5 */

.page-publish {
  min-height: 100vh;
  background: #FAFAF5;
  padding-bottom: 160rpx;
}

/* 场景标题区 */
.scene-header {
  padding: 36rpx 32rpx 24rpx;
}

.scene-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.scene-desc {
  font-size: 24rpx;
  color: #8B7355;
  letter-spacing: 1rpx;
}

/* 表单区块 */
.section {
  margin: 0 32rpx 28rpx;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.label-required {
  font-size: 28rpx;
  color: #e74c3c;
}

.ai-badge {
  font-size: 20rpx;
  color: #8B7355;
  background: rgba(200, 169, 126, 0.15);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
  font-weight: 500;
}

.label-hint {
  font-size: 22rpx;
  color: #999;
}

/* 图片上传 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 6rpx 0;
  background: rgba(139, 115, 85, 0.75);
  color: #fff;
  font-size: 22rpx;
  text-align: center;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.4);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  border: 2rpx dashed #C8A97E;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #fff;
}

.image-add:active {
  border-color: #8B7355;
  background: rgba(200, 169, 126, 0.05);
}

.add-icon {
  font-size: 48rpx;
  color: #C8A97E;
}

.add-text {
  font-size: 22rpx;
  color: #8B7355;
}

/* 模式提示 */
.mode-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: rgba(200, 169, 126, 0.08);
  border-radius: 12rpx;
  border: 1rpx solid #F0EBE5;
}

.mode-tag {
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
  background: rgba(200, 169, 126, 0.18);
  color: #8B7355;
  flex-shrink: 0;
}

.mode-text {
  font-size: 24rpx;
  color: #8B7355;
}

/* 选择器 */
.picker-value {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid #F0EBE5;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
}

.picker-value.small {
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  flex: 1;
  margin-left: 16rpx;
}

.picker-value.placeholder {
  color: #bbb;
}

.picker-arrow {
  font-size: 20rpx;
  color: #C8A97E;
}

/* 标签多选 */
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-option {
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  background: #fff;
  border: 2rpx solid #F0EBE5;
  transition: all 0.2s;
}

.tag-option.active {
  background: rgba(200, 169, 126, 0.15);
  color: #8B7355;
  border-color: #C8A97E;
  font-weight: 600;
}

.tag-option-hover {
  opacity: 0.7;
  transform: scale(0.96);
}

/* 价格列表 */
.price-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.price-row {
  display: flex;
  align-items: center;
}

.price-label {
  font-size: 26rpx;
  color: #8B7355;
  flex-shrink: 0;
  width: 80rpx;
  font-weight: 500;
}

/* 提交区域 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: #FAFAF5;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  font-size: 32rpx;
  background: linear-gradient(135deg, #C8A97E, #B8966E);
  border-radius: 44rpx;
  color: #fff;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.submit-btn[disabled] {
  opacity: 0.6;
}
