/* pages/consult-publish/consult-publish.wxss */
/* 全屏一屏一步式 · 金色天蓝混合风（与首页/我的页对齐） */

page {
  height: 100%;
  background: linear-gradient(180deg, #E8F4FC 0%, #EFF9FF 35%, #FFFFFF 70%);
}

.page-publish {
  position: relative;
  height: 100vh;
  padding-top: calc(env(safe-area-inset-top) + 208rpx);
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  color: #1F1A17;
}

/* 顶部金色细线 */
.page-publish::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, #D4B883 50%, transparent 100%);
  z-index: 50;
  pointer-events: none;
}

/* ============ 顶部进度（与返回按钮同高） ============ */
.topbar {
  flex-shrink: 0;
  height: 64rpx;
  margin-bottom: 24rpx;
  padding: 0 32rpx 0 116rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

/* 自定义返回按钮（沉浸式自定义导航） */
.nav-back {
  position: fixed;
  top: calc(env(safe-area-inset-top) + 8rpx);
  left: 16rpx;
  width: 76rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(184, 153, 104, 0.35);
  box-shadow: 0 4rpx 12rpx rgba(184, 153, 104, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  backdrop-filter: blur(10rpx);
}
.nav-back-hover {
  background: rgba(255, 255, 255, 0.95);
  transform: scale(0.94);
}
.nav-back-icon {
  font-size: 44rpx;
  font-weight: 500;
  color: #8C6E3A;
  line-height: 1;
}

.dots {
  display: flex;
  gap: 8rpx;
  flex: 1;
}

.dot {
  height: 6rpx;
  flex: 1;
  background: #E6EFF5;
  border-radius: 3rpx;
  transition: background 240ms ease;
}

.dot-active { background: #D4B883; }
.dot-now { background: linear-gradient(90deg, #D4B883, #B89968); box-shadow: 0 2rpx 8rpx rgba(184,153,104,0.45); }

.step-counter {
  font-size: 22rpx;
  color: #8C7340;
  font-family: "SF Mono", monospace;
  letter-spacing: 1rpx;
  flex-shrink: 0;
}

/* ============ Swiper 主体 ============ */
.slider {
  flex: 1;
  width: 100%;
  height: auto;
}

.slide {
  height: 100%;
  padding: 60rpx 48rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  overflow-y: auto;
}

.slide-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1F1A17;
  letter-spacing: 2rpx;
  line-height: 1.3;
  margin-bottom: 14rpx;
}

.req {
  font-size: 36rpx;
  color: #B89968;
  margin-left: 8rpx;
}

.slide-sub {
  font-size: 24rpx;
  color: #8C7340;
  margin-bottom: 56rpx;
  letter-spacing: 0.5rpx;
  line-height: 1.5;
}

.ai-badge {
  display: inline-block;
  font-size: 18rpx;
  color: #8C6E3A;
  background: rgba(184, 153, 104, 0.12);
  border: 1rpx solid rgba(184, 153, 104, 0.4);
  padding: 0 10rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  vertical-align: 2rpx;
}

/* ============ 上传 slide ============ */
.slide-upload {
  align-items: center;
  text-align: center;
}

.upload-stage {
  width: 100%;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  margin: 40rpx 0;
  transform: translateY(-50rpx);
}

.upload-empty {
  position: relative;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(184,153,104,0.10), rgba(159,207,236,0.12));
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed rgba(184,153,104,0.55);
}

.upload-empty:active { transform: scale(0.97); }

.upload-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F5E6B8 0%, #D4B883 50%, #B89968 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(184,153,104,0.45);
}

.upload-plus {
  font-size: 96rpx;
  color: #1F1A17;
  font-weight: 200;
  line-height: 1;
}

.upload-empty-text {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: #8C6E3A;
  letter-spacing: 2rpx;
  font-weight: 600;
}

.upload-pulse {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(184,153,104,0.55);
  animation: upPulse 2.2s ease-out infinite;
  pointer-events: none;
}
.upload-pulse-2 { animation-delay: 1.1s; }

@keyframes upPulse {
  0% { transform: scale(0.95); opacity: 0.8; }
  100% { transform: scale(1.18); opacity: 0; }
}

.upload-thumbs {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  justify-content: center;
}

.image-item {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fafafa;
  border: 1rpx solid #f0e8d8;
  box-shadow: 0 8rpx 24rpx rgba(184,153,104,0.16);
}

.image-thumb { width: 100%; height: 100%; }

.image-label {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 8rpx 0;
  background: linear-gradient(135deg, #D4B883 0%, #B89968 100%);
  color: #fff;
  font-size: 22rpx;
  text-align: center;
  letter-spacing: 2rpx;
  font-weight: 700;
}

.image-remove {
  position: absolute;
  top: 8rpx; right: 8rpx;
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 30rpx;
  line-height: 40rpx;
  text-align: center;
}

.image-add {
  width: 220rpx;
  height: 220rpx;
  border-radius: 16rpx;
  border: 2rpx dashed rgba(184,153,104,0.55);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: rgba(184,153,104,0.04);
}

.add-icon { font-size: 56rpx; color: #B89968; font-weight: 200; line-height: 1; }
.add-text { font-size: 22rpx; color: #8C7340; letter-spacing: 1rpx; }

/* ============ 模式徽章 ============ */
.mode-pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 32rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.mode-pill-buy {
  background: rgba(184,153,104,0.1);
  color: #8C6E3A;
}

.mode-pill-compare {
  background: linear-gradient(90deg, #D4B883, #B89968);
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(184,153,104,0.4);
}

.pill-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
}

/* ============ Chip ============ */
.chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 18rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #555;
  background: #fff;
  border: 1rpx solid #E6EFF5;
  letter-spacing: 1rpx;
  transition: all 180ms ease;
}

.chip:active { transform: scale(0.95); }

.chip-active {
  background: rgba(184,153,104,0.12);
  color: #8C6E3A;
  border-color: #B89968;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(184,153,104,0.25);
}

.chip-ai {
  background: linear-gradient(135deg, rgba(184,153,104,0.2), rgba(159,207,236,0.15));
  border-color: #B89968;
  position: relative;
}

.chip-ai::after {
  content: '✨';
  position: absolute;
  top: -10rpx;
  right: -4rpx;
  font-size: 22rpx;
}

.chip-group-lg .chip {
  padding: 26rpx 40rpx;
  font-size: 30rpx;
}

.chip-other {
  border-style: dashed;
  color: #888;
}

.other-input {
  margin-top: 20rpx;
  background: #fff;
  border: 1rpx solid #E6EFF5;
  border-radius: 12rpx;
  height: 84rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: #1F1A17;
}

.other-input-ph { color: #c0c0c0; font-size: 28rpx; }

/* ============ 补充 slide ============ */
.extra-block { margin-bottom: 40rpx; }

.extra-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #555;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.extra-hint {
  font-size: 20rpx;
  color: #b8b8b8;
  font-weight: 400;
  margin-left: 8rpx;
}

/* ============ 价格行 ============ */
.price-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.price-row { display: flex; align-items: center; }

.price-label {
  font-size: 26rpx;
  color: #8C6E3A;
  flex-shrink: 0;
  width: 60rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.picker-value {
  background: #fff;
  border: 1rpx solid #E6EFF5;
  border-radius: 10rpx;
  height: 72rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #1F1A17;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 1;
}

.picker-value.placeholder { color: #c0c0c0; }
.picker-arrow { font-size: 18rpx; color: #B89968; }

/* ============ 底部导航 ============ */
.footer {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(8px);
  border-top: 1rpx solid #EFE8D6;
}

.summary-bar {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 14rpx;
  margin-bottom: 12rpx;
  background: rgba(184,153,104,0.08);
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #8C7340;
}

.summary-icon { color: #B89968; font-weight: 700; flex-shrink: 0; }
.summary-text { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.footer-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-back, .btn-next, .btn-submit {
  height: 92rpx;
  line-height: 92rpx;
  padding: 0;
  font-size: 30rpx;
  border-radius: 48rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none !important;
}

.btn-back::after, .btn-next::after, .btn-submit::after { border: none !important; }

.btn-back {
  width: 200rpx;
  background: #fff !important;
  color: #888 !important;
  border: 1rpx solid #e8e8e8 !important;
  flex-shrink: 0;
  transition: opacity 200ms ease;
}

.btn-back-hidden {
  opacity: 0;
  pointer-events: none;
  width: 0;
  margin-right: -16rpx;
}

.btn-next, .btn-submit {
  flex: 1;
  background: linear-gradient(135deg, #F5E6B8 0%, #D4B883 50%, #B89968 100%) !important;
  color: #1F1A17 !important;
  box-shadow: 0 12rpx 32rpx rgba(184,153,104,0.4);
}

.btn-submit[disabled] {
  background: #e5e5e5 !important;
  color: #aaa !important;
  opacity: 0.7;
  box-shadow: none;
}

.btn-next:active, .btn-submit:active, .btn-back:active { transform: scale(0.98); }
