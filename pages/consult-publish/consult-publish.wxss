/* pages/consult-publish/consult-publish.wxss */
/* 高级金色科技风：白底 + 古铜金 #B8956A 主色，几何方形 + 极简装饰 */

.page-publish {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  color: #1a1a1a;
}

/* ============ 顶部 ============ */
.scene-header {
  padding: 36rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #f2f2f2;
  margin-bottom: 28rpx;
}

.scene-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #0a0a0a;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.scene-title::before {
  content: '▍';
  color: #B8956A;
  margin-right: 12rpx;
  font-weight: 400;
}

.scene-desc {
  font-size: 22rpx;
  color: #999;
  letter-spacing: 1rpx;
  font-family: -apple-system, "SF Mono", monospace;
}

/* ============ 表单区块 ============ */
.section {
  margin: 0 32rpx 32rpx;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.label-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 2rpx;
}

.label-required {
  font-size: 26rpx;
  color: #B8956A;
}

.ai-badge {
  font-size: 18rpx;
  color: #B8956A;
  background: rgba(184, 149, 106, 0.08);
  border: 1rpx solid rgba(184, 149, 106, 0.4);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-left: 10rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  font-family: "SF Mono", monospace;
}

.label-hint {
  font-size: 20rpx;
  color: #b8b8b8;
  font-family: "SF Mono", monospace;
}

/* ============ 图片上传 ============ */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 6rpx 0;
  background: linear-gradient(135deg, #C9A86A 0%, #B8956A 100%);
  color: #fff;
  font-size: 22rpx;
  text-align: center;
  letter-spacing: 2rpx;
  font-weight: 600;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 4rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  border: 1rpx dashed rgba(184, 149, 106, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: #fff;
}

.image-add:active {
  border-color: #B8956A;
  background: rgba(184, 149, 106, 0.04);
}

.add-icon {
  font-size: 44rpx;
  color: #B8956A;
  font-weight: 200;
}

.add-text {
  font-size: 20rpx;
  color: #888;
  letter-spacing: 1rpx;
}

/* ============ 模式提示 ============ */
.mode-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 12rpx 16rpx;
  background: rgba(184, 149, 106, 0.05);
  border-left: 3rpx solid #B8956A;
  border-radius: 4rpx;
}

.mode-tag {
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 700;
  background: #B8956A;
  color: #fff;
  flex-shrink: 0;
  letter-spacing: 2rpx;
}

.mode-text {
  font-size: 22rpx;
  color: #666;
}

/* ============ 选择器 / 输入 ============ */
.picker-value,
.category-input {
  background: #fafafa;
  border: 1rpx solid #ececec;
  border-radius: 8rpx;
  height: 84rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category-input {
  width: 100%;
  display: block;
  line-height: 84rpx;
  padding-right: 24rpx;
}

.category-input-ph {
  color: #c0c0c0;
  font-size: 26rpx;
}

.picker-value.small {
  height: 64rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  flex: 1;
  margin-left: 16rpx;
}

.picker-value.placeholder {
  color: #c0c0c0;
}

.picker-arrow {
  font-size: 16rpx;
  color: #B8956A;
}

/* ============ 标签多选 ============ */
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-option {
  padding: 12rpx 22rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666;
  background: #fafafa;
  border: 1rpx solid #ececec;
  letter-spacing: 1rpx;
}

.tag-option.active {
  background: rgba(184, 149, 106, 0.06);
  color: #8C6E48;
  border-color: #B8956A;
  font-weight: 600;
}

.tag-option-hover {
  opacity: 0.7;
}

/* ============ 价格列表 ============ */
.price-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.price-row {
  display: flex;
  align-items: center;
}

.price-label {
  font-size: 24rpx;
  color: #B8956A;
  flex-shrink: 0;
  width: 80rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  font-family: "SF Mono", monospace;
}

/* ============ 提交区域 ============ */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f2f2f2;
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0;
  font-size: 30rpx;
  background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%) !important;
  border-radius: 8rpx;
  color: #E5C98E !important;
  font-weight: 700;
  letter-spacing: 8rpx;
  border: 1rpx solid #B8956A !important;
  box-shadow: 0 8rpx 24rpx rgba(184, 149, 106, 0.3), inset 0 1rpx 0 rgba(229, 201, 142, 0.2);
}

.submit-btn::after {
  border: none !important;
}

.submit-btn[disabled] {
  background: #999 !important;
  color: #fff !important;
  border-color: #999 !important;
  opacity: 0.6;
  box-shadow: none;
}

.submit-btn:active {
  transform: scale(0.98);
}
