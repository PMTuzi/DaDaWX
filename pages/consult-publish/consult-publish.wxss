/* pages/consult-publish/consult-publish.wxss */
/* 与「形象诊断」一致：白底 + 樱粉 #F1849B 主色，极简卡片风 */

.page-publish {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  color: #1a1a1a;
}

/* ============ 顶部 ============ */
.scene-header {
  padding: 36rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #f2f2f2;
  margin-bottom: 28rpx;
}

.scene-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #0a0a0a;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.scene-title::before {
  content: '▍';
  color: #F1849B;
  margin-right: 12rpx;
  font-weight: 400;
}

.scene-desc {
  font-size: 22rpx;
  color: #999;
  letter-spacing: 1rpx;
  font-family: -apple-system, "SF Mono", monospace;
}

/* ============ 表单区块 ============ */
.section {
  margin: 0 32rpx 32rpx;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.label-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 2rpx;
}

.label-required {
  font-size: 26rpx;
  color: #F1849B;
}

.ai-badge {
  font-size: 18rpx;
  color: #F1849B;
  background: rgba(241, 132, 155, 0.08);
  border: 1rpx solid rgba(241, 132, 155, 0.4);
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-left: 10rpx;
  font-weight: 500;
  letter-spacing: 1rpx;
  font-family: "SF Mono", monospace;
}

.label-hint {
  font-size: 20rpx;
  color: #b8b8b8;
  font-family: "SF Mono", monospace;
}

/* ============ 图片上传 ============ */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
}

.image-thumb {
  width: 100%;
  height: 100%;
}

.image-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 6rpx 0;
  background: #F1849B;
  color: #fff;
  font-size: 22rpx;
  text-align: center;
  letter-spacing: 2rpx;
  font-weight: 600;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 4rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-add {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  border: 1rpx dashed rgba(241, 132, 155, 0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: #fff;
  overflow: visible;
  animation: addBreath 2.4s ease-in-out infinite;
}

@keyframes addBreath {
  0%, 100% {
    box-shadow: 0 0 0 0 rgba(241, 132, 155, 0.35);
    border-color: rgba(241, 132, 155, 0.5);
  }
  50% {
    box-shadow: 0 0 0 8rpx rgba(241, 132, 155, 0);
    border-color: #F1849B;
  }
}

.image-add:active {
  border-color: #F1849B;
  background: rgba(241, 132, 155, 0.04);
}

.add-icon {
  font-size: 44rpx;
  color: #F1849B;
  font-weight: 200;
}

/* 点击引导：脉冲光晕 */
.add-pulse {
  position: absolute;
  inset: 0;
  border-radius: 8rpx;
  border: 2rpx solid rgba(241, 132, 155, 0.6);
  animation: addPulse 2s ease-out infinite;
  pointer-events: none;
}

.add-pulse-2 {
  animation-delay: 1s;
}

@keyframes addPulse {
  0% { transform: scale(0.92); opacity: 0.9; }
  100% { transform: scale(1.18); opacity: 0; }
}

/* 小手点击引导（SVG，与诊断页一致） */
.add-finger {
  position: absolute;
  right: -14rpx;
  bottom: -14rpx;
  width: 64rpx;
  height: 64rpx;
  z-index: 2;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><g fill='none' stroke='%23F1849B' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'><path d='M26 38V18a4 4 0 1 1 8 0v14'/><path d='M34 28a4 4 0 0 1 8 0v6'/><path d='M42 30a4 4 0 0 1 8 0v10c0 8-5 14-13 14h-6c-5 0-8-2-10-6l-6-12a4 4 0 0 1 7-4l4 6'/></g><circle cx='32' cy='10' r='3' fill='%23F1849B'/><path d='M22 8l-4-3M42 8l4-3M32 4V0' stroke='%23F1849B' stroke-width='2' stroke-linecap='round'/></svg>");
  background-repeat: no-repeat;
  background-size: contain;
  background-position: center;
  filter: drop-shadow(0 4rpx 8rpx rgba(241, 132, 155, 0.4));
  animation: addFingerTap 1.4s ease-in-out infinite;
  transform-origin: 70% 30%;
  pointer-events: none;
}

@keyframes addFingerTap {
  0%, 100% {
    transform: translate(0, 0) rotate(-12deg) scale(1);
  }
  40% {
    transform: translate(-10rpx, -10rpx) rotate(-18deg) scale(1.08);
  }
  60% {
    transform: translate(0, 0) rotate(-12deg) scale(0.92);
  }
}

.add-text {
  font-size: 20rpx;
  color: #888;
  letter-spacing: 1rpx;
}

/* ============ 模式提示 ============ */
.mode-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 12rpx 16rpx;
  background: rgba(241, 132, 155, 0.05);
  border-left: 3rpx solid #F1849B;
  border-radius: 4rpx;
}

.mode-tag {
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  font-size: 20rpx;
  font-weight: 700;
  background: #F1849B;
  color: #fff;
  flex-shrink: 0;
  letter-spacing: 2rpx;
}

.mode-text {
  font-size: 22rpx;
  color: #666;
}

/* ============ 选择器 / 输入 ============ */
.picker-value,
.category-input {
  background: #fafafa;
  border: 1rpx solid #ececec;
  border-radius: 8rpx;
  height: 84rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category-input {
  width: 100%;
  display: block;
  line-height: 84rpx;
  padding-right: 24rpx;
}

.category-input-ph {
  color: #c0c0c0;
  font-size: 26rpx;
}

.picker-value.small {
  height: 64rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
  flex: 1;
  margin-left: 16rpx;
}

.picker-value.placeholder {
  color: #c0c0c0;
}

.picker-arrow {
  font-size: 16rpx;
  color: #F1849B;
}

/* ============ 标签多选 ============ */
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag-option {
  padding: 12rpx 22rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666;
  background: #fafafa;
  border: 1rpx solid #ececec;
  letter-spacing: 1rpx;
}

.tag-option.active {
  background: rgba(241, 132, 155, 0.08);
  color: #F1849B;
  border-color: #F1849B;
  font-weight: 600;
}

.tag-option-hover {
  opacity: 0.7;
}

/* ============ 价格列表 ============ */
.price-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.price-row {
  display: flex;
  align-items: center;
}

.price-label {
  font-size: 24rpx;
  color: #F1849B;
  flex-shrink: 0;
  width: 80rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  font-family: "SF Mono", monospace;
}

/* ============ 提交区域 ============ */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f2f2f2;
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  padding: 0;
  font-size: 32rpx;
  background: #F1849B !important;
  border-radius: 48rpx;
  color: #fff !important;
  font-weight: 700;
  letter-spacing: 6rpx;
  border: none !important;
  box-shadow: 0 12rpx 32rpx rgba(241, 132, 155, 0.4);
}

.submit-btn::after {
  border: none !important;
}

.submit-btn[disabled] {
  background: #e5e5e5 !important;
  color: #fff !important;
  opacity: 0.6;
  box-shadow: none;
}

.submit-btn:active {
  transform: scale(0.98);
}
