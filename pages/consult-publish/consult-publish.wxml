<!--pages/consult-publish/consult-publish.wxml-->
<view class="page-publish">

  <!-- 顶部进度 -->
  <view class="topbar">
    <view class="dots">
      <view class="dot {{step === 0 ? 'dot-now' : 'dot-active'}}"></view>
      <view class="dot {{step === 1 ? 'dot-now' : ''}}"></view>
    </view>
    <view class="step-counter">{{step + 1}} / 2</view>
  </view>

  <!-- ====== 第一步：上传图片 ====== -->
  <view class="step-body" wx:if="{{step === 0}}">
    <view class="step-title">上传照片</view>
    <view class="step-sub">1 张评估单品 · 2-4 张对比 PK</view>

    <view class="upload-stage">
      <!-- 空态 -->
      <view wx:if="{{images.length === 0}}" class="upload-empty" bindtap="onAddImage">
        <view class="upload-circle">
          <text class="upload-plus">+</text>
        </view>
        <view class="upload-empty-text">点击上传 / 拍照</view>
        <view class="upload-pulse"></view>
        <view class="upload-pulse upload-pulse-2"></view>
      </view>

      <!-- 已有图片 -->
      <view wx:else class="upload-thumbs">
        <view class="image-item" wx:for="{{images}}" wx:key="path">
          <image class="image-thumb" src="{{item.thumb}}" mode="aspectFill"
            data-index="{{index}}" bindtap="onPreviewImage" />
          <view class="image-label" wx:if="{{images.length > 1}}">{{['A','B','C','D'][index]}}</view>
          <view class="image-remove" data-index="{{index}}" catchtap="onRemoveImage">×</view>
        </view>
        <view class="image-add" wx:if="{{images.length < 4}}" bindtap="onAddImage">
          <text class="add-icon">+</text>
          <text class="add-text">加一张</text>
        </view>
      </view>
    </view>

    <!-- 模式 & AI识别结果 -->
    <view class="detect-result" wx:if="{{images.length > 0}}">
      <view class="mode-pill {{mode === 'compare' ? 'mode-pill-compare' : 'mode-pill-buy'}}">
        <text class="pill-dot"></text>
        {{mode === 'compare' ? images.length + ' 件对比 PK' : '单品评估模式'}}
      </view>

      <!-- 单品：AI识别品类 -->
      <view class="category-detect" wx:if="{{mode === 'buy'}}">
        <view class="detect-label" wx:if="{{categoryDetecting}}">
          <text class="detect-spin">◌</text> AI 正在识别品类…
        </view>
        <view class="detect-label detect-success" wx:elif="{{category}}">
          <text class="ai-badge">AI</text>
          识别为「<text class="detect-highlight">{{category}}</text>」
          <text class="detect-change" bindtap="onShowCategoryPicker">修改</text>
        </view>
        <view class="detect-label detect-change" wx:else bindtap="onShowCategoryPicker">未能自动识别，请手动选择</view>
      </view>
    </view>
  </view>

  <!-- ====== 第二步：选择场景 ====== -->
  <view class="step-body" wx:if="{{step === 1}}">
    <view class="step-title">穿什么场合？</view>
    <view class="step-sub">选择一个最贴近的场景</view>

    <view class="scene-grid">
      <view class="scene-item {{scene === item.value ? 'scene-active' : ''}}"
        wx:for="{{sceneOptions}}" wx:key="value"
        data-value="{{item.value}}" bindtap="onSceneTap">
        <image class="scene-icon" src="{{scene === item.value ? item.iconActive : item.icon}}" mode="aspectFit" />
        <text class="scene-name">{{item.label}}</text>
      </view>
    </view>

    <view class="scene-tip" wx:if="{{mode === 'compare'}}">
      <text class="scene-tip-icon">💡</text>
      对比模式下，AI 将根据「{{scene || '…'}}」场景对各款式进行评分
    </view>
  </view>

  <!-- 品类修改弹窗 -->
  <view class="modal-mask" wx:if="{{showCategoryPicker}}" bindtap="onHideCategoryPicker">
    <view class="modal-content" catchtap="onPreventBubble">
      <view class="modal-title">选择品类</view>
      <view class="modal-list">
        <view class="modal-item {{category === item ? 'modal-item-active' : ''}}"
          wx:for="{{categoryOptions}}" wx:key="*this"
          data-value="{{item}}" bindtap="onCategoryPick">
          {{item}}
        </view>
      </view>
      <view class="modal-close" bindtap="onHideCategoryPicker">关闭</view>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="footer safe-bottom">
    <view class="footer-row">
      <button class="btn-back {{step === 0 ? 'btn-back-hidden' : ''}}" bindtap="onPrev">上一步</button>

      <!-- 第一步：下一步 -->
      <button wx:if="{{step === 0}}" class="btn-next" bindtap="onNext"
        disabled="{{images.length === 0 || (mode === 'buy' && !category)}}">
        {{images.length === 0 ? '请先上传照片' : (mode === 'buy' && !category) ? 'AI识别中…' : '下一步'}}
      </button>

      <!-- 第二步：开始分析 -->
      <button wx:else class="btn-submit" bindtap="onSubmit" disabled="{{submitting || !scene}}">
        {{submitting ? '分析中…' : '开始 AI 分析'}}
      </button>
    </view>
  </view>
</view>
