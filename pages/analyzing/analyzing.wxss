/* pages/analyzing/analyzing.wxss —— 天蓝 + 金色风格（与穿搭决策 loading 对齐） */

/* ============ 页面容器 ============ */
.page-analyzing {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F4FC 0%, #F4FAFD 40%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 32rpx 80rpx;
  overflow: hidden;
  color: #1F1A17;
}

/* 极简网格 —— 浅天蓝 */
.bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(95, 158, 200, 0.07) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(95, 158, 200, 0.07) 1rpx, transparent 1rpx);
  background-size: 80rpx 80rpx;
  mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0) 50%);
  -webkit-mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0) 50%);
  pointer-events: none;
}

.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  pointer-events: none;
}

/* 右上：天蓝光晕 */
.bg-glow-1 {
  top: -160rpx;
  right: -160rpx;
  width: 480rpx;
  height: 480rpx;
  background: radial-gradient(circle, rgba(159, 207, 236, 0.55) 0%, transparent 70%);
}

/* 左下：金色光晕 */
.bg-glow-2 {
  display: block;
  bottom: -180rpx;
  left: -120rpx;
  width: 420rpx;
  height: 420rpx;
  background: radial-gradient(circle, rgba(245, 230, 184, 0.6) 0%, transparent 70%);
}

/* ============ 顶部状态徽标（金色调） ============ */
.status-tag {
  position: relative;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 20rpx;
  background: rgba(212, 184, 131, 0.18);
  border: 1rpx solid rgba(184, 153, 104, 0.4);
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #B89968;
  letter-spacing: 2rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(184, 153, 104, 0.18);
}

.tag-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #C9A45C;
  box-shadow: 0 0 12rpx rgba(201, 164, 92, 0.65);
  animation: tag-pulse 1.6s ease-in-out infinite;
}

@keyframes tag-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

/* ============ 扫描舞台 ============ */
.animation-area {
  position: relative;
  z-index: 2;
  margin-bottom: 56rpx;
}

.scan-stage {
  position: relative;
  width: 460rpx;
  height: 460rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-orbit {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

/* 外圈：天蓝虚线 */
.orbit-outer {
  width: 100%;
  height: 100%;
  border: 2rpx dashed rgba(95, 158, 200, 0.5);
  animation: spin 12s linear infinite;
}

/* 内圈：金色顶弧 */
.orbit-mid {
  width: 84%;
  height: 84%;
  border: 2rpx solid transparent;
  border-top-color: rgba(212, 184, 131, 0.9);
  animation: spin 4s linear infinite reverse;
}

.orbit-inner {
  display: none;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes pulse-ring {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(1.06); opacity: 1; }
}

/* 四角装饰：金色 */
.corner {
  position: absolute;
  width: 36rpx;
  height: 36rpx;
}

.corner::before, .corner::after {
  content: '';
  position: absolute;
  background: #C9A45C;
  border-radius: 2rpx;
  box-shadow: 0 0 8rpx rgba(201, 164, 92, 0.5);
}

.corner::before { width: 36rpx; height: 4rpx; }
.corner::after  { width: 4rpx;  height: 36rpx; }

.corner-tl { top: 0; left: 0; }
.corner-tl::before { top: 0; left: 0; }
.corner-tl::after  { top: 0; left: 0; }

.corner-tr { top: 0; right: 0; }
.corner-tr::before { top: 0; right: 0; }
.corner-tr::after  { top: 0; right: 0; }

.corner-bl { bottom: 0; left: 0; }
.corner-bl::before { bottom: 0; left: 0; }
.corner-bl::after  { bottom: 0; left: 0; }

.corner-br { bottom: 0; right: 0; }
.corner-br::before { bottom: 0; right: 0; }
.corner-br::after  { bottom: 0; right: 0; }

.photo-circle {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow:
    0 0 0 4rpx #ffffff,
    0 0 0 6rpx rgba(212, 184, 131, 0.45),
    0 8rpx 24rpx rgba(95, 158, 200, 0.3);
}

.user-photo {
  width: 100%;
  height: 100%;
  display: block;
  animation: photo-fade 0.5s ease;
}

@keyframes photo-fade {
  0% { opacity: 0.2; transform: scale(1.04); }
  100% { opacity: 1; transform: scale(1); }
}

/* 多图轮播指示器：金色胶囊 */
.preview-indicator {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #F5E6B8 0%, #D4B883 50%, #B89968 100%);
  z-index: 4;
  box-shadow: 0 2rpx 8rpx rgba(184, 153, 104, 0.45);
}

.indicator-text {
  color: #1F1A17;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.photo-fallback {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #F4FAFD 0%, #E8F4FC 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fallback-text {
  font-size: 32rpx;
  color: #B89968;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.photo-overlay {
  display: none;
}

/* 扫描线：天蓝 */
.scan-line {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 4rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(95, 158, 200, 0.85) 50%,
    transparent 100%);
  box-shadow: 0 0 16rpx rgba(95, 158, 200, 0.6);
  animation: scan-vertical 2.4s ease-in-out infinite;
  z-index: 2;
}

@keyframes scan-vertical {
  0%   { transform: translateY(0); opacity: 0; }
  10%  { opacity: 1; }
  50%  { transform: translateY(316rpx); opacity: 1; }
  90%  { opacity: 1; }
  100% { transform: translateY(0); opacity: 0; }
}

.scan-sweep {
  display: none;
}

@keyframes sweep {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* 进度胶囊：金色 */
.progress-chip {
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 8rpx 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #F5E6B8 0%, #D4B883 50%, #B89968 100%);
  box-shadow: 0 8rpx 20rpx rgba(184, 153, 104, 0.45);
  display: flex;
  align-items: center;
  gap: 8rpx;
  z-index: 3;
}

.chip-icon {
  color: rgba(31, 26, 23, 0.85);
  font-size: 22rpx;
}

.chip-percent {
  color: #1F1A17;
  font-size: 28rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

/* ============ 进度条：天蓝渐变 ============ */
.progress-bar {
  position: relative;
  z-index: 2;
  width: 80%;
  height: 6rpx;
  background: rgba(159, 207, 236, 0.25);
  border-radius: 4rpx;
  overflow: hidden;
  margin: 36rpx 0 60rpx;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #9FCFEC 0%, #5F9EC8 50%, #D4B883 100%);
  border-radius: 4rpx;
  box-shadow: 0 0 8rpx rgba(95, 158, 200, 0.55), 0 0 16rpx rgba(212, 184, 131, 0.35);
  transition: width 0.3s ease;
}

/* ============ 步骤列表：白底 + 金色描边 ============ */
.steps-area {
  position: relative;
  z-index: 2;
  width: 100%;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(212, 184, 131, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(95, 158, 200, 0.1),
              0 2rpx 6rpx rgba(184, 153, 104, 0.06);
}

.step-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  opacity: 0.4;
}

.step-item.active,
.step-item.done {
  opacity: 1;
}

.step-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.step-icon {
  font-size: 28rpx;
  color: #B89968;
}

.step-item.done .step-icon {
  color: #50b896;
}

.step-label {
  flex: 1;
  font-size: 28rpx;
  color: #1F1A17;
}

.step-status {
  font-size: 24rpx;
  color: #b8b8b8;
}

.step-status.active {
  color: #B89968;
  font-weight: 700;
}

.step-item.done .step-status {
  color: #50b896;
}

.tip-area {
  position: relative;
  z-index: 2;
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: #8C7340;
  letter-spacing: 1rpx;
}
