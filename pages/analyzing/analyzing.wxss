/* pages/analyzing/analyzing.wxss */

/* ============ 页面容器 ============ */
.page-analyzing {
  position: relative;
  min-height: 100vh;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 32rpx 80rpx;
  overflow: hidden;
  color: #1a1a1a;
}

/* 极简网格 */
.bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(241, 132, 155, 0.06) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(241, 132, 155, 0.06) 1rpx, transparent 1rpx);
  background-size: 80rpx 80rpx;
  mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0) 50%);
  -webkit-mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0) 50%);
  pointer-events: none;
}

.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  pointer-events: none;
}

.bg-glow-1 {
  top: -160rpx;
  right: -160rpx;
  width: 480rpx;
  height: 480rpx;
  background: radial-gradient(circle, rgba(241, 132, 155, 0.3) 0%, transparent 70%);
}

.bg-glow-2 {
  display: none;
}

/* ============ 顶部状态徽标 ============ */
.status-tag {
  position: relative;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 20rpx;
  background: rgba(241, 132, 155, 0.1);
  border: 1rpx solid rgba(241, 132, 155, 0.3);
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #F1849B;
  letter-spacing: 2rpx;
  margin-bottom: 32rpx;
}

.tag-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #F1849B;
  box-shadow: 0 0 12rpx rgba(241, 132, 155, 0.6);
  animation: tag-pulse 1.6s ease-in-out infinite;
}

@keyframes tag-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

/* ============ 扫描舞台 ============ */
.animation-area {
  position: relative;
  z-index: 2;
  margin-bottom: 56rpx;
}

.scan-stage {
  position: relative;
  width: 460rpx;
  height: 460rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.scan-orbit {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.orbit-outer {
  width: 100%;
  height: 100%;
  border: 2rpx dashed rgba(241, 132, 155, 0.4);
  animation: spin 12s linear infinite;
}

.orbit-mid {
  width: 84%;
  height: 84%;
  border: 2rpx solid transparent;
  border-top-color: rgba(241, 132, 155, 0.8);
  animation: spin 4s linear infinite reverse;
}

.orbit-inner {
  display: none;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes pulse-ring {
  0%, 100% { transform: scale(1); opacity: 0.7; }
  50% { transform: scale(1.06); opacity: 1; }
}

/* 四角标记 */
.corner {
  position: absolute;
  width: 36rpx;
  height: 36rpx;
}

.corner::before, .corner::after {
  content: '';
  position: absolute;
  background: #F1849B;
  border-radius: 2rpx;
}

.corner::before { width: 36rpx; height: 4rpx; }
.corner::after  { width: 4rpx;  height: 36rpx; }

.corner-tl { top: 0; left: 0; }
.corner-tl::before { top: 0; left: 0; }
.corner-tl::after  { top: 0; left: 0; }

.corner-tr { top: 0; right: 0; }
.corner-tr::before { top: 0; right: 0; }
.corner-tr::after  { top: 0; right: 0; }

.corner-bl { bottom: 0; left: 0; }
.corner-bl::before { bottom: 0; left: 0; }
.corner-bl::after  { bottom: 0; left: 0; }

.corner-br { bottom: 0; right: 0; }
.corner-br::before { bottom: 0; right: 0; }
.corner-br::after  { bottom: 0; right: 0; }

/* 用户图片圆形容器 */
.photo-circle {
  position: relative;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow:
    0 0 0 4rpx #ffffff,
    0 8rpx 24rpx rgba(241, 132, 155, 0.25);
}

.user-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-fallback {
  width: 100%;
  height: 100%;
  background: #fafafa;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fallback-text {
  font-size: 32rpx;
  color: #F1849B;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.photo-overlay {
  display: none;
}

/* 横向扫描线 */
.scan-line {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 4rpx;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(241, 132, 155, 0.8) 50%,
    transparent 100%);
  box-shadow: 0 0 16rpx rgba(241, 132, 155, 0.6);
  animation: scan-vertical 2.4s ease-in-out infinite;
  z-index: 2;
}

@keyframes scan-vertical {
  0%   { transform: translateY(0); opacity: 0; }
  10%  { opacity: 1; }
  50%  { transform: translateY(316rpx); opacity: 1; }
  90%  { opacity: 1; }
  100% { transform: translateY(0); opacity: 0; }
}

/* 旋转扇形光束（去掉，简洁化） */
.scan-sweep {
  display: none;
}

@keyframes sweep {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* 进度百分比浮标 */
.progress-chip {
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 8rpx 24rpx;
  border-radius: 28rpx;
  background: #F1849B;
  box-shadow: 0 8rpx 20rpx rgba(241, 132, 155, 0.4);
  display: flex;
  align-items: center;
  gap: 8rpx;
  z-index: 3;
}

.chip-icon {
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.chip-percent {
  color: #fff;
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

/* ============ 进度条 ============ */
.progress-bar {
  position: relative;
  z-index: 2;
  width: 80%;
  height: 6rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
  margin: 36rpx 0 60rpx;
}

.progress-inner {
  height: 100%;
  background: #F1849B;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* ============ 步骤列表 ============ */
.steps-area {
  position: relative;
  z-index: 2;
  width: 100%;
  background: #fafafa;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid #f0f0f0;
}

.step-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  opacity: 0.4;
}

.step-item.active,
.step-item.done {
  opacity: 1;
}

.step-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.step-icon {
  font-size: 28rpx;
  color: #F1849B;
}

.step-item.done .step-icon {
  color: #50b896;
}

.step-label {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
}

.step-status {
  font-size: 24rpx;
  color: #b8b8b8;
}

.step-status.active {
  color: #F1849B;
  font-weight: 600;
}

.step-item.done .step-status {
  color: #50b896;
}

.tip-area {
  position: relative;
  z-index: 2;
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: #b8b8b8;
  letter-spacing: 1rpx;
}
