<!--pages/analyzing/analyzing.wxml-->
<view class="page-analyzing">
  <!-- 背景装饰 -->
  <view class="bg-grid"></view>
  <view class="bg-glow bg-glow-1"></view>
  <view class="bg-glow bg-glow-2"></view>

  <!-- 顶部状态徽标 -->
  <view class="status-tag">
    <view class="tag-dot"></view>
    <text>AI ANALYZING · 形象诊断中</text>
  </view>

  <!-- 科技扫描动画区域 -->
  <view class="animation-area">
    <view class="scan-stage">
      <!-- 外层旋转环 -->
      <view class="scan-orbit orbit-outer"></view>
      <view class="scan-orbit orbit-mid"></view>
      <view class="scan-orbit orbit-inner"></view>

      <!-- 四角十字标记 -->
      <view class="corner corner-tl"></view>
      <view class="corner corner-tr"></view>
      <view class="corner corner-bl"></view>
      <view class="corner corner-br"></view>

      <!-- 用户图片圆形容器 -->
      <view class="photo-circle">
        <image class="user-photo" src="{{localPhoto || imageUrl}}" mode="aspectFill" wx:if="{{localPhoto || imageUrl}}" />
        <view class="photo-fallback" wx:else>
          <text class="fallback-text">扫描中</text>
        </view>
        <!-- 扫描线 -->
        <view class="scan-line"></view>
        <!-- 内部柔光罩 -->
        <view class="photo-overlay"></view>
        <!-- 扇形光束 -->
        <view class="scan-sweep"></view>
      </view>

      <!-- 进度百分比浮标 -->
      <view class="progress-chip">
        <text class="chip-icon">✦</text>
        <text class="chip-percent">{{progress}}%</text>
      </view>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-inner" style="width: {{progress}}%"></view>
  </view>

  <!-- 步骤列表 -->
  <view class="steps-area">
    <view class="step-item {{item.status}}" wx:for="{{steps}}" wx:key="label">
      <view class="step-icon-wrap">
        <view class="step-icon icon icon-checkmark" wx:if="{{item.status === 'done'}}"></view>
        <view class="step-icon icon icon-{{item.icon}}" wx:elif="{{item.status === 'active'}}"></view>
        <text class="step-icon" wx:else>○</text>
      </view>
      <text class="step-label">{{item.label}}</text>
      <text class="step-status" wx:if="{{item.status === 'done'}}">完成</text>
      <text class="step-status active" wx:elif="{{item.status === 'active'}}">分析中...</text>
    </view>
  </view>

  <!-- 提示文字 -->
  <view class="tip-area">
    <text class="tip-text">3000亿参数模型分析中，请耐心等待...</text>
  </view>
</view>
