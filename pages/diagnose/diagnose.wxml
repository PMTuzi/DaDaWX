<!--pages/diagnose/diagnose.wxml-->
<view class="page-diagnose">
  <!-- 背景装饰 -->
  <view class="bg-grid"></view>
  <view class="bg-glow bg-glow-1"></view>
  <view class="bg-glow bg-glow-2"></view>

  <!-- 顶部品牌头 -->
  <view class="hero">
    <view class="hero-tag">
      <view class="tag-dot"></view>
      <text>AI · IMAGE DIAGNOSIS</text>
    </view>
    <view class="hero-title">智能形象诊断</view>
   
  </view>

  <!-- 上传扫描卡片 -->
  <view class="scan-card {{photoUrl ? 'has-photo' : ''}}">
    <view class="scan-corner tl"></view>
    <view class="scan-corner tr"></view>
    <view class="scan-corner bl"></view>
    <view class="scan-corner br"></view>

    <block wx:if="{{photoUrl}}">
      <view class="photo-frame">
        <image class="photo-img" src="{{photoUrl}}" mode="aspectFill" />
        <view class="scan-sweep"></view>
        <view class="photo-mask"></view>
      </view>
      <view class="rechoose-btn" bindtap="onRechoose">
        <text class="rechoose-icon">↻</text>
        <text>重新选择</text>
      </view>
    </block>

    <view class="upload-empty" wx:else bindtap="onChoosePhoto">
      <view class="upload-icon-wrap">
        <view class="upload-ring"></view>
        <view class="upload-pulse"></view>
        <view class="upload-pulse upload-pulse-2"></view>
        <view class="upload-icon icon icon-camera"></view>
        <view class="tap-finger"></view>
      </view>
      <view class="upload-title">点击上传 / 拍照</view>
    </view>
  </view>

  <!-- 拍照贴士 -->
  <view class="tips-grid" wx:if="{{guideVisible}}">
    <view class="tip-chip"><view class="dot"></view><text>正对镜头</text></view>
    <view class="tip-chip"><view class="dot"></view><text>光线均匀</text></view>
    <view class="tip-chip"><view class="dot"></view><text>素颜淡妆</text></view>
    <view class="tip-chip"><view class="dot"></view><text>不遮轮廓</text></view>
  </view>

  <!-- 行动区 -->
  <view class="action-area safe-bottom">
    <button class="start-btn {{isUploading || !photoUrl ? 'disabled' : ''}}" bindtap="onStartAnalysis" disabled="{{isUploading || !photoUrl}}" loading="{{isUploading}}">
      <text class="start-text">{{isUploading ? '上传中...' : '开始 AI 诊断'}}</text>
      <text class="start-arrow" wx:if="{{!isUploading}}">→</text>
    </button>
    <view class="action-tip">
      <text class="action-tip-dot"></text>
      <text>3000 亿参数大模型 · 10 秒生成专业报告</text>
    </view>
  </view>
</view>
