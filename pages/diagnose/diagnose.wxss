/* pages/diagnose/diagnose.wxss */
.page-diagnose {
  min-height: 100vh;
  background: #FAFAF5;
  padding-top: 48rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.type-switch {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 16rpx;
}

.type-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  background: #ffffff;
  color: #999999;
  transition: all 0.3s;
}

.type-item.active {
  background: #C8A97E;
  color: #ffffff;
  font-weight: 600;
}

/* 性别选择 */
.gender-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 32rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
}

.gender-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.gender-switch {
  display: flex;
  gap: 16rpx;
}

.gender-item {
  padding: 12rpx 40rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  background: #ffffff;
  color: #999999;
  transition: all 0.3s;
}

.gender-item.active {
  background: #C8A97E;
  color: #ffffff;
  font-weight: 600;
}

/* 基本信息 */
.info-section {
  margin: 24rpx 32rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
}

.info-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  width: 120rpx;
  flex-shrink: 0;
}

.info-required {
  color: #e85c5c;
  font-size: 28rpx;
  margin-left: 4rpx;
}

.info-input {
  flex: 1;
  height: 64rpx;
  background: #FAFAF5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  text-align: right;
}

.info-unit {
  font-size: 26rpx;
  color: #999999;
  width: 48rpx;
  text-align: right;
  flex-shrink: 0;
}

.info-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 4rpx 0;
}

.photo-area {
  padding: 24rpx 32rpx;
  display: flex;
  justify-content: center;
}

.photo-circle-wrap {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.photo-circle {
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  border: 4rpx solid #f0ebe5;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.rechoose {
  margin-top: 20rpx;
  background: rgba(0, 0, 0, 0.05);
  color: #666666;
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.photo-upload {
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-circle-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 360rpx;
  height: 360rpx;
  border-radius: 50%;
  border: 2rpx dashed #cccccc;
  background: #ffffff;
  transition: all 0.3s;
}

.upload-circle-btn:active {
  transform: scale(0.97);
  border-color: #C8A97E;
}

.upload-icon {
  font-size: 64rpx;
}

.upload-text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
}

.upload-hint {
  font-size: 22rpx;
  color: #999999;
}

.guide-section {
  margin: 12rpx 32rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.guide-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx 20rpx;
}

.guide-cell {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666666;
}

.tags-section {
  margin: 24rpx 32rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
}

.tags-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.tags-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.tags-add {
  font-size: 26rpx;
  color: #C8A97E;
  font-weight: 500;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.user-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(200, 169, 126, 0.12);
  color: #8B7355;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.tag-remove {
  font-size: 28rpx;
  color: #C8A97E;
  padding: 0 4rpx;
}

.tags-empty {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}

.tag-input-area {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  align-items: center;
}

.tag-input {
  flex: 1;
  height: 64rpx;
  background: #FAFAF5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.tag-input-btn {
  padding: 12rpx 24rpx;
  background: #C8A97E;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 26rpx;
  flex-shrink: 0;
}

.action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.start-btn {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
}

.start-btn[disabled] {
  opacity: 0.5;
}
