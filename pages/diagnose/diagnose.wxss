/* pages/diagnose/diagnose.wxss */

/* ============ 页面容器 ============ */
.page-diagnose {
  position: relative;
  min-height: 100vh;
  background: #FFFFFF;
  padding-top: 56rpx;
  padding-bottom: calc(220rpx + env(safe-area-inset-bottom));
  overflow: hidden;
  color: #1a1a1a;
}

/* 极简网格（隐去多余装饰，仅保留淡雅纹理） */
.bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(241, 132, 155, 0.06) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(241, 132, 155, 0.06) 1rpx, transparent 1rpx);
  background-size: 80rpx 80rpx;
  mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0) 60%);
  -webkit-mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.4) 0%, rgba(0, 0, 0, 0) 60%);
  pointer-events: none;
}

/* 单色光晕 */
.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(100rpx);
  pointer-events: none;
}

.bg-glow-1 {
  top: -160rpx;
  right: -160rpx;
  width: 480rpx;
  height: 480rpx;
  background: radial-gradient(circle, rgba(241, 132, 155, 0.35) 0%, transparent 70%);
}

.bg-glow-2 {
  display: none;
}

/* ============ 顶部品牌头 ============ */
.hero {
  position: relative;
  padding: 24rpx 48rpx 8rpx;
  z-index: 2;
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 20rpx;
  background: rgba(241, 132, 155, 0.1);
  border: 1rpx solid rgba(241, 132, 155, 0.3);
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #F1849B;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.tag-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #F1849B;
  box-shadow: 0 0 12rpx rgba(241, 132, 155, 0.6);
  animation: pulse 1.6s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.hero-title {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.hero-sub {
  font-size: 24rpx;
  color: #999;
  letter-spacing: 1rpx;
  line-height: 1.6;
}

/* ============ 步骤指示 ============ */
.step-line {
  position: relative;
  display: flex;
  align-items: center;
  padding: 40rpx 48rpx 32rpx;
  z-index: 2;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.step-dot {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 1rpx solid #ececec;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #c0c0c0;
  letter-spacing: 1rpx;
}

.step.active .step-dot {
  background: #F1849B;
  border-color: transparent;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(241, 132, 155, 0.4);
}

.step.next .step-dot {
  border-color: rgba(241, 132, 155, 0.5);
  color: #F1849B;
}

.step-label {
  font-size: 22rpx;
  color: #b8b8b8;
  letter-spacing: 1rpx;
}

.step.active .step-label,
.step.next .step-label {
  color: #1a1a1a;
}

.step-bar {
  flex: 1;
  height: 1rpx;
  background: #ececec;
  margin: 0 16rpx;
  margin-bottom: 32rpx;
}

/* ============ 扫描上传卡片 ============ */
.scan-card {
  position: relative;
  margin: 16rpx 32rpx 0;
  padding: 48rpx 32rpx 36rpx;
  background: #fff;
  border: 1rpx solid #f0f0f0;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  z-index: 2;
}

.scan-card:not(.has-photo) {
  animation: cardBreath 2.4s ease-in-out infinite;
}

@keyframes cardBreath {
  0%, 100% {
    box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04), 0 0 0 0 rgba(241, 132, 155, 0.35);
    border-color: #f0f0f0;
  }
  50% {
    box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04), 0 0 0 8rpx rgba(241, 132, 155, 0);
    border-color: rgba(241, 132, 155, 0.5);
  }
}

.scan-card:not(.has-photo):active {
  transform: scale(0.99);
}

.scan-corner {
  position: absolute;
  width: 36rpx;
  height: 36rpx;
  border-color: #F1849B;
  border-style: solid;
  border-width: 0;
}

.scan-corner.tl { top: 16rpx; left: 16rpx; border-top-width: 3rpx; border-left-width: 3rpx; border-top-left-radius: 12rpx; }
.scan-corner.tr { top: 16rpx; right: 16rpx; border-top-width: 3rpx; border-right-width: 3rpx; border-top-right-radius: 12rpx; }
.scan-corner.bl { bottom: 16rpx; left: 16rpx; border-bottom-width: 3rpx; border-left-width: 3rpx; border-bottom-left-radius: 12rpx; }
.scan-corner.br { bottom: 16rpx; right: 16rpx; border-bottom-width: 3rpx; border-right-width: 3rpx; border-bottom-right-radius: 12rpx; }

/* 空态上传 */
.upload-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0 24rpx;
  gap: 20rpx;
}

.upload-icon-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx dashed rgba(241, 132, 155, 0.5);
  animation: rotate 12s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.upload-icon-wrap::before {
  content: '';
  position: absolute;
  inset: 20rpx;
  border-radius: 50%;
  background: rgba(241, 132, 155, 0.08);
}

.upload-icon {
  position: relative;
  font-size: 64rpx;
  color: #F1849B;
  z-index: 1;
}

/* 点击引导：脉冲光晕 */
.upload-pulse {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 2rpx solid rgba(241, 132, 155, 0.6);
  animation: uploadPulse 2s ease-out infinite;
  pointer-events: none;
}

.upload-pulse-2 {
  animation-delay: 1s;
}

@keyframes uploadPulse {
  0% {
    transform: scale(0.85);
    opacity: 0.9;
  }
  100% {
    transform: scale(1.4);
    opacity: 0;
  }
}

/* 小手点击引导（SVG） */
.tap-finger {
  position: absolute;
  right: -12rpx;
  bottom: -12rpx;
  width: 72rpx;
  height: 72rpx;
  z-index: 2;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'><g fill='none' stroke='%23F1849B' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'><path d='M26 38V18a4 4 0 1 1 8 0v14'/><path d='M34 28a4 4 0 0 1 8 0v6'/><path d='M42 30a4 4 0 0 1 8 0v10c0 8-5 14-13 14h-6c-5 0-8-2-10-6l-6-12a4 4 0 0 1 7-4l4 6'/></g><circle cx='32' cy='10' r='3' fill='%23F1849B'/><path d='M22 8l-4-3M42 8l4-3M32 4V0' stroke='%23F1849B' stroke-width='2' stroke-linecap='round'/></svg>");
  background-repeat: no-repeat;
  background-size: contain;
  background-position: center;
  filter: drop-shadow(0 4rpx 8rpx rgba(241, 132, 155, 0.4));
  animation: fingerTap 1.4s ease-in-out infinite;
  transform-origin: 70% 30%;
}

@keyframes fingerTap {
  0%, 100% {
    transform: translate(0, 0) rotate(-12deg) scale(1);
  }
  40% {
    transform: translate(-12rpx, -12rpx) rotate(-18deg) scale(1.08);
  }
  60% {
    transform: translate(0, 0) rotate(-12deg) scale(0.92);
  }
}

.upload-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  letter-spacing: 2rpx;
  margin-top: 8rpx;
}

.upload-sub {
  font-size: 22rpx;
  color: #b8b8b8;
  letter-spacing: 1rpx;
}

/* 已上传状态 */
.scan-card.has-photo {
  padding: 36rpx 28rpx 24rpx;
}

.photo-frame {
  position: relative;
  width: 100%;
  aspect-ratio: 3 / 4;
  border-radius: 24rpx;
  overflow: hidden;
  background: #f5f5f5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.photo-img {
  width: 100%;
  height: 100%;
  display: block;
}

.photo-mask { display: none; }

.scan-sweep {
  position: absolute;
  left: 0;
  right: 0;
  height: 80rpx;
  background: linear-gradient(180deg, rgba(241, 132, 155, 0) 0%, rgba(241, 132, 155, 0.5) 60%, rgba(241, 132, 155, 0) 100%);
  filter: blur(2rpx);
  animation: sweep 2.4s ease-in-out infinite;
  pointer-events: none;
}

@keyframes sweep {
  0% { top: -10%; opacity: 0; }
  20% { opacity: 1; }
  80% { opacity: 1; }
  100% { top: 100%; opacity: 0; }
}

.rechoose-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 24rpx;
  padding: 16rpx 0;
  background: #fafafa;
  border: 1rpx solid #ececec;
  border-radius: 16rpx;
  color: #888;
  font-size: 24rpx;
  letter-spacing: 1rpx;
}

.rechoose-btn:active {
  background: #f0f0f0;
}

.rechoose-icon {
  font-size: 28rpx;
  color: #F1849B;
}

/* ============ 拍照贴士 ============ */
.tips-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin: 28rpx 32rpx 0;
  position: relative;
  z-index: 2;
}

.tip-chip {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 20rpx;
  background: #fafafa;
  border-radius: 14rpx;
  font-size: 24rpx;
  color: #666;
  letter-spacing: 1rpx;
}

.tip-chip .dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #F1849B;
  flex-shrink: 0;
}

/* ============ 行动区 ============ */
.action-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #fff 30%);
  z-index: 100;
}

.start-btn {
  width: 100% !important;
  height: 96rpx;
  display: flex !important;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: #F1849B !important;
  color: #fff !important;
  border-radius: 48rpx !important;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  border: none !important;
  box-shadow: 0 12rpx 32rpx rgba(241, 132, 155, 0.4);
  position: relative;
  overflow: hidden;
}

.start-btn::after {
  border: none !important;
}

.start-btn.disabled {
  opacity: 0.4;
  box-shadow: none;
}

.start-btn:active {
  transform: scale(0.98);
}

.start-text {
  position: relative;
  z-index: 1;
}

.start-arrow {
  font-size: 32rpx;
  position: relative;
  z-index: 1;
}

.action-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 16rpx;
  font-size: 20rpx;
  color: #b8b8b8;
  letter-spacing: 2rpx;
}

.action-tip-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #F1849B;
}
