/* pages/index/index.wxss */
.page-index {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #FAFAF5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 顶部品牌区 */
.header {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 40rpx 32rpx 0;
  background: #FAFAF5;
  overflow: visible;
  position: relative;
  z-index: 10;
}

.brand-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 20rpx;
  margin-left: -20rpx;
  gap: 16rpx;
}

.brand-logo {
  width: 350rpx;
  height: 350rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 11;
  margin-left: -20rpx;
  margin-top: 30rpx;
}

.brand-text {
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 21;
  margin-left: -50rpx;
}

.header-diagnosed {
  padding-top: 48rpx;
  padding-bottom: 28rpx;
}

.brand-area-small {
  flex: 0;
  margin-bottom: 20rpx;
}

.header-diagnosed .report-summary {
  margin-bottom: 20rpx;
}

.logo {
  font-size: 48rpx;
  font-weight: 800;
  color: #333;
  letter-spacing: 6rpx;
  margin-bottom: 4rpx;
}

.slogan {
  font-size: 24rpx;
  color: #8B7355;
  letter-spacing: 2rpx;
}

/* 报告摘要卡片 */
.report-summary {
  background: #fff;
  border: 1rpx solid #F0EBE5;
  border-radius: 20rpx;
  padding: 20rpx 24rpx 18rpx;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.summary-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.summary-title-icon {
  color: #8B7355;
}

.summary-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #8B7355;
  letter-spacing: 1rpx;
}

.summary-arrow {
  font-size: 32rpx;
  color: #C8A97E;
  font-weight: 300;
}

.summary-body {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.score-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #FAFAF5;
}

.score-num {
  font-size: 38rpx;
  font-weight: 800;
  color: #333;
  line-height: 1;
}

.score-unit {
  font-size: 18rpx;
  color: #999;
}

.score-detail {
  flex: 1;
  min-width: 0;
}

.score-level {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.score-tags {
  display: flex;
  flex-wrap: nowrap;
  overflow: hidden;
  gap: 8rpx;
}

.summary-footer {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F0EBE5;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-conclusion {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 1.5;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.summary-date {
  font-size: 20rpx;
  color: #bbb;
  flex-shrink: 0;
  margin-top: 4rpx;
}

/* 核心入口 */
.action-area {
  flex-shrink: 0;
  padding: 0 32rpx;
  margin-top: 38rpx;
  position: relative;
  z-index: 10;
}

.diagnose-btn {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
  gap: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(200, 169, 126, 0.25);
  background: linear-gradient(135deg, #C8A97E, #B8966E);
}

.btn-icon {
  font-size: 56rpx;
  flex-shrink: 0;
  color: #fff;
}

.btn-text {
  display: flex;
  flex-direction: column;
}

.btn-main {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.btn-sub {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
  color: #fff;
}

/* 实时动态轮播 */
.live-ticker {
  margin-top: 16rpx;
  height: 48rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: rgba(200, 169, 126, 0.08);
}

.ticker-swiper {
  height: 48rpx;
}

.ticker-text {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 48rpx;
  padding: 0 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 功能简介 */
.feature-intro {
  flex-shrink: 0;
  padding: 50rpx 32rpx 0;
  position: relative;
  z-index: 20;
  margin-top: -150rpx;
}

.feature-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F0EBE5;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.step-icon {
  font-size: 48rpx;
  color: #C8A97E;
}

.step-text {
  font-size: 24rpx;
  color: #8B7355;
  font-weight: 500;
}

.step-arrow {
  font-size: 32rpx;
  color: #C8A97E;
  margin-top: -20rpx;
}

/* 穿搭决策入口 */
.outfit-entry {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 2rpx 32rpx 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F0EBE5;
}

.outfit-entry:active {
  transform: scale(0.98);
  transition: transform 0.15s;
}

.outfit-entry-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.outfit-entry-icon {
  font-size: 56rpx;
  color: #C8A97E;
  flex-shrink: 0;
}

.outfit-entry-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.outfit-entry-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.outfit-entry-desc {
  font-size: 24rpx;
  color: #999;
}

.outfit-entry-arrow {
  font-size: 36rpx;
  color: #C8A97E;
}

/* Banner广告 */
.banner-ad {
  flex-shrink: 0;
  margin: 24rpx 32rpx 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #F5F0EB, #EDE5DA);
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-placeholder-text {
  font-size: 28rpx;
  color: rgba(139, 115, 85, 0.25);
  letter-spacing: 8rpx;
}

/* 标签覆盖色 */
.tag-warm {
  background: rgba(200, 169, 126, 0.15);
  color: #8B7355;
}
