/* pages/index/index.wxss */
.page-index {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 顶部品牌区 */
.header {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 40rpx 32rpx 0;
  background: #FFFFFF;
  overflow: visible;
  position: relative;
  z-index: 10;
}

.brand-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.brand-text {
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 100;
  margin-top: -400rpx;
}

.header-diagnosed {
  flex: 0 0 auto;
  justify-content: flex-start;
  padding-top: 48rpx;
  padding-bottom: 28rpx;
  margin-top: 0;
}

.brand-area-small {
  flex: 0;
  margin-bottom: 20rpx;
}

.header-diagnosed .brand-text {
  margin-top: 20rpx;
}

.header-diagnosed .report-summary {
  margin-top: 16rpx;
  margin-bottom: 20rpx;
}

.header-diagnosed + .action-area {
  margin-top: -20rpx;
}

.header-diagnosed + .action-area + .banner-ad {
  margin-top: 24rpx;
}

.logo {
  font-size: 48rpx;
  font-weight: 800;
  color: #333;
  letter-spacing: 6rpx;
  margin-bottom: 4rpx;
}

.slogan {
  font-size: 24rpx;
  color: #8B7355;
  letter-spacing: 2rpx;
}

/* 报告摘要卡片 */
.report-summary {
  background: #fff;
  border: 1rpx solid #F0EBE5;
  border-radius: 20rpx;
  padding: 20rpx 24rpx 18rpx;
  margin-top: -104rpx;
  position: relative;
  z-index: 100;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s, box-shadow 0.15s;
}

.report-summary-hover {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.summary-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.summary-title-icon {
  color: #B76E79;
  font-size: 26rpx;
}

.summary-title {
  font-size: 26rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #B76E79 0%, #C38D9E 50%, #E8A87C 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: 2rpx;
  text-shadow: 0 1rpx 2rpx rgba(183, 110, 121, 0.15);
}

.summary-arrow {
  font-size: 28rpx;
  color: #C8A97E;
  font-weight: 300;
}

.summary-tap-hint {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: linear-gradient(135deg, rgba(200, 169, 126, 0.22), rgba(214, 158, 148, 0.22));
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
}

.summary-tap-text {
  font-size: 22rpx;
  color: #B08070;
  font-weight: 600;
}

.summary-tap-hint .summary-arrow {
  color: #B08070;
}

.summary-body {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.score-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #FFFFFF;
}

.score-num {
  font-size: 38rpx;
  font-weight: 800;
  color: #333;
  line-height: 1;
}

.score-unit {
  font-size: 18rpx;
  color: #999;
}

.score-detail {
  flex: 1;
  min-width: 0;
}

.score-level {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.score-level-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 10rpx;
}

.score-level-row .score-level {
  margin-bottom: 0;
}

/* 视觉年龄核心 chip */
.age-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #B76E79 0%, #8B4F58 100%);
  box-shadow: 0 4rpx 12rpx rgba(183, 110, 121, 0.35), inset 0 1rpx 0 rgba(255, 255, 255, 0.25);
}

.age-chip-icon {
  font-size: 20rpx;
  color: #FFE6C7;
  line-height: 1;
}

.age-chip-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
  line-height: 1;
}

.score-tags {
  display: flex;
  flex-wrap: nowrap;
  overflow: hidden;
  gap: 8rpx;
}

.summary-footer {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F0EBE5;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-conclusion {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 1.5;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.summary-date {
  font-size: 20rpx;
  color: #bbb;
  flex-shrink: 0;
  margin-top: 4rpx;
}

/* 核心入口 */
.action-area {
  flex-shrink: 0;
  padding: 0 32rpx;
  margin-top: 28rpx;
  position: relative;
  z-index: 10;
}

/* 未诊断首页宣传视频（高:宽 = 4:3 居中剪裁） */
.intro-video {
  margin: -72rpx 32rpx 0;
  width: calc(100% - 64rpx);
  height: 0;
  padding-bottom: calc(100% - 64rpx);
  position: relative;
  z-index: 100;
  transform: translateY(-30rpx);
  border-radius: 24rpx;
  overflow: hidden;
  background: #000;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}
/* 未诊断状态下，按钮与文字轮播整体上移 */
.intro-video + .action-area {
  transform: translateY(-150rpx);
  z-index: 200;
}
/* 未诊断态：整体内容上移 50rpx（在原位置基础上） */
.page-index-undiag .brand-area {
  transform: translateY(-150rpx);
}
.page-index-undiag .intro-video {
  transform: translateY(-180rpx);
}
.page-index-undiag .intro-video + .action-area-undiag {
  transform: translateY(-180rpx);
}

/* 未诊断态：视频已承载主 CTA，action-area 只剩 ticker，不再向上覆盖视频 */
.intro-video + .action-area-undiag {
  transform: translateY(0);
  margin-top: 12rpx;
}

.intro-video-player {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.intro-video-hover {
  transform: translateY(-30rpx) scale(0.985);
  transition: transform 0.18s ease;
}

/* ============ 视频上酷炫科技风文字引导 ============ */
.tech-overlay {
  position: absolute;
  inset: 0;
  z-index: 5;
  /* 顶部/底部渐变罩，使文字在视频上更清晰 */
  background:
    linear-gradient(180deg, rgba(0, 8, 24, 0.55) 0%, rgba(0, 8, 24, 0) 28%, rgba(0, 8, 24, 0) 55%, rgba(0, 8, 24, 0.78) 100%);
}

/* 四角科技装饰 */
.tech-corner {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #5EE6FF;
  box-shadow: 0 0 12rpx rgba(94, 230, 255, 0.85), inset 0 0 8rpx rgba(94, 230, 255, 0.55);
}
.tech-corner-tl { top: 20rpx; left: 20rpx; border-right: none; border-bottom: none; }
.tech-corner-tr { top: 20rpx; right: 20rpx; border-left: none; border-bottom: none; }
.tech-corner-bl { bottom: 20rpx; left: 20rpx; border-right: none; border-top: none; }
.tech-corner-br { bottom: 20rpx; right: 20rpx; border-left: none; border-top: none; }

/* 顶部状态行 */
.tech-status {
  position: absolute;
  top: 32rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.tech-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #5EE6FF;
  box-shadow: 0 0 12rpx #5EE6FF, 0 0 24rpx rgba(94, 230, 255, 0.6);
  animation: techPulse 1.4s ease-in-out infinite;
}
.tech-status-text {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #B8F4FF;
  font-weight: 600;
  text-shadow: 0 0 8rpx rgba(94, 230, 255, 0.6);
}

/* 扫描线 */
.tech-scan {
  position: absolute;
  left: 4%;
  right: 4%;
  height: 3rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(94, 230, 255, 0.95) 50%, transparent 100%);
  box-shadow: 0 0 18rpx rgba(94, 230, 255, 0.85), 0 0 40rpx rgba(94, 230, 255, 0.45);
  animation: techScan 3.6s ease-in-out infinite;
  border-radius: 2rpx;
}

/* 底部 CTA 文字组 */
.tech-cta {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.tech-cta-sub {
  display: flex;
  align-items: center;
  gap: 10rpx;
  opacity: 0.92;
}
.tech-bracket {
  font-size: 26rpx;
  color: #5EE6FF;
  font-weight: 600;
  text-shadow: 0 0 8rpx rgba(94, 230, 255, 0.7);
}
.tech-cta-en {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: #B8F4FF;
  font-weight: 700;
  text-shadow: 0 0 8rpx rgba(94, 230, 255, 0.55);
}

.tech-cta-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 36rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, rgba(0, 16, 40, 0.35) 0%, rgba(94, 230, 255, 0.18) 50%, rgba(0, 16, 40, 0.35) 100%);
  border: 1rpx solid rgba(94, 230, 255, 0.55);
  box-shadow: 0 0 24rpx rgba(94, 230, 255, 0.35), inset 0 0 16rpx rgba(94, 230, 255, 0.18);
  animation: techGlow 2.2s ease-in-out infinite;
}
.tech-arrow {
  font-size: 32rpx;
  color: #5EE6FF;
  text-shadow: 0 0 10rpx rgba(94, 230, 255, 0.9);
  animation: techArrow 1.4s ease-in-out infinite;
}
.tech-arrow-rev {
  animation-delay: 0.7s;
}
.tech-cta-text {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #FFFFFF;
  background: linear-gradient(90deg, #FFFFFF 0%, #B8F4FF 50%, #FFFFFF 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 0 14rpx rgba(94, 230, 255, 0.55);
}

.tech-cta-hint {
  font-size: 20rpx;
  color: rgba(184, 244, 255, 0.85);
  letter-spacing: 3rpx;
  text-shadow: 0 0 6rpx rgba(94, 230, 255, 0.4);
}

@keyframes techPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}
@keyframes techScan {
  0% { top: 18%; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { top: 82%; opacity: 0; }
}
@keyframes techGlow {
  0%, 100% { box-shadow: 0 0 24rpx rgba(94, 230, 255, 0.35), inset 0 0 16rpx rgba(94, 230, 255, 0.18); }
  50% { box-shadow: 0 0 36rpx rgba(94, 230, 255, 0.7), inset 0 0 24rpx rgba(94, 230, 255, 0.32); }
}
@keyframes techArrow {
  0%, 100% { transform: translateX(0); opacity: 0.7; }
  50% { transform: translateX(6rpx); opacity: 1; }
}

.diagnose-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 40rpx;
  gap: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(249, 184, 201, 0.35);
  background: #F1849B;
  position: relative;
  overflow: hidden;
}

/* 闪烁星星 */
.btn-sparkle .sparkle {
  position: absolute;
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  pointer-events: none;
  animation: sparkle 2s ease-in-out infinite;
}

.sparkle-1 {
  top: 24rpx;
  left: 28rpx;
  font-size: 42rpx;
  animation-delay: 0s;
}

.sparkle-2 {
  top: 28rpx;
  right: 44rpx;
  font-size: 26rpx;
  animation-delay: 0.5s;
}

.sparkle-3 {
  bottom: 24rpx;
  left: 84rpx;
  font-size: 30rpx;
  animation-delay: 1s;
}

.sparkle-4 {
  bottom: 26rpx;
  right: 24rpx;
  font-size: 36rpx;
  animation-delay: 1.5s;
}

@keyframes sparkle {
  0%, 100% { opacity: 0; transform: scale(0.5); }
  50% { opacity: 1; transform: scale(1.2); }
}

.btn-icon {
  font-size: 56rpx;
  flex-shrink: 0;
  color: #fff;
}

.btn-text {
  display: flex;
  flex-direction: column;
  transform: translateX(-30rpx);
}

/* 已诊断态：穿搭按钮内有图标，避免图标与文字重叠 */
.diagnose-btn .btn-icon {
  transform: translateX(-10rpx);
}
.diagnose-btn .btn-icon + .btn-text {
  transform: translateX(10rpx);
}

/* 未登录提示用：右侧手指点击矢量图标（SVG data URI 作 CSS 背景，纯静态） */
.btn-tap-hint {
  position: absolute;
  right: 142rpx;
  top: 50%;
  width: 60rpx;
  height: 60rpx;
  transform: translateY(-50%) rotate(-15deg);
  pointer-events: none;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23ffffff' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'><path d='M9 11V6.5a2 2 0 1 1 4 0V12'/><path d='M13 10.5a2 2 0 1 1 4 0V13'/><path d='M17 11.5a2 2 0 1 1 4 0V16a6 6 0 0 1-6 6h-2a6 6 0 0 1-5.2-3l-3.3-5.7a2 2 0 0 1 3.46-2L9 14'/></svg>");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.btn-main {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.btn-sub {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
  color: #fff;
}

/* 实时动态轮播 */
.live-ticker {
  margin-top: 16rpx;
  height: 48rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: rgba(200, 169, 126, 0.08);
}

.ticker-swiper {
  height: 48rpx;
}

.ticker-text {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 48rpx;
  padding: 0 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 功能简介 */
.feature-intro {
  flex-shrink: 0;
  padding: 20rpx 32rpx 0;
  margin-top: -125rpx;
  position: relative;
  z-index: 20;
}

.feature-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F0EBE5;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.step-icon {
  font-size: 48rpx;
  color: #C8A97E;
}

.step-text {
  font-size: 24rpx;
  color: #8B7355;
  font-weight: 500;
}

.step-arrow {
  font-size: 32rpx;
  color: #C8A97E;
  margin-top: -20rpx;
}

/* 穿搭决策入口 */
.outfit-entry {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 2rpx 32rpx 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F0EBE5;
}

.outfit-entry:active {
  transform: scale(0.98);
  transition: transform 0.15s;
}

.outfit-entry-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.outfit-entry-icon {
  font-size: 56rpx;
  color: #F67C9F;
  flex-shrink: 0;
}

.outfit-entry-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.outfit-entry-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.outfit-entry-desc {
  font-size: 24rpx;
  color: #999;
}

.outfit-entry-arrow {
  font-size: 36rpx;
  color: #F67C9F;
}

/* Banner广告 - 强化点击引导 */
.banner-ad {
  position: relative;
  flex-shrink: 0;
  margin: 28rpx 24rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow:
    0 8rpx 28rpx rgba(246, 124, 159, 0.18),
    0 2rpx 10rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid rgba(246, 124, 159, 0.35);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  animation: bannerBreath 2.6s ease-in-out infinite;
}

.banner-ad-hover {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(246, 124, 159, 0.22);
}

@keyframes bannerBreath {
  0%, 100% {
    box-shadow: 0 8rpx 28rpx rgba(246, 124, 159, 0.18), 0 2rpx 10rpx rgba(0,0,0,0.06);
  }
  50% {
    box-shadow: 0 10rpx 36rpx rgba(246, 124, 159, 0.32), 0 2rpx 12rpx rgba(0,0,0,0.08);
  }
}

.banner-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 斜向光带扫过动效 */
.banner-shine {
  pointer-events: none;
  position: absolute;
  top: 0;
  left: -60%;
  width: 50%;
  height: 100%;
  background: linear-gradient(
    115deg,
    transparent 0%,
    rgba(255, 255, 255, 0) 35%,
    rgba(255, 255, 255, 0.55) 50%,
    rgba(255, 255, 255, 0) 65%,
    transparent 100%
  );
  transform: skewX(-20deg);
  animation: bannerShine 3.2s ease-in-out infinite;
}

@keyframes bannerShine {
  0% { left: -60%; }
  60%, 100% { left: 120%; }
}

/* 顶部反种草角标 */
.banner-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FF6B8B 0%, #F67C9F 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(246, 124, 159, 0.45);
}

.banner-badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFFFFF;
  margin-right: 8rpx;
  box-shadow: 0 0 8rpx rgba(255, 255, 255, 0.9);
  animation: bannerDot 1.4s ease-in-out infinite;
}

@keyframes bannerDot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.7); }
}

.banner-badge-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* 底部点击引导胶囊 */
.banner-cta {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(8rpx);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.banner-cta-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.banner-cta-arrow {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-left: 8rpx;
  font-weight: 700;
  animation: bannerArrow 1.2s ease-in-out infinite;
}

@keyframes bannerArrow {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(6rpx); }
}

.banner-placeholder {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #F5F0EB, #EDE5DA);
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-placeholder-text {
  font-size: 28rpx;
  color: rgba(139, 115, 85, 0.25);
  letter-spacing: 8rpx;
}

/* 标签覆盖色 */
.tag-warm {
  background: linear-gradient(135deg, #FFF4E6 0%, #FCE7EC 100%);
  color: #C97B82;
  border: 1rpx solid rgba(232, 168, 124, 0.35);
  font-weight: 600;
  padding: 5rpx 16rpx;
  font-size: 22rpx;
  margin: 0;
  box-shadow: 0 2rpx 6rpx rgba(232, 168, 124, 0.15);
}

/* ============ 登录确认弹窗 ============ */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-modal {
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 56rpx 48rpx 40rpx;
  text-align: center;
  animation: modalIn 0.3s ease;
}

@keyframes modalIn {
  from { transform: scale(0.85); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.login-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.login-modal-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.login-avatar-area {
  margin-bottom: 36rpx;
}

.login-avatar-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.login-avatar-btn::after {
  border: none;
}

.login-avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #F1849B;
}

.login-avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f5f5f7;
  border: 4rpx dashed #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-avatar-add {
  font-size: 64rpx;
  color: #ccc;
}

.login-avatar-edit {
  font-size: 22rpx;
  color: #F1849B;
  margin-top: 12rpx;
}

.login-nickname-area {
  margin-bottom: 40rpx;
  padding: 0 20rpx;
}

.login-nickname-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

.login-confirm-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #F1849B, #E8607A);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.login-confirm-btn:active {
  opacity: 0.85;
}

.login-skip {
  font-size: 24rpx;
  color: #999;
  padding: 12rpx 0;
}

/* 浮动「蜕变」FAB */
.beauty-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(40rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB6C1 0%, #F1849B 60%, #E5739A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(241, 132, 155, 0.45),
              0 0 0 6rpx rgba(255, 255, 255, 0.85);
  z-index: 99;
}
.beauty-fab-hover {
  transform: scale(0.94);
}
.beauty-fab-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

/* 颜值百分位徽章 */
.score-percentile {
  display: inline-flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, rgba(255, 235, 240, 0.9) 0%, rgba(255, 224, 230, 0.9) 100%);
  border-radius: 999rpx;
  border: 1rpx solid rgba(241, 132, 155, 0.25);
  align-self: flex-start;
}
.score-percentile .percentile-icon {
  font-size: 18rpx;
  color: #F1849B;
  margin-right: 6rpx;
}
.score-percentile .percentile-text {
  font-size: 22rpx;
  color: #8a4a58;
  letter-spacing: 0.5rpx;
}
.score-percentile .percentile-num {
  font-size: 26rpx;
  font-weight: 700;
  color: #e8506a;
  margin: 0 2rpx;
}

/* 未诊断态：底部能力标签横向无缝轮播（双排反向） */
.feature-marquee {
  margin: -150rpx 0 40rpx;
  padding: 16rpx 0;
  overflow: hidden;
  position: relative;
  -webkit-mask-image: linear-gradient(to right, transparent 0, #000 8%, #000 92%, transparent 100%);
  mask-image: linear-gradient(to right, transparent 0, #000 8%, #000 92%, transparent 100%);
}
.feature-marquee-row {
  overflow: hidden;
  padding: 8rpx 0;
}
.feature-marquee-track {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: max-content;
  animation: feature-marquee-scroll 60s linear infinite;
}
.feature-marquee-track-rev {
  animation: feature-marquee-scroll-rev 72s linear infinite;
}
.feature-chip {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(235, 244, 252, 0.92) 0%, rgba(214, 230, 245, 0.88) 100%);
  border: 1rpx solid rgba(120, 160, 200, 0.22);
  box-shadow: 0 2rpx 12rpx rgba(90, 130, 180, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(8rpx);
}
.feature-chip-dot {
  font-size: 18rpx;
  color: #7aa6cf;
  margin-right: 10rpx;
  letter-spacing: 0;
}
.feature-chip-text {
  font-size: 24rpx;
  color: #3d5a7a;
  letter-spacing: 2rpx;
  font-weight: 500;
  white-space: nowrap;
}
@keyframes feature-marquee-scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
@keyframes feature-marquee-scroll-rev {
  from { transform: translateX(-50%); }
  to { transform: translateX(0); }
}
