/* pages/index/index.wxss */
.page-index {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 顶部品牌区 */
.header {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 40rpx 32rpx 0;
  background: #FFFFFF;
  overflow: visible;
  position: relative;
  z-index: 10;
}

.brand-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.brand-text {
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 100;
  margin-top: -400rpx;
}

.header-diagnosed {
  flex: 0 0 auto;
  justify-content: flex-start;
  padding-top: 48rpx;
  padding-bottom: 28rpx;
  margin-top: 0;
}

.brand-area-small {
  flex: 0;
  margin-bottom: 20rpx;
}

.header-diagnosed .brand-text {
  margin-top: 20rpx;
}

.header-diagnosed .report-summary {
  margin-top: 16rpx;
  margin-bottom: 20rpx;
}

.header-diagnosed + .action-area {
  margin-top: -20rpx;
}

.header-diagnosed + .action-area + .banner-ad {
  margin-top: 24rpx;
}

.logo {
  font-size: 48rpx;
  font-weight: 800;
  color: #333;
  letter-spacing: 6rpx;
  margin-bottom: 4rpx;
}

.slogan {
  font-size: 24rpx;
  color: #8B7355;
  letter-spacing: 2rpx;
}

/* 报告摘要卡片 */
.report-summary {
  background: #EEF3F8;
  border: 1rpx solid #DCE5EF;
  border-radius: 24rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-top: -104rpx;
  position: relative;
  z-index: 100;
  box-shadow: 0 8rpx 32rpx rgba(40, 60, 90, 0.08);
  transition: transform 0.15s, box-shadow 0.15s;
}

.report-summary-hover {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(40, 30, 20, 0.08);
}

.summary-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 18rpx;
  margin-bottom: 22rpx;
  border-bottom: 1rpx solid #DCE5EF;
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.summary-title-icon {
  color: #B89968;
  font-size: 26rpx;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1F1A17;
  letter-spacing: 3rpx;
}

.summary-arrow {
  font-size: 30rpx;
  color: #B89968;
  font-weight: 300;
  line-height: 1;
}

.summary-tap-hint {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.summary-tap-text {
  font-size: 22rpx;
  color: #8C7A5C;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.summary-tap-hint .summary-arrow {
  color: #8C7A5C;
  font-size: 26rpx;
}

.summary-body {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.score-circle {
  width: 116rpx;
  height: 116rpx;
  border-radius: 50%;
  border: 2rpx solid;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #FFFFFF;
  box-shadow: inset 0 0 0 6rpx #fff;
}

.score-num {
  font-size: 46rpx;
  font-weight: 800;
  color: #1F1A17;
  line-height: 1;
  letter-spacing: -1rpx;
}

.score-unit {
  font-size: 18rpx;
  color: #B0A498;
  margin-top: 2rpx;
  letter-spacing: 1rpx;
}

.score-detail {
  flex: 1;
  min-width: 0;
}

.score-level {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.score-level-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 14rpx;
}

.score-level-row .score-level {
  margin-bottom: 0;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* 视觉年龄核心 chip - 香槟金 */
.age-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: #F5EFE3;
  border: 1rpx solid rgba(184, 153, 104, 0.4);
  flex-shrink: 0;
}

.age-chip-icon {
  font-size: 20rpx;
  color: #B89968;
  line-height: 1;
}

.age-chip-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #6B5326;
  letter-spacing: 1rpx;
  line-height: 1;
}

.score-tags {
  display: flex;
  flex-wrap: nowrap;
  overflow: hidden;
  gap: 8rpx;
}

.summary-footer {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #DCE5EF;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-conclusion {
  font-size: 24rpx;
  color: #5C5048;
  line-height: 1.6;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.summary-date {
  font-size: 20rpx;
  color: #C0B5A6;
  flex-shrink: 0;
  margin-top: 4rpx;
  letter-spacing: 0.5rpx;
}

/* 核心入口 */
.action-area {
  flex-shrink: 0;
  padding: 0 32rpx;
  margin-top: 28rpx;
  position: relative;
  z-index: 10;
}

/* 未诊断首页宣传视频（高:宽 = 4:3 居中剪裁） */
.intro-video {
  margin: -72rpx 32rpx 0;
  width: calc(100% - 64rpx);
  height: 0;
  padding-bottom: calc(100% - 64rpx);
  position: relative;
  z-index: 100;
  transform: translateY(-30rpx);
  border-radius: 24rpx;
  overflow: hidden;
  background: #000;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}
/* 未诊断状态下，按钮与文字轮播整体上移 */
.intro-video + .action-area {
  transform: translateY(-150rpx);
  z-index: 200;
}
/* 未诊断态：整体内容上移 50rpx（在原位置基础上） */
.page-index-undiag .brand-area {
  transform: translateY(-150rpx);
}
/* 未诊断态：品牌文案放大，强化主页气势 */
.page-index-undiag .logo {
  font-size: 64rpx;
  letter-spacing: 8rpx;
  margin-bottom: 10rpx;
}
.page-index-undiag .slogan {
  font-size: 30rpx;
  letter-spacing: 3rpx;
}
.page-index-undiag .intro-video {
  transform: translateY(-180rpx);
}
.page-index-undiag .intro-video + .action-area-undiag {
  transform: translateY(-180rpx);
}

/* 未诊断态：视频已承载主 CTA，action-area 只剩 ticker，不再向上覆盖视频 */
.intro-video + .action-area-undiag {
  transform: translateY(0);
  margin-top: 12rpx;
}

.intro-video-player {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.intro-video-hover {
  transform: translateY(-30rpx) scale(0.985);
  transition: transform 0.18s ease;
}

/* ============ 视频上酷炫科技风文字引导 ============ */
.tech-overlay {
  position: absolute;
  inset: 0;
  z-index: 5;
  /* 顶部/底部渐变罩，使文字在视频上更清晰 */
  background:
    linear-gradient(180deg, rgba(0, 8, 24, 0.55) 0%, rgba(0, 8, 24, 0) 28%, rgba(0, 8, 24, 0) 55%, rgba(0, 8, 24, 0.78) 100%);
}

/* 四角科技装饰 */
.tech-corner {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #5EE6FF;
  box-shadow: 0 0 12rpx rgba(94, 230, 255, 0.85), inset 0 0 8rpx rgba(94, 230, 255, 0.55);
}
.tech-corner-tl { top: 20rpx; left: 20rpx; border-right: none; border-bottom: none; }
.tech-corner-tr { top: 20rpx; right: 20rpx; border-left: none; border-bottom: none; }
.tech-corner-bl { bottom: 20rpx; left: 20rpx; border-right: none; border-top: none; }
.tech-corner-br { bottom: 20rpx; right: 20rpx; border-left: none; border-top: none; }

/* 顶部状态行 */
.tech-status {
  position: absolute;
  top: 32rpx;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.tech-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #5EE6FF;
  box-shadow: 0 0 12rpx #5EE6FF, 0 0 24rpx rgba(94, 230, 255, 0.6);
  animation: techPulse 1.4s ease-in-out infinite;
}
.tech-status-text {
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #B8F4FF;
  font-weight: 600;
  text-shadow: 0 0 8rpx rgba(94, 230, 255, 0.6);
}

/* 扫描线 */
.tech-scan {
  position: absolute;
  left: 4%;
  right: 4%;
  height: 3rpx;
  background: linear-gradient(90deg, transparent 0%, rgba(94, 230, 255, 0.95) 50%, transparent 100%);
  box-shadow: 0 0 18rpx rgba(94, 230, 255, 0.85), 0 0 40rpx rgba(94, 230, 255, 0.45);
  animation: techScan 3.6s ease-in-out infinite;
  border-radius: 2rpx;
}

/* 底部 CTA 文字组 */
.tech-cta {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 64rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
}

.tech-cta-sub {
  display: flex;
  align-items: center;
  gap: 10rpx;
  opacity: 0.92;
}
.tech-bracket {
  font-size: 26rpx;
  color: #5EE6FF;
  font-weight: 600;
  text-shadow: 0 0 8rpx rgba(94, 230, 255, 0.7);
}
.tech-cta-en {
  font-size: 22rpx;
  letter-spacing: 8rpx;
  color: #B8F4FF;
  font-weight: 700;
  text-shadow: 0 0 8rpx rgba(94, 230, 255, 0.55);
}

.tech-cta-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 36rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, rgba(0, 16, 40, 0.35) 0%, rgba(94, 230, 255, 0.18) 50%, rgba(0, 16, 40, 0.35) 100%);
  border: 1rpx solid rgba(94, 230, 255, 0.55);
  box-shadow: 0 0 24rpx rgba(94, 230, 255, 0.35), inset 0 0 16rpx rgba(94, 230, 255, 0.18);
  animation: techGlow 2.2s ease-in-out infinite;
}
.tech-arrow {
  font-size: 32rpx;
  color: #5EE6FF;
  text-shadow: 0 0 10rpx rgba(94, 230, 255, 0.9);
  animation: techArrow 1.4s ease-in-out infinite;
}
.tech-arrow-rev {
  animation-delay: 0.7s;
}
.tech-cta-text {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #FFFFFF;
  background: linear-gradient(90deg, #FFFFFF 0%, #B8F4FF 50%, #FFFFFF 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 0 14rpx rgba(94, 230, 255, 0.55);
}

.tech-cta-hint {
  font-size: 20rpx;
  color: rgba(184, 244, 255, 0.85);
  letter-spacing: 3rpx;
  text-shadow: 0 0 6rpx rgba(94, 230, 255, 0.4);
}

@keyframes techPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}
@keyframes techScan {
  0% { top: 18%; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { top: 82%; opacity: 0; }
}
@keyframes techGlow {
  0%, 100% { box-shadow: 0 0 24rpx rgba(94, 230, 255, 0.35), inset 0 0 16rpx rgba(94, 230, 255, 0.18); }
  50% { box-shadow: 0 0 36rpx rgba(94, 230, 255, 0.7), inset 0 0 24rpx rgba(94, 230, 255, 0.32); }
}
@keyframes techArrow {
  0%, 100% { transform: translateX(0); opacity: 0.7; }
  50% { transform: translateX(6rpx); opacity: 1; }
}

.diagnose-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 40rpx;
  gap: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(249, 184, 201, 0.35);
  background: #F1849B;
  position: relative;
  overflow: hidden;
}

/* 闪烁星星 */
.btn-sparkle .sparkle {
  position: absolute;
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  pointer-events: none;
  animation: sparkle 2s ease-in-out infinite;
}

.sparkle-1 {
  top: 24rpx;
  left: 28rpx;
  font-size: 42rpx;
  animation-delay: 0s;
}

.sparkle-2 {
  top: 28rpx;
  right: 44rpx;
  font-size: 26rpx;
  animation-delay: 0.5s;
}

.sparkle-3 {
  bottom: 24rpx;
  left: 84rpx;
  font-size: 30rpx;
  animation-delay: 1s;
}

.sparkle-4 {
  bottom: 26rpx;
  right: 24rpx;
  font-size: 36rpx;
  animation-delay: 1.5s;
}

@keyframes sparkle {
  0%, 100% { opacity: 0; transform: scale(0.5); }
  50% { opacity: 1; transform: scale(1.2); }
}

.btn-icon {
  font-size: 56rpx;
  flex-shrink: 0;
  color: #fff;
}

.btn-text {
  display: flex;
  flex-direction: column;
  transform: translateX(-30rpx);
}

/* 已诊断态：穿搭按钮内有图标，避免图标与文字重叠 */
.diagnose-btn .btn-icon {
  transform: translateX(-10rpx);
}
.diagnose-btn .btn-icon + .btn-text {
  transform: translateX(10rpx);
}

/* 未登录提示用：右侧手指点击矢量图标（SVG data URI 作 CSS 背景，纯静态） */
.btn-tap-hint {
  position: absolute;
  right: 142rpx;
  top: 50%;
  width: 60rpx;
  height: 60rpx;
  transform: translateY(-50%) rotate(-15deg);
  pointer-events: none;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23ffffff' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'><path d='M9 11V6.5a2 2 0 1 1 4 0V12'/><path d='M13 10.5a2 2 0 1 1 4 0V13'/><path d='M17 11.5a2 2 0 1 1 4 0V16a6 6 0 0 1-6 6h-2a6 6 0 0 1-5.2-3l-3.3-5.7a2 2 0 0 1 3.46-2L9 14'/></svg>");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.btn-main {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.btn-sub {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
  color: #fff;
}

/* 实时动态轮播 */
.live-ticker {
  margin-top: 16rpx;
  height: 48rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: rgba(200, 169, 126, 0.08);
}

.ticker-swiper {
  height: 48rpx;
}

.ticker-text {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 48rpx;
  padding: 0 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 功能简介 */
.feature-intro {
  flex-shrink: 0;
  padding: 20rpx 32rpx 0;
  margin-top: -125rpx;
  position: relative;
  z-index: 20;
}

.feature-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F0EBE5;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.step-icon {
  font-size: 48rpx;
  color: #C8A97E;
}

.step-text {
  font-size: 24rpx;
  color: #8B7355;
  font-weight: 500;
}

.step-arrow {
  font-size: 32rpx;
  color: #C8A97E;
  margin-top: -20rpx;
}

/* 穿搭决策入口 */
.outfit-entry {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 2rpx 32rpx 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F0EBE5;
}

.outfit-entry:active {
  transform: scale(0.98);
  transition: transform 0.15s;
}

.outfit-entry-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.outfit-entry-icon {
  font-size: 56rpx;
  color: #F67C9F;
  flex-shrink: 0;
}

.outfit-entry-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.outfit-entry-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.outfit-entry-desc {
  font-size: 24rpx;
  color: #999;
}

.outfit-entry-arrow {
  font-size: 36rpx;
  color: #F67C9F;
}

/* Banner广告 - 强化点击引导 */
.banner-ad {
  position: relative;
  flex-shrink: 0;
  margin: 28rpx 24rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow:
    0 8rpx 28rpx rgba(246, 124, 159, 0.18),
    0 2rpx 10rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid rgba(246, 124, 159, 0.35);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  animation: bannerBreath 2.6s ease-in-out infinite;
}

.banner-ad-hover {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(246, 124, 159, 0.22);
}

@keyframes bannerBreath {
  0%, 100% {
    box-shadow: 0 8rpx 28rpx rgba(246, 124, 159, 0.18), 0 2rpx 10rpx rgba(0,0,0,0.06);
  }
  50% {
    box-shadow: 0 10rpx 36rpx rgba(246, 124, 159, 0.32), 0 2rpx 12rpx rgba(0,0,0,0.08);
  }
}

.banner-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 斜向光带扫过动效 */
.banner-shine {
  pointer-events: none;
  position: absolute;
  top: 0;
  left: -60%;
  width: 50%;
  height: 100%;
  background: linear-gradient(
    115deg,
    transparent 0%,
    rgba(255, 255, 255, 0) 35%,
    rgba(255, 255, 255, 0.55) 50%,
    rgba(255, 255, 255, 0) 65%,
    transparent 100%
  );
  transform: skewX(-20deg);
  animation: bannerShine 3.2s ease-in-out infinite;
}

@keyframes bannerShine {
  0% { left: -60%; }
  60%, 100% { left: 120%; }
}

/* 顶部反种草角标 */
.banner-badge {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, #FF6B8B 0%, #F67C9F 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(246, 124, 159, 0.45);
}

.banner-badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #FFFFFF;
  margin-right: 8rpx;
  box-shadow: 0 0 8rpx rgba(255, 255, 255, 0.9);
  animation: bannerDot 1.4s ease-in-out infinite;
}

@keyframes bannerDot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.7); }
}

.banner-badge-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 700;
  letter-spacing: 2rpx;
}

/* 底部点击引导胶囊 */
.banner-cta {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(8rpx);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.banner-cta-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.banner-cta-arrow {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-left: 8rpx;
  font-weight: 700;
  animation: bannerArrow 1.2s ease-in-out infinite;
}

@keyframes bannerArrow {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(6rpx); }
}

.banner-placeholder {
  width: 100%;
  height: 240rpx;
  background: linear-gradient(135deg, #F5F0EB, #EDE5DA);
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-placeholder-text {
  font-size: 28rpx;
  color: rgba(139, 115, 85, 0.25);
  letter-spacing: 8rpx;
}

/* 标签覆盖色 */
.tag-warm {
  background: linear-gradient(135deg, #FFF4E6 0%, #FCE7EC 100%);
  color: #C97B82;
  border: 1rpx solid rgba(232, 168, 124, 0.35);
  font-weight: 600;
  padding: 5rpx 16rpx;
  font-size: 22rpx;
  margin: 0;
  box-shadow: 0 2rpx 6rpx rgba(232, 168, 124, 0.15);
}

/* ============ 登录确认弹窗 ============ */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-modal {
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 56rpx 48rpx 40rpx;
  text-align: center;
  animation: modalIn 0.3s ease;
}

@keyframes modalIn {
  from { transform: scale(0.85); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.login-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.login-modal-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.login-avatar-area {
  margin-bottom: 36rpx;
}

.login-avatar-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.login-avatar-btn::after {
  border: none;
}

.login-avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #F1849B;
}

.login-avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f5f5f7;
  border: 4rpx dashed #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-avatar-add {
  font-size: 64rpx;
  color: #ccc;
}

.login-avatar-edit {
  font-size: 22rpx;
  color: #F1849B;
  margin-top: 12rpx;
}

.login-nickname-area {
  margin-bottom: 40rpx;
  padding: 0 20rpx;
}

.login-nickname-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

.login-confirm-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #F1849B, #E8607A);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.login-confirm-btn:active {
  opacity: 0.85;
}

.login-skip {
  font-size: 24rpx;
  color: #999;
  padding: 12rpx 0;
}

/* ============================================================
 *  已诊断态 · 完整报告样式（合并自 report.wxss）
 * ============================================================ */

/* 已诊断容器 */
.page-index-diag {
  background: #EEF3F8;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 报告主容器 */
.diag-report {
  display: flex;
  flex-direction: column;
}

/* Tab 导航 */
.dr-tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #DCE5EF;
  position: sticky;
  top: 0;
  z-index: 50;
}
.dr-tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 4rpx;
  position: relative;
}
.dr-tab-label {
  font-size: 24rpx;
  color: #8A8580;
  font-weight: 500;
  white-space: nowrap;
}
.dr-tab-item.active .dr-tab-label {
  color: #1F1A17;
  font-weight: 600;
}
.dr-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #B89968;
  border-radius: 3rpx;
}

/* 报告头部右上角分享胶囊（视龄上方） */
.dr-share-capsule {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  z-index: 5;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  border: none;
  background: linear-gradient(135deg, #B89968 0%, #D4B883 100%);
  color: #1F1A17;
  box-shadow: 0 4rpx 12rpx rgba(184, 153, 104, 0.35);
}
.dr-share-capsule::after { border: none; }
.dr-share-capsule .dr-share-icon {
  font-size: 24rpx;
  font-weight: 700;
}
.dr-share-capsule .dr-share-text {
  font-size: 22rpx;
  letter-spacing: 0.5rpx;
}
.dr-share-capsule.pulsing {
  animation: dr-capsule-pulse 1.8s ease-in-out infinite;
}
.dr-share-capsule.shared {
  background: #F0EDE6;
  color: #9C8A6E;
  box-shadow: none;
  animation: none;
}
@keyframes dr-capsule-pulse {
  0%, 100% {
    transform: scale(1);
    box-shadow: 0 4rpx 12rpx rgba(184, 153, 104, 0.35);
  }
  50% {
    transform: scale(1.04);
    box-shadow: 0 6rpx 18rpx rgba(184, 153, 104, 0.55);
  }
}

/* 报告末尾收尾操作 */
.report-actions {
  margin: 32rpx 32rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.report-actions-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #9C8A6E;
  letter-spacing: 0.5rpx;
}
.report-actions-tip-icon {
  color: #B89968;
  font-size: 22rpx;
}
.report-actions-row {
  display: flex;
  gap: 20rpx;
}
.report-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
  border: none;
  padding: 0;
  margin: 0;
}
.report-action-btn::after { border: none; }
.report-action-btn.save {
  background: #1F1A17;
  color: #fff;
}
.report-action-btn.redo {
  background: #fff;
  color: #1F1A17;
  border: 1rpx solid #DCE5EF;
}
.report-action-btn.locked {
  opacity: 0.85;
}
.report-action-icon {
  font-size: 28rpx;
  font-weight: 700;
}
.report-action-text {
  font-size: 28rpx;
}

/* 综合评分头部 */
.report-header {
  position: relative;
  overflow: hidden;
  margin: 24rpx 32rpx 0;
  border-radius: 28rpx;
}
.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #FFFFFF;
  border: 2rpx solid #DCE5EF;
  z-index: 0;
}
.header-bg::before {
  content: '';
  position: absolute;
  top: -40%; right: -20%;
  width: 320rpx; height: 320rpx;
  background: radial-gradient(circle, rgba(184, 153, 104,0.12) 0%, transparent 70%);
  border-radius: 50%;
}
.header-bg::after {
  content: '';
  position: absolute;
  bottom: -30%; left: -10%;
  width: 280rpx; height: 280rpx;
  background: radial-gradient(circle, rgba(120,150,190,0.12) 0%, transparent 70%);
  border-radius: 50%;
}
.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 36rpx 32rpx 20rpx;
  gap: 28rpx;
}
.avatar-main {
  width: 120rpx; height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(184, 153, 104,0.4);
  box-shadow: 0 6rpx 24rpx rgba(40,60,90,0.12);
  background: #FBF7EF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.avatar-main-img { width: 100%; height: 100%; }
.avatar-main-fallback {
  font-size: 36rpx;
  font-weight: 800;
  color: #B89968;
  letter-spacing: 2rpx;
}
.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  gap: 12rpx;
}
.dr-score-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.dr-score-num-group { display: flex; align-items: baseline; }
.dr-score-big {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
  line-height: 1;
  color: #1F1A17;
  text-shadow: 0 2rpx 12rpx rgba(40,60,90,0.12);
}
.dr-score-suffix {
  font-size: 28rpx;
  color: #B89968;
  margin-left: 4rpx;
  font-weight: 700;
}
.htag-age {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #D4B883 0%, #B89968 50%, #8C6E3A 100%);
  box-shadow: 0 6rpx 18rpx rgba(120,95,50,0.4),
              inset 0 1rpx 0 rgba(255,255,255,0.5),
              inset 0 -1rpx 0 rgba(0,0,0,0.08);
  border: 2rpx solid rgba(255,255,255,0.7);
  flex-shrink: 0;
}
.htag-age-icon {
  font-size: 24rpx;
  color: #FFFBE6;
  line-height: 1;
}
.htag-age-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 2rpx;
  line-height: 1;
}
.dr-percentile {
  position: relative;
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  background:
    linear-gradient(135deg, rgba(212, 184, 131, 0.18) 0%, rgba(212, 184, 131, 0) 60%),
    linear-gradient(180deg, #1A1612 0%, #2A2520 100%);
  border-radius: 999rpx;
  border: 1rpx solid rgba(212, 184, 131, 0.55);
  align-self: flex-start;
  box-shadow:
    0 6rpx 18rpx rgba(20, 16, 12, 0.35),
    inset 0 1rpx 0 rgba(255, 240, 200, 0.12);
}
.dr-percentile::before {
  content: '';
  position: absolute;
  top: 1rpx; left: 1rpx; right: 1rpx;
  height: 50%;
  border-radius: 999rpx 999rpx 0 0;
  background: linear-gradient(180deg, rgba(255, 246, 220, 0.10), rgba(255, 246, 220, 0));
  pointer-events: none;
}
.dr-percentile .percentile-icon {
  font-size: 18rpx;
  color: #D4B883;
  margin-right: 8rpx;
  letter-spacing: 0;
}
.dr-percentile .percentile-text {
  font-size: 22rpx;
  color: #E6DCC8;
  font-weight: 500;
  letter-spacing: 1rpx;
}
.dr-percentile .percentile-num {
  font-size: 26rpx;
  font-weight: 800;
  margin: 0 4rpx;
  background: linear-gradient(135deg, #F5E6B8 0%, #D4B883 50%, #B89968 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: 0.5rpx;
}
/* 卡片顶部标题样式 */
.dr-percentile-title {
  z-index: 2;
  display: flex;
  width: fit-content;
  margin: 24rpx auto 0;
  padding: 12rpx 32rpx;
}
.dr-percentile-title .percentile-text {
  font-size: 24rpx;
  letter-spacing: 1.5rpx;
}
.dr-percentile-title .percentile-num {
  font-size: 30rpx;
}
.dr-percentile-title .percentile-icon {
  font-size: 20rpx;
}
.header-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}
.htag {
  font-size: 22rpx;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  background: #F5EFE3;
  color: #6B5326;
  font-weight: 600;
  border: 1rpx solid rgba(184, 153, 104,0.3);
  box-shadow: 0 2rpx 6rpx rgba(40,60,90,0.05);
  flex-shrink: 0;
  white-space: nowrap;
}
.header-summary {
  position: relative;
  z-index: 1;
  margin: 0 32rpx 28rpx;
  padding: 16rpx 20rpx;
  background: #F8FAFC;
  border-radius: 16rpx;
  box-sizing: border-box;
  border: 1rpx solid #DCE5EF;
}
.summary-text {
  font-size: 22rpx;
  color: #5C5048;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.info-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #F9E6EC;
  color: #D46A8A;
}
.info-tag.accent { background: #F0EBF5; color: #7B5EA7; }
.info-tag.accent2 { background: #EBF5F0; color: #5EA77B; }

/* 模块卡片 */
.module-content {
  padding: 24rpx 32rpx;
}
.section-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 24rpx rgba(40,60,90,0.06);
  border: 1rpx solid #DCE5EF;
}
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1F1A17;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #B89968;
}
.tags-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 28rpx;
}
.sub-section {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F5F0EB;
}
.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #555;
  margin-bottom: 16rpx;
}
.sub-title.warn { color: #E74C3C; }

/* 雷达图 */
.radar-wrap {
  width: 100%;
  display: flex;
  justify-content: center;
  margin: 16rpx 0;
}
.radar-canvas { width: 560rpx; height: 400rpx; }

/* 三庭五眼 */
.proportion-bar {
  display: flex;
  border-radius: 12rpx;
  overflow: hidden;
  height: 64rpx;
  margin-bottom: 16rpx;
}
.prop-segment {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.prop-segment.upper { background: #F5ECD7; }
.prop-segment.middle { background: #F0EBE5; }
.prop-segment.lower { background: #E8E5E0; }
.prop-label { font-size: 20rpx; color: #999; }
.prop-val { font-size: 22rpx; font-weight: 600; color: #666; }

.insight-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  margin-top: 8rpx;
}
.body-text { font-size: 26rpx; color: #555; line-height: 1.8; }

/* 五官评分 */
.dr-score-list { display: flex; flex-direction: column; gap: 16rpx; }
.dr-feature-row { display: flex; align-items: center; gap: 16rpx; }
.dr-feature-name { font-size: 24rpx; color: #666; width: 80rpx; flex-shrink: 0; }
.dr-bar-wrap { flex: 1; }
.dr-bar-bg {
  height: 16rpx;
  background: #F5F0EB;
  border-radius: 8rpx;
  overflow: hidden;
}
.dr-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #B89968, #D4B883);
  border-radius: 8rpx;
}
.dr-feature-val {
  font-size: 24rpx;
  color: #B89968;
  font-weight: 600;
  width: 40rpx;
  text-align: right;
}

/* 属性网格 */
.attr-grid { display: flex; gap: 20rpx; }
.attr-item {
  flex: 1;
  background: #FAFAF5;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}
.attr-label { font-size: 22rpx; color: #999; display: block; }
.attr-val {
  font-size: 30rpx;
  font-weight: 700;
  color: #B89968;
  display: block;
  margin-top: 4rpx;
}

/* 色卡 */
.color-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.color-item { width: calc(25% - 12rpx); text-align: center; }
.color-swatch {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 16rpx;
  margin-bottom: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}
.color-swatch.hair { background: linear-gradient(135deg, #4A3728, #8B6914, #2C1810); }
.color-name { font-size: 20rpx; color: #333; font-weight: 600; display: block; }
.color-usage {
  font-size: 18rpx;
  color: #999;
  display: block;
  margin-top: 2rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.color-grid.warn .color-swatch { border: 3rpx solid #FFCDD2; }

/* 调色盘 */
.palette-group { display: flex; flex-direction: column; gap: 12rpx; }
.palette-row { display: flex; align-items: center; gap: 16rpx; }
.palette-label { font-size: 24rpx; color: #999; width: 80rpx; flex-shrink: 0; }
.palette-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.palette-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #F5F0EB;
  color: #B89968;
}

/* 穿搭建议 */
.advice-list { display: flex; flex-direction: column; gap: 12rpx; }
.advice-item { display: flex; gap: 12rpx; align-items: center; }
.advice-label {
  font-size: 24rpx;
  color: #B89968;
  font-weight: 600;
  flex-shrink: 0;
  width: 64rpx;
}
.advice-text { font-size: 24rpx; color: #555; line-height: 1.6; }
.advice-thumb {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #F9E6EC;
  box-shadow: 0 2rpx 6rpx rgba(184, 153, 104,0.15);
}

/* 发型 */
.hair-list { display: flex; flex-direction: column; gap: 16rpx; }
.hair-card {
  display: flex;
  gap: 16rpx;
  background: #FAFAF5;
  border-radius: 16rpx;
  padding: 20rpx;
}
.hair-rank {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #B89968, #D4B883);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.hair-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #F5E6E9;
}
.hair-info { flex: 1; min-width: 0; }
.hair-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.hair-name { font-size: 28rpx; font-weight: 600; color: #333; }
.hair-score { font-size: 24rpx; color: #B89968; font-weight: 600; }
.hair-detail { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }
.hair-reason { font-size: 24rpx; color: #666; display: block; margin-top: 8rpx; line-height: 1.5; }

/* 避雷 */
.avoid-list { display: flex; flex-direction: column; gap: 12rpx; }
.avoid-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: #FFF5F5;
  border-radius: 12rpx;
  padding: 16rpx;
}
.avoid-x { color: #E74C3C; font-weight: 700; font-size: 28rpx; flex-shrink: 0; }
.avoid-info { flex: 1; }
.avoid-name { font-size: 26rpx; font-weight: 600; color: #E74C3C; display: block; }
.avoid-reason { font-size: 22rpx; color: #999; display: block; margin-top: 4rpx; }

/* 妆容 */
.makeup-grid { display: flex; flex-direction: column; gap: 12rpx; }
.makeup-item { display: flex; gap: 16rpx; align-items: center; }
.makeup-label {
  font-size: 24rpx;
  color: #B89968;
  font-weight: 600;
  flex-shrink: 0;
  width: 72rpx;
}
.makeup-thumb {
  width: 88rpx;
  height: 88rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #FCEDE3;
}
.makeup-text { font-size: 24rpx; color: #555; line-height: 1.6; }

/* 优化优先级 */
.optimize-list { display: flex; flex-direction: column; gap: 16rpx; }
.optimize-item { display: flex; gap: 16rpx; }
.optimize-priority {
  width: 48rpx; height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.optimize-priority.high { background: #E74C3C; }
.optimize-priority.mid { background: #F39C12; }
.optimize-priority.low { background: #95A5A6; }
.optimize-info { flex: 1; min-width: 0; }
.optimize-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.optimize-area { font-size: 28rpx; font-weight: 600; color: #333; }
.optimize-timeline {
  font-size: 22rpx;
  color: #B89968;
  background: #FAFAF5;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}
.optimize-problem { font-size: 24rpx; color: #E74C3C; display: block; margin-top: 4rpx; }
.optimize-plan { font-size: 24rpx; color: #555; display: block; margin-top: 4rpx; line-height: 1.5; }

/* 路线图 */
.roadmap { display: flex; flex-direction: column; }
.roadmap-item { display: flex; position: relative; padding-bottom: 24rpx; }
.roadmap-item:last-child { padding-bottom: 0; }
.roadmap-dot {
  width: 20rpx; height: 20rpx;
  border-radius: 50%;
  background: #B89968;
  flex-shrink: 0;
  margin-top: 8rpx;
  margin-right: 16rpx;
  position: relative;
  z-index: 1;
}
.roadmap-line {
  position: absolute;
  left: 9rpx;
  top: 28rpx;
  width: 2rpx;
  height: calc(100% - 28rpx);
  background: #F0E5C8;
}
.roadmap-content { flex: 1; }
.roadmap-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.roadmap-thumb {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #F9E6EC;
  border: 2rpx solid #fff;
}
.roadmap-month { font-size: 26rpx; font-weight: 600; color: #B89968; display: block; }
.roadmap-desc { font-size: 24rpx; color: #555; display: block; margin-top: 4rpx; line-height: 1.6; }

/* 洞察卡 */
.insight-card {
  margin-top: 24rpx;
  background: linear-gradient(135deg, #FAFAF5, #F5F0EB);
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  gap: 12rpx;
  align-items: flex-start;
}
.insight-icon { font-size: 28rpx; color: #B89968; flex-shrink: 0; }
.insight-content { font-size: 26rpx; color: #666; line-height: 1.6; }

/* 明星相似 */
.celeb-subtitle {
  font-size: 24rpx;
  color: #999;
  margin: -8rpx 0 24rpx;
}
.celeb-list { display: flex; flex-direction: column; gap: 24rpx; }
.celeb-item {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  padding: 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #fffaf6 0%, #fff5ec 100%);
  border: 1rpx solid rgba(212,184,122,0.18);
}
.celeb-rank {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #b8a888, #8e7e5c);
  box-shadow: 0 2rpx 8rpx rgba(140,110,60,0.18);
}
.celeb-rank.rank-1 {
  background: linear-gradient(135deg, #ffd56b, #d4a23a);
  box-shadow: 0 4rpx 12rpx rgba(212,162,58,0.35);
}
.celeb-rank.rank-2 { background: linear-gradient(135deg, #d8d8d8, #a8a8a8); }
.celeb-rank.rank-3 { background: linear-gradient(135deg, #e0a878, #b07840); }
.celeb-rank-text { line-height: 1; }
.celeb-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}
.celeb-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}
.celeb-name { font-size: 32rpx; font-weight: 600; color: #2c2418; }
.celeb-similarity-badge {
  display: inline-flex;
  align-items: baseline;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(212,184,122,0.12);
}
.celeb-similarity-num { font-size: 30rpx; font-weight: 700; color: #b8924a; }
.celeb-similarity-unit { font-size: 20rpx; color: #b8924a; margin-left: 2rpx; }
.celeb-bar-wrap {
  width: 100%;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(212,184,122,0.15);
  overflow: hidden;
  margin-bottom: 12rpx;
}
.celeb-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #d4b87a, #b8924a);
}
.celeb-match { font-size: 24rpx; color: #6b5a3e; line-height: 1.5; }
.celeb-match-label {
  display: inline-block;
  padding: 2rpx 10rpx;
  margin-right: 8rpx;
  border-radius: 6rpx;
  background: rgba(212,184,122,0.18);
  font-size: 20rpx;
  color: #8e7e5c;
}
.celeb-match-text { color: #6b5a3e; }
.celeb-empty {
  padding: 40rpx 20rpx;
  text-align: center;
  color: #999;
}
.celeb-empty-icon {
  display: block;
  font-size: 48rpx;
  color: #d4b87a;
  margin-bottom: 12rpx;
}
.celeb-empty-text { font-size: 26rpx; color: #888; line-height: 1.6; }

/* 底部操作栏 */
.share-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  z-index: 90;
}
.share-bar button {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}
.share-btn {
  background: #B89968;
  color: #ffffff;
  flex-direction: row;
  gap: 6rpx;
}
.share-btn.shared { background: #E8F5E9; color: #4CAF50; }
.share-icon { font-size: 28rpx; }
.save-all-btn { background: #1F1A17; color: #fff; }
.rediagnose-btn {
  background: #FAFAF5;
  color: #666;
  flex: 0.8;
}
.save-all-btn.locked,
.rediagnose-btn.locked {
  opacity: 0.4;
}
.safe-bottom { padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); }

.report-card-canvas {
  position: fixed;
  left: -9999rpx;
  width: 680rpx;
  height: 1700rpx;
}

/* 浮动「蜕变」FAB */
.beauty-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(60rpx + env(safe-area-inset-bottom));
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #E8D098 0%, #B89968 60%, #8C6E3A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(184, 153, 104, 0.45),
              0 0 0 6rpx rgba(255, 255, 255, 0.85);
  z-index: 99;
}
.beauty-fab-hover {
  transform: scale(0.94);
}
.beauty-fab-text {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

/* 颜值百分位徽章 - 深墨配深金 */
.score-percentile {
  display: inline-flex;
  align-items: center;
  margin-top: 0;
  padding: 6rpx 16rpx;
  background: #1F1A17;
  border-radius: 999rpx;
  border: 1rpx solid rgba(184, 153, 104, 0.5);
  align-self: flex-start;
}
.score-percentile .percentile-icon {
  font-size: 18rpx;
  color: #D4B883;
  margin-right: 6rpx;
}
.score-percentile .percentile-text {
  font-size: 22rpx;
  color: #E6DCC8;
  letter-spacing: 0.5rpx;
}
.score-percentile .percentile-num {
  font-size: 24rpx;
  font-weight: 700;
  color: #D4B883;
  margin: 0 2rpx;
}

/* 未诊断态：底部能力标签横向无缝轮播（双排反向） */
.feature-marquee {
  margin: -150rpx 0 40rpx;
  padding: 16rpx 0;
  overflow: hidden;
  position: relative;
  -webkit-mask-image: linear-gradient(to right, transparent 0, #000 8%, #000 92%, transparent 100%);
  mask-image: linear-gradient(to right, transparent 0, #000 8%, #000 92%, transparent 100%);
}
.feature-marquee-row {
  overflow: hidden;
  padding: 8rpx 0;
}
.feature-marquee-track {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: max-content;
  animation: feature-marquee-scroll 60s linear infinite;
}
.feature-marquee-track-rev {
  animation: feature-marquee-scroll-rev 72s linear infinite;
}
.feature-chip {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(235, 244, 252, 0.92) 0%, rgba(214, 230, 245, 0.88) 100%);
  border: 1rpx solid rgba(120, 160, 200, 0.22);
  box-shadow: 0 2rpx 12rpx rgba(90, 130, 180, 0.08), inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(8rpx);
}
.feature-chip-dot {
  font-size: 18rpx;
  color: #7aa6cf;
  margin-right: 10rpx;
  letter-spacing: 0;
}
.feature-chip-text {
  font-size: 24rpx;
  color: #3d5a7a;
  letter-spacing: 2rpx;
  font-weight: 500;
  white-space: nowrap;
}
@keyframes feature-marquee-scroll {
  from { transform: translateX(0); }
  to { transform: translateX(-50%); }
}
@keyframes feature-marquee-scroll-rev {
  from { transform: translateX(-50%); }
  to { transform: translateX(0); }
}

/* 顶部后台任务进度条 */
.task-bar {
  position: sticky;
  top: 16rpx;
  z-index: 1000;
  margin: 16rpx 24rpx 0;
  background: #FFFFFF;
  border: 1rpx solid #DCE5EF;
  border-radius: 18rpx;
  padding: 18rpx 24rpx 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(40, 60, 90, 0.08);
}
.task-bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.task-bar-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2E7BD6;
  flex-shrink: 0;
  box-shadow: 0 0 0 4rpx rgba(46, 123, 214, 0.18);
  animation: task-bar-pulse 1.4s ease-in-out infinite;
}
.task-bar-label {
  font-size: 24rpx;
  color: #1F1A17;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  flex: 1;
}
.task-bar-progress {
  font-size: 22rpx;
  color: #2E7BD6;
  font-weight: 600;
  font-family: 'Menlo', 'Courier New', monospace;
  flex-shrink: 0;
}
.task-bar-cta {
  font-size: 22rpx;
  color: #2E7BD6;
  font-weight: 600;
  flex-shrink: 0;
}
.task-bar-cta-error {
  color: #C0392B;
}
.task-bar-track {
  width: 100%;
  height: 6rpx;
  background: #EEF3F8;
  border-radius: 3rpx;
  overflow: hidden;
}
.task-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #2E7BD6, #6BB6FF);
  border-radius: 3rpx;
  transition: width 0.4s ease;
}
.task-bar-done .task-bar-dot {
  background: #4CAF50;
  box-shadow: 0 0 0 4rpx rgba(76, 175, 80, 0.18);
  animation: none;
}
.task-bar-done .task-bar-fill {
  background: linear-gradient(90deg, #4CAF50, #81C784);
}
.task-bar-done .task-bar-cta {
  color: #2E7D32;
}
.task-bar-error .task-bar-dot {
  background: #E74C3C;
  box-shadow: 0 0 0 4rpx rgba(231, 76, 60, 0.18);
  animation: none;
}
.task-bar-error .task-bar-fill {
  background: #E74C3C;
}
@keyframes task-bar-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}

/* ==================== 第一印象 · 魅力六边形 ==================== */
.impression-card {
  background: #FFFFFF;
  border: 1rpx solid #DCE5EF;
}
.impression-index {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 12rpx;
  background: linear-gradient(135deg, #F8FAFD 0%, #EEF3F8 100%);
  border: 1rpx solid #DCE5EF;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
}
.impression-index::before {
  content: '';
  position: absolute;
  top: -40%; right: -20%;
  width: 320rpx; height: 320rpx;
  background: radial-gradient(circle, rgba(184,153,104,0.14) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}
.impression-index::after {
  content: '';
  position: absolute;
  bottom: -30%; left: -10%;
  width: 280rpx; height: 280rpx;
  background: radial-gradient(circle, rgba(120,150,190,0.14) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}
.impr-idx-ring {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background:
    conic-gradient(#B89968 0deg 300deg, #E5DCC4 300deg 360deg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  box-shadow: 0 6rpx 18rpx rgba(184,153,104,0.18);
}
.impr-idx-ring::after {
  content: '';
  position: absolute;
  inset: 8rpx;
  border-radius: 50%;
  background: #FFFFFF;
}
.impr-idx-num-wrap {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}
.impr-idx-num {
  font-size: 64rpx;
  font-weight: 800;
  color: #1F1A17;
  letter-spacing: -2rpx;
  line-height: 1;
}
.impr-idx-unit {
  font-size: 22rpx;
  color: #B0A498;
  font-weight: 600;
}
.impr-idx-label {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  color: #8C7A5C;
  margin-top: 6rpx;
  letter-spacing: 2rpx;
}
.impr-idx-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  position: relative;
  z-index: 1;
}
.impr-idx-tag {
  font-size: 20rpx;
  color: #B89968;
  letter-spacing: 3rpx;
  font-weight: 700;
}
.impr-idx-sub {
  font-size: 24rpx;
  color: #5C5048;
  line-height: 1.5;
}
.impr-idx-percentile {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  margin-top: 6rpx;
  padding: 8rpx 16rpx;
  background: #F5EFE3;
  border: 1rpx solid #E5DCC4;
  border-radius: 100rpx;
  font-size: 22rpx;
  color: #6B5326;
  align-self: flex-start;
}
.impr-idx-percent-icon { font-size: 18rpx; color: #B89968; }
.impr-idx-percent-num { color: #1F1A17; font-weight: 700; }

/* 第一印象人格标签（9 型） · 醒目 hero 块 */
.impression-persona {
  position: relative;
  margin: 24rpx 0 4rpx;
  padding: 32rpx 28rpx 28rpx;
  border-radius: 24rpx;
  background:
    radial-gradient(120% 100% at 0% 0%, rgba(212,184,131,0.18) 0%, transparent 60%),
    linear-gradient(135deg, #1F1A17 0%, #2C2620 100%);
  color: #FFFFFF;
  overflow: hidden;
  box-shadow: 0 10rpx 32rpx rgba(31,26,23,0.28);
}
.impression-persona::before {
  content: '';
  position: absolute;
  top: -60rpx; right: -60rpx;
  width: 280rpx; height: 280rpx;
  background: radial-gradient(circle, rgba(212,184,131,0.35) 0%, transparent 70%);
  pointer-events: none;
}
.impression-persona::after {
  content: '';
  position: absolute;
  inset: 4rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(212,184,131,0.28);
  pointer-events: none;
}
.persona-badge {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}
.persona-badge-no {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #1F1A17;
  background: linear-gradient(90deg, #E5C988, #B89968);
  padding: 6rpx 14rpx;
  border-radius: 100rpx;
}
.persona-badge-label {
  font-size: 22rpx;
  color: rgba(229,201,136,0.85);
  letter-spacing: 4rpx;
}
.persona-main {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.persona-emoji {
  font-size: 100rpx;
  line-height: 1;
  flex-shrink: 0;
  filter: drop-shadow(0 4rpx 12rpx rgba(212,184,131,0.4));
}
.persona-photo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: rgba(255,255,255,0.5);
  border: 3rpx solid rgba(212,184,131,0.6);
  box-shadow: 0 4rpx 16rpx rgba(212,184,131,0.4), inset 0 0 0 2rpx rgba(255,255,255,0.85);
  object-fit: cover;
}
.persona-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}
.persona-name-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
}
.persona-animal {
  font-size: 64rpx;
  font-weight: 800;
  color: #FFE7B8;
  letter-spacing: 4rpx;
  line-height: 1.1;
  text-shadow: 0 4rpx 16rpx rgba(212,184,131,0.4);
}
.persona-divider {
  font-size: 32rpx;
  color: rgba(229,201,136,0.6);
  margin: 0 4rpx;
}
.persona-style {
  font-size: 30rpx;
  font-weight: 600;
  color: #E5C988;
  letter-spacing: 1rpx;
}
.persona-tagline {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  line-height: 1.6;
}
.persona-traits {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(212,184,131,0.18);
}
.persona-trait {
  font-size: 22rpx;
  color: #E5C988;
  background: rgba(212,184,131,0.14);
  border: 1rpx solid rgba(212,184,131,0.32);
  padding: 6rpx 18rpx;
  border-radius: 100rpx;
  letter-spacing: 0.5rpx;
}

.impression-card .section-title {
  border-left-color: #B89968;
}
.impression-card .radar-wrap {
  margin: 8rpx 0 0;
}
.impr-feat-name {
  width: 110rpx;
  color: #5C5048;
  font-weight: 600;
}
.impr-bar-fill {
  background: linear-gradient(90deg, #B89968, #D4B883);
}
.impr-feat-val {
  color: #B89968;
}

.impression-desc {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.impr-desc-item {
  padding: 18rpx 22rpx;
  background: #FAFAF5;
  border-left: 4rpx solid #B89968;
  border-radius: 12rpx;
}
.impr-desc-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6rpx;
}
.impr-desc-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1F1A17;
}
.impr-desc-score {
  font-size: 22rpx;
  font-weight: 700;
  color: #B89968;
}
.impr-desc-sub {
  display: block;
  font-size: 22rpx;
  color: #B0A498;
  line-height: 1.4;
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
}
.impr-desc-text {
  display: block;
  font-size: 26rpx;
  color: #2C2620;
  line-height: 1.7;
  font-weight: 500;
}
