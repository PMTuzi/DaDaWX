/* pages/index/index.wxss */
.page-index {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #FAFAF5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 顶部品牌区 */
.header {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 40rpx 32rpx 0;
  background: #FAFAF5;
  overflow: visible;
  position: relative;
  z-index: 10;
}

.brand-area {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 20rpx;
  margin-left: -20rpx;
  gap: 16rpx;
}

.brand-logo {
  width: 350rpx;
  height: 350rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 11;
  margin-left: -20rpx;
  margin-top: 30rpx;
}

.brand-text {
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 100;
  margin-left: -50rpx;
}

.header-diagnosed {
  padding-top: 48rpx;
  padding-bottom: 28rpx;
}

.brand-area-small {
  flex: 0;
  margin-bottom: 20rpx;
}

.header-diagnosed .brand-text {
  margin-top: 20rpx;
}

.header-diagnosed .report-summary {
  margin-top: -104rpx;
  margin-bottom: 20rpx;
}

.header-diagnosed + .action-area {
  margin-top: -20rpx;
}

.header-diagnosed + .action-area + .banner-ad {
  margin-top: 24rpx;
}

.logo {
  font-size: 48rpx;
  font-weight: 800;
  color: #333;
  letter-spacing: 6rpx;
  margin-bottom: 4rpx;
}

.slogan {
  font-size: 24rpx;
  color: #8B7355;
  letter-spacing: 2rpx;
}

/* 报告摘要卡片 */
.report-summary {
  background: #fff;
  border: 1rpx solid #F0EBE5;
  border-radius: 20rpx;
  padding: 20rpx 24rpx 18rpx;
  margin-top: -104rpx;
  position: relative;
  z-index: 100;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s, box-shadow 0.15s;
}

.report-summary-hover {
  transform: scale(0.98);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.summary-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.summary-title-icon {
  color: #B76E79;
  font-size: 26rpx;
}

.summary-title {
  font-size: 26rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #B76E79 0%, #C38D9E 50%, #E8A87C 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: 2rpx;
  text-shadow: 0 1rpx 2rpx rgba(183, 110, 121, 0.15);
}

.summary-arrow {
  font-size: 28rpx;
  color: #C8A97E;
  font-weight: 300;
}

.summary-tap-hint {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: linear-gradient(135deg, rgba(200, 169, 126, 0.22), rgba(214, 158, 148, 0.22));
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
}

.summary-tap-text {
  font-size: 22rpx;
  color: #B08070;
  font-weight: 600;
}

.summary-tap-hint .summary-arrow {
  color: #B08070;
}

.summary-body {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.score-circle {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #FAFAF5;
}

.score-num {
  font-size: 38rpx;
  font-weight: 800;
  color: #333;
  line-height: 1;
}

.score-unit {
  font-size: 18rpx;
  color: #999;
}

.score-detail {
  flex: 1;
  min-width: 0;
}

.score-level {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.score-level-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 10rpx;
}

.score-level-row .score-level {
  margin-bottom: 0;
}

/* 视觉年龄核心 chip */
.age-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #B76E79 0%, #8B4F58 100%);
  box-shadow: 0 4rpx 12rpx rgba(183, 110, 121, 0.35), inset 0 1rpx 0 rgba(255, 255, 255, 0.25);
}

.age-chip-icon {
  font-size: 20rpx;
  color: #FFE6C7;
  line-height: 1;
}

.age-chip-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
  line-height: 1;
}

.score-tags {
  display: flex;
  flex-wrap: nowrap;
  overflow: hidden;
  gap: 8rpx;
}

.summary-footer {
  margin-top: 14rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #F0EBE5;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.summary-conclusion {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 1.5;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.summary-date {
  font-size: 20rpx;
  color: #bbb;
  flex-shrink: 0;
  margin-top: 4rpx;
}

/* 核心入口 */
.action-area {
  flex-shrink: 0;
  padding: 0 32rpx;
  margin-top: 28rpx;
  position: relative;
  z-index: 10;
}

.diagnose-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 40rpx;
  gap: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(249, 184, 201, 0.35);
  background: #F1849B;
  position: relative;
  overflow: hidden;
}

/* 闪烁星星 */
.btn-sparkle .sparkle {
  position: absolute;
  color: rgba(255, 255, 255, 0.9);
  font-size: 24rpx;
  pointer-events: none;
  animation: sparkle 2s ease-in-out infinite;
}

.sparkle-1 {
  top: 24rpx;
  left: 28rpx;
  font-size: 42rpx;
  animation-delay: 0s;
}

.sparkle-2 {
  top: 28rpx;
  right: 44rpx;
  font-size: 26rpx;
  animation-delay: 0.5s;
}

.sparkle-3 {
  bottom: 24rpx;
  left: 84rpx;
  font-size: 30rpx;
  animation-delay: 1s;
}

.sparkle-4 {
  bottom: 26rpx;
  right: 24rpx;
  font-size: 36rpx;
  animation-delay: 1.5s;
}

@keyframes sparkle {
  0%, 100% { opacity: 0; transform: scale(0.5); }
  50% { opacity: 1; transform: scale(1.2); }
}

.btn-icon {
  font-size: 56rpx;
  flex-shrink: 0;
  color: #fff;
}

.btn-text {
  display: flex;
  flex-direction: column;
  transform: translateX(-30rpx);
}

/* 已诊断态：穿搭按钮内有图标，避免图标与文字重叠 */
.diagnose-btn .btn-icon {
  transform: translateX(-10rpx);
}
.diagnose-btn .btn-icon + .btn-text {
  transform: translateX(10rpx);
}

/* 未登录提示用：右侧手指点击矢量图标（SVG data URI 作 CSS 背景，纯静态） */
.btn-tap-hint {
  position: absolute;
  right: 142rpx;
  top: 50%;
  width: 60rpx;
  height: 60rpx;
  transform: translateY(-50%) rotate(-15deg);
  pointer-events: none;
  background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%23ffffff' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'><path d='M9 11V6.5a2 2 0 1 1 4 0V12'/><path d='M13 10.5a2 2 0 1 1 4 0V13'/><path d='M17 11.5a2 2 0 1 1 4 0V16a6 6 0 0 1-6 6h-2a6 6 0 0 1-5.2-3l-3.3-5.7a2 2 0 0 1 3.46-2L9 14'/></svg>");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.btn-main {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.btn-sub {
  font-size: 22rpx;
  opacity: 0.85;
  margin-top: 4rpx;
  color: #fff;
}

/* 实时动态轮播 */
.live-ticker {
  margin-top: 16rpx;
  height: 48rpx;
  overflow: hidden;
  border-radius: 24rpx;
  background: rgba(200, 169, 126, 0.08);
}

.ticker-swiper {
  height: 48rpx;
}

.ticker-text {
  font-size: 22rpx;
  color: #8B7355;
  line-height: 48rpx;
  padding: 0 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 功能简介 */
.feature-intro {
  flex-shrink: 0;
  padding: 20rpx 32rpx 0;
  margin-top: -125rpx;
  position: relative;
  z-index: 20;
}

.feature-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F0EBE5;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.step-icon {
  font-size: 48rpx;
  color: #C8A97E;
}

.step-text {
  font-size: 24rpx;
  color: #8B7355;
  font-weight: 500;
}

.step-arrow {
  font-size: 32rpx;
  color: #C8A97E;
  margin-top: -20rpx;
}

/* 穿搭决策入口 */
.outfit-entry {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 2rpx 32rpx 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid #F0EBE5;
}

.outfit-entry:active {
  transform: scale(0.98);
  transition: transform 0.15s;
}

.outfit-entry-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.outfit-entry-icon {
  font-size: 56rpx;
  color: #F67C9F;
  flex-shrink: 0;
}

.outfit-entry-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.outfit-entry-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.outfit-entry-desc {
  font-size: 24rpx;
  color: #999;
}

.outfit-entry-arrow {
  font-size: 36rpx;
  color: #F67C9F;
}

/* Banner广告 */
.banner-ad {
  flex-shrink: 0;
  margin: 24rpx 32rpx 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #F5F0EB, #EDE5DA);
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-placeholder-text {
  font-size: 28rpx;
  color: rgba(139, 115, 85, 0.25);
  letter-spacing: 8rpx;
}

/* 标签覆盖色 */
.tag-warm {
  background: linear-gradient(135deg, #FFF4E6 0%, #FCE7EC 100%);
  color: #C97B82;
  border: 1rpx solid rgba(232, 168, 124, 0.35);
  font-weight: 600;
  padding: 5rpx 16rpx;
  font-size: 22rpx;
  margin: 0;
  box-shadow: 0 2rpx 6rpx rgba(232, 168, 124, 0.15);
}

/* ============ 登录确认弹窗 ============ */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-modal {
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 56rpx 48rpx 40rpx;
  text-align: center;
  animation: modalIn 0.3s ease;
}

@keyframes modalIn {
  from { transform: scale(0.85); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.login-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}

.login-modal-desc {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 48rpx;
}

.login-avatar-area {
  margin-bottom: 36rpx;
}

.login-avatar-btn {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: normal;
}

.login-avatar-btn::after {
  border: none;
}

.login-avatar-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #F1849B;
}

.login-avatar-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f5f5f7;
  border: 4rpx dashed #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-avatar-add {
  font-size: 64rpx;
  color: #ccc;
}

.login-avatar-edit {
  font-size: 22rpx;
  color: #F1849B;
  margin-top: 12rpx;
}

.login-nickname-area {
  margin-bottom: 40rpx;
  padding: 0 20rpx;
}

.login-nickname-input {
  width: 100%;
  height: 80rpx;
  background: #f5f5f7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  text-align: center;
}

.login-confirm-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #F1849B, #E8607A);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.login-confirm-btn:active {
  opacity: 0.85;
}

.login-skip {
  font-size: 24rpx;
  color: #999;
  padding: 12rpx 0;
}
