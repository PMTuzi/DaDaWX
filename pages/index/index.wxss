/* pages/index/index.wxss */
.page-index {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f5f7;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.header {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 60rpx 32rpx 40rpx;
  background: linear-gradient(180deg, #1a1a2e, #2d2d4a);
}

.brand-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: center;
  margin-bottom: 24rpx;
}

.header-diagnosed {
  padding-top: 32rpx;
  padding-bottom: 28rpx;
}

.brand-area-small {
  flex: 0;
  margin-bottom: 20rpx;
  margin-top: 40rpx;
}

.header-diagnosed .report-summary {
  margin-bottom: 20rpx;
}

.logo {
  font-size: 56rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
}

.slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

.report-summary {
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-top: 20rpx;
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.summary-date {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.summary-score {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.score-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.score-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  line-height: 1;
}

.score-unit {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.6);
}

.score-info {
  flex: 1;
}

.score-level {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.summary-advantage {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 16rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.action-area {
  flex-shrink: 0;
  padding: 0 32rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.diagnose-btn {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx;
  gap: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(232, 168, 124, 0.35);
}


.btn-icon {
  font-size: 56rpx;
  flex-shrink: 0;
}

.btn-text {
  display: flex;
  flex-direction: column;
}

.btn-main {
  font-size: 34rpx;
  font-weight: 700;
}

.btn-sub {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.feature-intro {
  flex-shrink: 0;
  padding: 40rpx 32rpx 0;
}

.feature-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.step-icon {
  font-size: 48rpx;
}

.step-text {
  font-size: 24rpx;
  color: #666666;
  font-weight: 500;
}

.step-arrow {
  font-size: 32rpx;
  color: #cccccc;
  margin-top: -20rpx;
}

.quick-entries {
  display: flex;
  padding: 32rpx 32rpx 0;
  gap: 20rpx;
}

/* 穿搭决策入口 */
.outfit-entry {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 32rpx 32rpx 40rpx;
  padding: 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.outfit-entry-bottom {
  margin-bottom: 120rpx;
}

.outfit-entry:active {
  transform: scale(0.98);
  transition: transform 0.15s;
}

.outfit-entry-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.outfit-entry-icon {
  font-size: 56rpx;
  color: var(--accent);
  flex-shrink: 0;
}

.outfit-entry-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.outfit-entry-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.outfit-entry-desc {
  font-size: 24rpx;
  color: #999;
}

.outfit-entry-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.entry-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.entry-icon {
  font-size: 44rpx;
}

.entry-name {
  font-size: 22rpx;
  color: #666666;
  font-weight: 500;
}

.cases-section {
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
  color: #1a1a2e;
}

.case-swiper {
  height: 240rpx;
}

.case-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin: 0 8rpx;
  padding: 28rpx;
}

.case-avatar {
  font-size: 80rpx;
  flex-shrink: 0;
}

.case-info {
  flex: 1;
}

.case-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a2e;
  margin-right: 16rpx;
}

.case-score {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin: 8rpx 0;
}

.case-score-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #e8a87c;
}

.case-score-label {
  font-size: 22rpx;
  color: #999999;
}

/* Banner广告 */
.banner-ad {
  flex-shrink: 0;
  margin: 24rpx 32rpx 40rpx;
  border-radius: 20rpx;
  overflow: hidden;
  height: 240rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f0e6dc, #e8ddd4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner-placeholder-text {
  font-size: 28rpx;
  color: rgba(26, 26, 46, 0.25);
  letter-spacing: 8rpx;
}
