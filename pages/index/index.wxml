<!--pages/index/index.wxml-->
<wxs module="util">
  function cleanAge(s) {
    if (!s) return '';
    var t = s + '';
    while (t.length >= 2 && t.substring(0, 2) === '视龄') {
      t = t.substring(2);
      if (t.length > 0 && t.substring(0, 1) === '·') t = t.substring(1);
    }
    return '视龄·' + t;
  }
  module.exports = { cleanAge: cleanAge };
</wxs>
<view class="page-index">
  <!-- 顶部品牌区 -->
  <view class="header {{hasReport ? 'header-diagnosed' : ''}}">
    <view class="brand-area {{hasReport ? 'brand-area-small' : ''}}">
      <image class="brand-logo" src="/images/logo.png" mode="aspectFit"></image>
      <view class="brand-text">
        <view class="logo">美哒 Meeta</view>
        <view class="slogan">{{slogan}}</view>
      </view>
    </view>

    <!-- 如果有最新报告，展示摘要 -->
    <view class="report-summary" wx:if="{{hasReport}}" bindtap="onViewReport" hover-class="report-summary-hover">
      <view class="summary-top">
        <view class="summary-header">
          <view class="summary-title-icon icon icon-chart" style="font-size:24rpx;"></view>
          <text class="summary-title">形象诊断报告</text>
        </view>
        <view class="summary-tap-hint">
          <text class="summary-tap-text">查看详情</text>
          <text class="summary-arrow">›</text>
        </view>
      </view>
      <view class="summary-body">
        <view class="score-circle" style="border-color: {{scoreLevel.color}}">
          <text class="score-num">{{latestReport.basic.overallScore}}</text>
          <text class="score-unit">/10</text>
        </view>
        <view class="score-detail">
          <view class="score-level-row">
            <view class="score-level" style="color: {{scoreLevel.color}}">{{scoreLevel.text}}</view>
            <block wx:for="{{latestReport.basic.tags}}" wx:key="*this" wx:for-item="t" wx:for-index="i">
              <view class="age-chip" wx:if="{{(t && t.indexOf('视龄') === 0) || i === latestReport.basic.tags.length - 1}}">
                <text class="age-chip-icon">✦</text>
                <text class="age-chip-text">{{util.cleanAge(t)}}</text>
              </view>
            </block>
          </view>
          <view class="score-tags">
            <block wx:for="{{latestReport.basic.tags}}" wx:key="*this" wx:for-item="t" wx:for-index="i">
              <text class="tag tag-warm" wx:if="{{t && t.indexOf('视龄') !== 0 && i !== latestReport.basic.tags.length - 1}}">{{t}}</text>
            </block>
          </view>
        </view>
      </view>
      <view class="summary-footer">
        <text class="summary-conclusion">{{latestReport.modules.optimize.coreConclusion || latestReport.summary.coreConclusion || latestReport.basic.advantages}}</text>
        <text class="summary-date">{{latestReport.createTime}}</text>
      </view>
    </view>
  </view>

  <!-- 功能简介（紧跟品牌区） -->
  <view class="feature-intro" wx:if="{{!hasReport}}">
    <view class="feature-steps">
      <view class="step">
        <view class="step-icon icon icon-camera"></view>
        <text class="step-text">拍照上传</text>
      </view>
      <view class="step-arrow">→</view>
      <view class="step">
        <view class="step-icon icon icon-ai"></view>
        <text class="step-text">AI 分析</text>
      </view>
      <view class="step-arrow">→</view>
      <view class="step">
        <view class="step-icon icon icon-clipboard"></view>
        <text class="step-text">生成报告</text>
      </view>
    </view>
  </view>

  <!-- 核心入口 -->
  <view class="action-area">
    <!-- 未诊断：形象诊断为主按钮 -->
    <block wx:if="{{!hasReport}}">
      <view class="diagnose-btn btn-primary btn-sparkle" bindtap="onStartDiagnose">
        <view class="sparkle sparkle-1">✦</view>
        <view class="sparkle sparkle-2">✧</view>
        <view class="sparkle sparkle-3">✦</view>
        <view class="sparkle sparkle-4">✧</view>
        <view class="btn-text">
          <text class="btn-main">开始「 形象风格分析 」</text>
        </view>
        <view class="btn-tap-hint"></view>
      </view>
    </block>
    <!-- 已诊断：穿搭决策为主按钮 -->
    <block wx:else>
      <view class="diagnose-btn btn-primary btn-sparkle" bindtap="onGoOutfit">
        <view class="sparkle sparkle-1">✦</view>
        <view class="sparkle sparkle-2">✧</view>
        <view class="sparkle sparkle-3">✦</view>
        <view class="sparkle sparkle-4">✧</view>
        <view class="btn-icon icon icon-dress"></view>
        <view class="btn-text">
          <text class="btn-main">开始穿搭「 反种草 」</text>
          <text class="btn-sub">基于风格诊断报告，进行购物决策</text>
        </view>
      </view>
    </block>

    <!-- 实时动态轮播 -->
    <view class="live-ticker">
      <swiper class="ticker-swiper" vertical autoplay circular interval="3000" duration="500">
        <swiper-item wx:for="{{tickerList}}" wx:key="index">
          <text class="ticker-text">{{item}}</text>
        </swiper-item>
      </swiper>
    </view>
  </view>

  <!-- Banner广告 -->
  <view class="banner-ad" bindtap="onBannerTap">
    <image class="banner-image" src="{{bannerImage}}" mode="widthFix" wx:if="{{bannerImage}}"></image>
    <view class="banner-placeholder" wx:else>
      <text class="banner-placeholder-text">广告位</text>
    </view>
  </view>

  <!-- 未诊断：穿搭决策次入口 -->
  <view class="outfit-entry" wx:if="{{!hasReport}}" bindtap="onGoOutfit">
    <view class="outfit-entry-left">
      <view class="outfit-entry-icon icon icon-dress"></view>
      <view class="outfit-entry-info">
        <text class="outfit-entry-title">穿搭决策</text>
        <text class="outfit-entry-desc">上传穿搭单品照片，AI 帮你理性分析</text>
      </view>
    </view>
    <text class="outfit-entry-arrow">→</text>
  </view>

  <!-- 登录确认弹窗 -->
  <view class="login-modal-mask" wx:if="{{showLoginModal}}" bindtap="onCloseLoginModal">
    <view class="login-modal" catchtap="onPreventBubble">
      <view class="login-modal-title">完善个人信息</view>
      <view class="login-modal-desc">点击即可获取微信头像和昵称，也可自行编辑</view>

      <!-- 头像选择 -->
      <view class="login-avatar-area">
        <button class="login-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{loginAvatarUrl}}" class="login-avatar-img" src="{{loginAvatarUrl}}" mode="aspectFill" />
          <view wx:else class="login-avatar-placeholder">
            <text class="login-avatar-add">+</text>
          </view>
          <view class="login-avatar-edit">选择头像</view>
        </button>
      </view>

      <!-- 昵称输入 -->
      <view class="login-nickname-area">
        <input class="login-nickname-input" type="nickname" placeholder="点击获取微信昵称"
               value="{{loginNickname}}" bindblur="onNicknameInput" bindconfirm="onNicknameInput"
               focus="{{autoFocusNickname}}" />
      </view>

      <!-- 确认按钮 -->
      <view class="login-confirm-btn" bindtap="onConfirmLogin">
        <text>确认开启</text>
      </view>

      <!-- 跳过 -->
      <view class="login-skip" bindtap="onSkipLogin">暂不设置，直接体验</view>
    </view>
  </view>

  <!-- 浮动 蜕变 入口 -->
  <view class="beauty-fab" bindtap="onGoBeautyPlan" hover-class="beauty-fab-hover">
    <text class="beauty-fab-text">蜕变</text>
  </view>

</view>