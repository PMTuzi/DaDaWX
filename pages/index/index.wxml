<!--pages/index/index.wxml-->
<wxs module="util">
  function cleanAge(s) {
    if (!s) return '';
    var t = s + '';
    while (t.length >= 2 && t.substring(0, 2) === '视龄') {
      t = t.substring(2);
      if (t.length > 0 && t.substring(0, 1) === '·') t = t.substring(1);
    }
    return '视龄·' + t;
  }
  module.exports = { cleanAge: cleanAge };
</wxs>
<view class="page-index {{hasReport ? 'page-index-diag' : 'page-index-undiag'}}">
  <!-- 顶部后台任务进度条 -->
  <view class="task-bar task-bar-{{diagnoseTask.status}}" wx:if="{{diagnoseTask}}" bindtap="onTapDiagnoseTask">
    <view class="task-bar-row">
      <text class="task-bar-dot"></text>
      <text class="task-bar-label">{{diagnoseTask.label || 'AI 形象诊断中'}}</text>
      <text class="task-bar-progress" wx:if="{{diagnoseTask.status === 'running'}}">{{diagnoseTask.progress}}%</text>
      <text class="task-bar-cta" wx:if="{{diagnoseTask.status === 'done'}}">查看 ›</text>
      <text class="task-bar-cta task-bar-cta-error" wx:if="{{diagnoseTask.status === 'error'}}">查看错误 ›</text>
    </view>
    <view class="task-bar-track">
      <view class="task-bar-fill" style="width: {{diagnoseTask.status === 'running' ? diagnoseTask.progress : 100}}%"></view>
    </view>
  </view>

  <!-- 顶部品牌区（已诊断态保留小尺寸） -->
  <view class="header {{hasReport ? 'header-diagnosed' : ''}}">
    <view class="brand-area {{hasReport ? 'brand-area-small' : ''}}">
      <view class="brand-text">
        <view class="logo">美哒 Meeta</view>
        <view class="slogan" wx:if="{{!hasReport}}">{{slogan}}</view>
      </view>
    </view>
  </view>

  <!-- ==================== 已诊断态：直接展示完整报告详情 ==================== -->
  <view class="diag-report" wx:if="{{hasReport && latestReport}}">
    <!-- 综合评分头部 -->
    <view class="report-header">
      <view class="header-bg"></view>
      <view class="dr-percentile dr-percentile-title" wx:if="{{latestReport.basic.percentile != null}}">
        <text class="percentile-icon">▲</text>
        <text class="percentile-text">颜值打败 <text class="percentile-num">{{latestReport.basic.percentile}}%</text> 的人</text>
      </view>
      <view class="header-content">
        <view class="avatar-main">
          <image class="avatar-main-img" src="{{latestReport.photoUrl}}" mode="aspectFill" binderror="onAvatarError" wx:if="{{latestReport.photoUrl}}" />
          <text class="avatar-main-fallback" wx:else>Me</text>
        </view>
        <view class="header-info">
          <view class="dr-score-row">
            <view class="dr-score-num-group">
              <text class="dr-score-big">{{latestReport.basic.overallScore}}</text>
              <text class="dr-score-suffix">/10</text>
            </view>
            <block wx:for="{{latestReport.basic.tags}}" wx:key="*this" wx:for-item="t" wx:for-index="i">
              <view class="htag-age" wx:if="{{(t && t.indexOf('视龄') === 0) || i === latestReport.basic.tags.length - 1}}">
                <text class="htag-age-icon">✦</text>
                <text class="htag-age-text">{{util.cleanAge(t)}}</text>
              </view>
            </block>
          </view>
          <view class="header-tags">
            <block wx:for="{{latestReport.basic.tags}}" wx:key="*this" wx:for-item="t" wx:for-index="i">
              <text class="htag" wx:if="{{t && t.indexOf('视龄') !== 0 && i !== latestReport.basic.tags.length - 1}}">{{t}}</text>
            </block>
          </view>
        </view>
      </view>
      <view class="header-summary" wx:if="{{latestReport.modules.optimize.coreConclusion}}">
        <text class="summary-text">{{latestReport.modules.optimize.coreConclusion}}</text>
      </view>
    </view>

    <!-- Tab导航（sticky 锁在模块内容上方）+ 右侧分享胶囊 -->
    <view class="dr-tab-bar">
      <view class="dr-tab-item {{activeTab === 'impression' ? 'active' : ''}}" data-tab="impression" bindtap="onTabTap">
        <text class="dr-tab-label">第一印象</text>
      </view>
      <view class="dr-tab-item {{activeTab === 'celebrity' ? 'active' : ''}}" data-tab="celebrity" bindtap="onTabTap">
        <text class="dr-tab-label">明星风格</text>
      </view>
      <view class="dr-tab-item {{activeTab === 'optimize' ? 'active' : ''}}" data-tab="optimize" bindtap="onTabTap">
        <text class="dr-tab-label">颜值蜕变</text>
      </view>
      <view class="dr-tab-item {{activeTab === 'hairmakeup' ? 'active' : ''}}" data-tab="hairmakeup" bindtap="onTabTap">
        <text class="dr-tab-label">发型妆容</text>
      </view>
      <view class="dr-tab-item {{activeTab === 'dna' ? 'active' : ''}}" data-tab="dna" bindtap="onTabTap">
        <text class="dr-tab-label">面部骨相</text>
      </view>
      <view class="dr-tab-item {{activeTab === 'style' ? 'active' : ''}}" data-tab="style" bindtap="onTabTap">
        <text class="dr-tab-label">色彩风格</text>
      </view>
    </view>

    <!-- 模块: 第一印象 · 魅力六边形 -->
    <view class="module-content" wx:if="{{activeTab === 'impression' && latestReport.modules.impression}}">
      <view class="section-card impression-card">
        <view class="section-title">第一印象 · {{latestReport.modules.impression.persona ? latestReport.modules.impression.persona.animal + '型' : '魅力六边形'}}</view>
        <view class="impression-index">
          <view class="impr-idx-ring">
            <view class="impr-idx-num-wrap">
              <text class="impr-idx-num">{{latestReport.modules.impression.attractIndex}}</text>
              <text class="impr-idx-unit">/100</text>
            </view>
            <text class="impr-idx-label">吸引力指数</text>
          </view>
          <view class="impr-idx-meta">
            <text class="impr-idx-tag">ATTRACTION INDEX</text>
            <view class="impr-idx-percentile" wx:if="{{latestReport.modules.impression.percentile}}">
              <text class="impr-idx-percent-icon">▲</text>
              <text>击败 <text class="impr-idx-percent-num">{{latestReport.modules.impression.percentile}}%</text> 的同龄人</text>
            </view>
          </view>
        </view>
        <!-- 第一印象人格标签 · 9 型 -->
        <view class="impression-persona" wx:if="{{latestReport.modules.impression.persona}}">
          <view class="persona-badge">
            <text class="persona-badge-label">第一印象人格</text>
          </view>
          <view class="persona-main">
            <image class="persona-photo" src="{{latestReport.modules.impression.persona.image}}" mode="aspectFill" wx:if="{{latestReport.modules.impression.persona.image}}" />
            <text class="persona-emoji" wx:else>{{latestReport.modules.impression.persona.emoji}}</text>
            <view class="persona-text">
              <view class="persona-name-row">
                <text class="persona-animal">{{latestReport.modules.impression.persona.animal}}</text>
                <text class="persona-divider">｜</text>
                <text class="persona-style">{{latestReport.modules.impression.persona.style}}</text>
              </view>
              <text class="persona-tagline">{{latestReport.modules.impression.persona.tagline}}</text>
            </view>
          </view>
          <view class="persona-traits">
            <text class="persona-trait" wx:for="{{latestReport.modules.impression.persona.traits}}" wx:key="*this" wx:for-item="tr"># {{tr}}</text>
          </view>
        </view>
        <view class="radar-wrap">
          <canvas type="2d" id="radar-impression" class="radar-canvas"></canvas>
        </view>
        <view class="sub-section">
          <view class="sub-title">六维评分</view>
          <view class="dr-score-list">
            <view class="dr-feature-row" wx:for="{{latestReport.modules.impression.scores}}" wx:key="key">
              <text class="dr-feature-name impr-feat-name">{{item.name}}</text>
              <view class="dr-bar-wrap">
                <view class="dr-bar-bg">
                  <view class="dr-bar-fill impr-bar-fill" style="width: {{item.score * 10}}%;"></view>
                </view>
              </view>
              <text class="dr-feature-val impr-feat-val">{{item.score}}</text>
            </view>
          </view>
        </view>
        <view class="sub-section">
          <view class="sub-title">维度解析 · 你的形象原因</view>
          <view class="impression-desc">
            <view class="impr-desc-item" wx:for="{{latestReport.modules.impression.scores}}" wx:key="key">
              <view class="impr-desc-head">
                <text class="impr-desc-name">{{item.name}}</text>
                <text class="impr-desc-score">{{item.score}}/10</text>
              </view>
              <text class="impr-desc-sub">{{item.desc}}</text>
              <text class="impr-desc-text">{{item.reason}}</text>
            </view>
          </view>
        </view>
        <view class="insight-card" wx:if="{{latestReport.modules.impression.keyInsight}}">
          <text class="insight-icon">✦</text>
          <text class="insight-content">{{latestReport.modules.impression.keyInsight}}</text>
        </view>
      </view>
    </view>

    <!-- 模块: 面部骨相 -->
    <view class="module-content" wx:if="{{activeTab === 'dna' && latestReport.modules.dna}}">
      <view class="section-card">
        <view class="section-title">面部骨相诊断</view>
        <view class="tags-row">
          <text class="info-tag">{{latestReport.modules.dna.faceType}}</text>
          <text class="info-tag accent">{{latestReport.modules.dna.boneType}}</text>
        </view>
        <view class="radar-wrap">
          <canvas type="2d" id="radar-dna" class="radar-canvas"></canvas>
        </view>
        <view class="sub-section">
          <view class="sub-title">三庭五眼比例</view>
          <view class="proportion-bar" wx:if="{{latestReport.modules.dna.threeCourts}}">
            <view class="prop-segment upper" style="flex:1;">
              <text class="prop-label">上庭</text>
              <text class="prop-val">{{latestReport.modules.dna.threeCourts.balance === '上长' ? '偏长' : latestReport.modules.dna.threeCourts.balance === '均衡' ? '均衡' : '偏短'}}</text>
            </view>
            <view class="prop-segment middle" style="flex:1;">
              <text class="prop-label">中庭</text>
              <text class="prop-val">{{latestReport.modules.dna.threeCourts.balance === '中长' ? '偏长' : '均衡'}}</text>
            </view>
            <view class="prop-segment lower" style="flex:1;">
              <text class="prop-label">下庭</text>
              <text class="prop-val">{{latestReport.modules.dna.threeCourts.balance === '下长' ? '偏长' : '均衡'}}</text>
            </view>
          </view>
          <view class="insight-text" wx:if="{{latestReport.modules.dna.threeCourts}}"><text>上庭：{{latestReport.modules.dna.threeCourts.upper}}</text></view>
          <view class="insight-text" wx:if="{{latestReport.modules.dna.threeCourts}}"><text>中庭：{{latestReport.modules.dna.threeCourts.middle}}</text></view>
          <view class="insight-text" wx:if="{{latestReport.modules.dna.threeCourts}}"><text>下庭：{{latestReport.modules.dna.threeCourts.lower}}</text></view>
          <view class="insight-text" wx:if="{{latestReport.modules.dna.fiveEyes}}"><text>五眼：{{latestReport.modules.dna.fiveEyes.analysis}}</text></view>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.dna.faceFeatures}}">
          <view class="sub-title">五官评分</view>
          <view class="dr-score-list">
            <view class="dr-feature-row" wx:for="{{latestReport.modules.dna.faceFeatures}}" wx:key="name">
              <text class="dr-feature-name">{{item.name}}</text>
              <view class="dr-bar-wrap">
                <view class="dr-bar-bg">
                  <view class="dr-bar-fill" style="width: {{item.score * 10}}%;"></view>
                </view>
              </view>
              <text class="dr-feature-val">{{item.score}}</text>
            </view>
          </view>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.dna.lineStyle}}">
          <view class="sub-title">面部线条风格</view>
          <text class="body-text">{{latestReport.modules.dna.lineStyle}}</text>
        </view>
        <view class="insight-card" wx:if="{{latestReport.modules.dna.keyInsight}}">
          <text class="insight-icon">✦</text>
          <text class="insight-content">{{latestReport.modules.dna.keyInsight}}</text>
        </view>
      </view>
    </view>

    <!-- 模块: 色彩风格 -->
    <view class="module-content" wx:if="{{activeTab === 'style' && latestReport.modules.style}}">
      <view class="section-card">
        <view class="section-title">色彩风格诊断</view>
        <view class="tags-row">
          <text class="info-tag">{{latestReport.modules.style.skinType}}</text>
          <text class="info-tag accent">{{latestReport.modules.style.season}}</text>
          <text class="info-tag accent2">{{latestReport.modules.style.mainStyle}}</text>
        </view>
        <view class="radar-wrap">
          <canvas type="2d" id="radar-style" class="radar-canvas"></canvas>
        </view>
        <view class="sub-section">
          <view class="sub-title">肤色属性</view>
          <view class="attr-grid">
            <view class="attr-item"><text class="attr-label">明度</text><text class="attr-val">{{latestReport.modules.style.brightness}}/10</text></view>
            <view class="attr-item"><text class="attr-label">纯度</text><text class="attr-val">{{latestReport.modules.style.purity}}/10</text></view>
            <view class="attr-item"><text class="attr-label">量感</text><text class="attr-val">{{latestReport.modules.style.mass}}/10</text></view>
          </view>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.style.goodColors}}">
          <view class="sub-title">本命色卡</view>
          <view class="color-grid">
            <view class="color-item" wx:for="{{latestReport.modules.style.goodColors}}" wx:key="name">
              <view class="color-swatch" style="background: {{item.hex}};"></view>
              <text class="color-name">{{item.name}}</text>
              <text class="color-usage">{{item.usage}}</text>
            </view>
          </view>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.style.badColors && latestReport.modules.style.badColors.length}}">
          <view class="sub-title warn">避雷色</view>
          <view class="color-grid warn">
            <view class="color-item" wx:for="{{latestReport.modules.style.badColors}}" wx:key="name">
              <view class="color-swatch" style="background: {{item.hex}}; opacity: 0.5;"></view>
              <text class="color-name">{{item.name}}</text>
              <text class="color-usage">{{item.reason}}</text>
            </view>
          </view>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.style.colorPalette}}">
          <view class="sub-title">色彩搭配方案</view>
          <view class="palette-group">
            <view class="palette-row" wx:if="{{latestReport.modules.style.colorPalette.primary}}">
              <text class="palette-label">主色调</text>
              <view class="palette-tags">
                <text class="palette-tag" wx:for="{{latestReport.modules.style.colorPalette.primary}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
            <view class="palette-row" wx:if="{{latestReport.modules.style.colorPalette.secondary}}">
              <text class="palette-label">辅助色</text>
              <view class="palette-tags">
                <text class="palette-tag" wx:for="{{latestReport.modules.style.colorPalette.secondary}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
            <view class="palette-row" wx:if="{{latestReport.modules.style.colorPalette.neutral}}">
              <text class="palette-label">中性色</text>
              <view class="palette-tags">
                <text class="palette-tag" wx:for="{{latestReport.modules.style.colorPalette.neutral}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
            <view class="palette-row" wx:if="{{latestReport.modules.style.colorPalette.accent}}">
              <text class="palette-label">点缀色</text>
              <view class="palette-tags">
                <text class="palette-tag" wx:for="{{latestReport.modules.style.colorPalette.accent}}" wx:key="*this">{{item}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.style.clothingAdvice}}">
          <view class="sub-title">穿搭建议</view>
          <view class="advice-list">
            <view class="advice-item" wx:if="{{latestReport.modules.style.clothingAdvice.silhouette}}">
              <text class="advice-label">版型</text>
              <image class="advice-thumb" wx:if="{{cdnImages.advice.silhouette}}" src="{{cdnImages.advice.silhouette}}" mode="aspectFill" data-key="advice" data-sub="silhouette" binderror="onCdnImgError" />
              <text class="advice-text">{{latestReport.modules.style.clothingAdvice.silhouette}}</text>
            </view>
            <view class="advice-item" wx:if="{{latestReport.modules.style.clothingAdvice.material}}">
              <text class="advice-label">材质</text>
              <image class="advice-thumb" wx:if="{{cdnImages.advice.material}}" src="{{cdnImages.advice.material}}" mode="aspectFill" data-key="advice" data-sub="material" binderror="onCdnImgError" />
              <text class="advice-text">{{latestReport.modules.style.clothingAdvice.material}}</text>
            </view>
            <view class="advice-item" wx:if="{{latestReport.modules.style.clothingAdvice.pattern}}">
              <text class="advice-label">图案</text>
              <image class="advice-thumb" wx:if="{{cdnImages.advice.pattern}}" src="{{cdnImages.advice.pattern}}" mode="aspectFill" data-key="advice" data-sub="pattern" binderror="onCdnImgError" />
              <text class="advice-text">{{latestReport.modules.style.clothingAdvice.pattern}}</text>
            </view>
          </view>
        </view>
        <view class="insight-card" wx:if="{{latestReport.modules.style.keyInsight}}">
          <text class="insight-icon">✦</text>
          <text class="insight-content">{{latestReport.modules.style.keyInsight}}</text>
        </view>
      </view>
    </view>

    <!-- 模块: 发型妆容 -->
    <view class="module-content" wx:if="{{activeTab === 'hairmakeup' && latestReport.modules.hairmakeup}}">
      <view class="section-card">
        <view class="section-title">发型妆容诊断</view>
        <view class="radar-wrap">
          <canvas type="2d" id="radar-hairmakeup" class="radar-canvas"></canvas>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.hairmakeup.hairRecommend.top3.length}}">
          <view class="sub-title">推荐发型 TOP3</view>
          <view class="hair-list">
            <view class="hair-card" wx:for="{{latestReport.modules.hairmakeup.hairRecommend.top3}}" wx:key="name">
              <view class="hair-rank">{{index + 1}}</view>
              <image class="hair-thumb" wx:if="{{cdnImages.hair[index]}}" src="{{cdnImages.hair[index]}}" mode="aspectFill" data-key="hair" data-idx="{{index}}" binderror="onCdnImgError" />
              <view class="hair-info">
                <view class="hair-name-row">
                  <text class="hair-name">{{item.name}}</text>
                  <text class="hair-score">{{item.score}}/10</text>
                </view>
                <text class="hair-detail" wx:if="{{item.length}}">{{item.length}} · {{item.bangs || '无刘海'}}</text>
                <text class="hair-reason">{{item.reason}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.hairmakeup.hairRecommend.hairColors.length}}">
          <view class="sub-title">适配发色</view>
          <view class="color-grid">
            <view class="color-item" wx:for="{{latestReport.modules.hairmakeup.hairRecommend.hairColors}}" wx:key="name">
              <view class="color-swatch" style="background: {{item.hex}};" wx:if="{{item.hex}}"></view>
              <view class="color-swatch hair" wx:else></view>
              <text class="color-name">{{item.name}}</text>
              <text class="color-usage">{{item.detail}}</text>
            </view>
          </view>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.hairmakeup.hairRecommend.avoidHair.length}}">
          <view class="sub-title warn">避雷发型</view>
          <view class="avoid-list">
            <view class="avoid-item" wx:for="{{latestReport.modules.hairmakeup.hairRecommend.avoidHair}}" wx:key="name">
              <text class="avoid-x">✕</text>
              <view class="avoid-info">
                <text class="avoid-name">{{item.name}}</text>
                <text class="avoid-reason">{{item.reason}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.hairmakeup.makeup}}">
          <view class="sub-title">妆容方案 · {{latestReport.modules.hairmakeup.makeup.style}}</view>
          <view class="makeup-grid" wx:if="{{latestReport.modules.hairmakeup.makeup.foundation}}">
            <view class="makeup-item">
              <text class="makeup-label">粉底</text>
              <image class="makeup-thumb" wx:if="{{cdnImages.makeup.foundation}}" src="{{cdnImages.makeup.foundation}}" mode="aspectFill" data-key="makeup" data-sub="foundation" binderror="onCdnImgError" />
              <text class="makeup-text">{{latestReport.modules.hairmakeup.makeup.foundation.tone}} · {{latestReport.modules.hairmakeup.makeup.foundation.shade}}</text>
            </view>
            <view class="makeup-item" wx:if="{{latestReport.modules.hairmakeup.makeup.eyeBrow}}">
              <text class="makeup-label">眉眼</text>
              <image class="makeup-thumb" wx:if="{{cdnImages.makeup.eyeBrow}}" src="{{cdnImages.makeup.eyeBrow}}" mode="aspectFill" data-key="makeup" data-sub="eyeBrow" binderror="onCdnImgError" />
              <text class="makeup-text">{{latestReport.modules.hairmakeup.makeup.eyeBrow.shape}} · {{latestReport.modules.hairmakeup.makeup.eyeBrow.shadow}}</text>
            </view>
            <view class="makeup-item" wx:if="{{latestReport.modules.hairmakeup.makeup.lipRecommend}}">
              <text class="makeup-label">唇妆</text>
              <image class="makeup-thumb" wx:if="{{cdnImages.makeup.lipRecommend}}" src="{{cdnImages.makeup.lipRecommend}}" mode="aspectFill" data-key="makeup" data-sub="lipRecommend" binderror="onCdnImgError" />
              <text class="makeup-text">{{latestReport.modules.hairmakeup.makeup.lipRecommend.destiny}}</text>
            </view>
            <view class="makeup-item" wx:if="{{latestReport.modules.hairmakeup.makeup.blush}}">
              <text class="makeup-label">腮红</text>
              <image class="makeup-thumb" wx:if="{{cdnImages.makeup.blush}}" src="{{cdnImages.makeup.blush}}" mode="aspectFill" data-key="makeup" data-sub="blush" binderror="onCdnImgError" />
              <text class="makeup-text">{{latestReport.modules.hairmakeup.makeup.blush.color}} · {{latestReport.modules.hairmakeup.makeup.blush.position}}</text>
            </view>
          </view>
        </view>
        <view class="insight-card" wx:if="{{latestReport.modules.hairmakeup.keyInsight}}">
          <text class="insight-icon">✦</text>
          <text class="insight-content">{{latestReport.modules.hairmakeup.keyInsight}}</text>
        </view>
      </view>
    </view>

    <!-- 模块: 颜值蜕变 -->
    <view class="module-content" wx:if="{{activeTab === 'optimize' && latestReport.modules.optimize}}">
      <view class="section-card">
        <view class="section-title">蜕变建议报告</view>
        <view class="radar-wrap">
          <canvas type="2d" id="radar-optimize" class="radar-canvas"></canvas>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.optimize.optimizablePoints.length}}">
          <view class="sub-title">优化优先级</view>
          <view class="optimize-list">
            <view class="optimize-item" wx:for="{{latestReport.modules.optimize.optimizablePoints}}" wx:key="area">
              <view class="optimize-priority {{item.priority === '高' ? 'high' : item.priority === '中' ? 'mid' : 'low'}}">{{item.priority}}</view>
              <view class="optimize-info">
                <view class="optimize-top">
                  <text class="optimize-area">{{item.area}}</text>
                  <text class="optimize-timeline">{{item.timeline}}</text>
                </view>
                <text class="optimize-problem">{{item.problem}}</text>
                <text class="optimize-plan">{{item.conservativePlan}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.optimize.roadmap3m}}">
          <view class="sub-title">3个月蜕变路线</view>
          <view class="roadmap">
            <view class="roadmap-item" wx:if="{{latestReport.modules.optimize.roadmap3m.month1}}">
              <view class="roadmap-dot"></view><view class="roadmap-line"></view>
              <view class="roadmap-content">
                <view class="roadmap-head">
                  <text class="roadmap-month">第1个月</text>
                  <image class="roadmap-thumb" wx:if="{{cdnImages.roadmap[0]}}" src="{{cdnImages.roadmap[0]}}" mode="aspectFill" data-key="roadmap" data-idx="0" binderror="onCdnImgError" />
                </view>
                <text class="roadmap-desc">{{latestReport.modules.optimize.roadmap3m.month1}}</text>
              </view>
            </view>
            <view class="roadmap-item" wx:if="{{latestReport.modules.optimize.roadmap3m.month2}}">
              <view class="roadmap-dot"></view><view class="roadmap-line"></view>
              <view class="roadmap-content">
                <view class="roadmap-head">
                  <text class="roadmap-month">第2个月</text>
                  <image class="roadmap-thumb" wx:if="{{cdnImages.roadmap[1]}}" src="{{cdnImages.roadmap[1]}}" mode="aspectFill" data-key="roadmap" data-idx="1" binderror="onCdnImgError" />
                </view>
                <text class="roadmap-desc">{{latestReport.modules.optimize.roadmap3m.month2}}</text>
              </view>
            </view>
            <view class="roadmap-item" wx:if="{{latestReport.modules.optimize.roadmap3m.month3}}">
              <view class="roadmap-dot"></view>
              <view class="roadmap-content">
                <view class="roadmap-head">
                  <text class="roadmap-month">第3个月</text>
                  <image class="roadmap-thumb" wx:if="{{cdnImages.roadmap[2]}}" src="{{cdnImages.roadmap[2]}}" mode="aspectFill" data-key="roadmap" data-idx="2" binderror="onCdnImgError" />
                </view>
                <text class="roadmap-desc">{{latestReport.modules.optimize.roadmap3m.month3}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="sub-section" wx:if="{{latestReport.modules.optimize.coreConclusion}}">
          <view class="sub-title">核心结论</view>
          <text class="body-text">{{latestReport.modules.optimize.coreConclusion}}</text>
        </view>
        <view class="insight-card" wx:if="{{latestReport.modules.optimize.keyInsight}}">
          <text class="insight-icon">✦</text>
          <text class="insight-content">{{latestReport.modules.optimize.keyInsight}}</text>
        </view>
      </view>
    </view>

    <!-- 模块: 明星相似度 -->
    <view class="module-content" wx:if="{{activeTab === 'celebrity'}}">
      <view class="section-card" wx:if="{{latestReport.modules.celebrity && latestReport.modules.celebrity.top5 && latestReport.modules.celebrity.top5.length}}">
        <view class="section-title">明星相似度分析</view>
        <view class="celeb-subtitle">基于面部骨相、五官比例与气质类型综合匹配</view>
        <view class="celeb-list">
          <view class="celeb-item" wx:for="{{latestReport.modules.celebrity.top5}}" wx:key="name" wx:for-index="ci">
            <view class="celeb-rank rank-{{ci + 1}}">
              <text class="celeb-rank-text">{{ci + 1}}</text>
            </view>
            <view class="celeb-info">
              <view class="celeb-name-row">
                <text class="celeb-name">{{item.name}}</text>
                <view class="celeb-similarity-badge">
                  <text class="celeb-similarity-num">{{item.similarity}}</text>
                  <text class="celeb-similarity-unit">%</text>
                </view>
              </view>
              <view class="celeb-bar-wrap">
                <view class="celeb-bar-fill" style="width: {{item.similarity}}%"></view>
              </view>
              <view class="celeb-match" wx:if="{{item.matchPoint}}">
                <text class="celeb-match-label">相似点</text>
                <text class="celeb-match-text">{{item.matchPoint}}</text>
              </view>
            </view>
          </view>
        </view>
        <view class="insight-card" wx:if="{{latestReport.modules.celebrity.keyInsight}}">
          <text class="insight-icon">✦</text>
          <text class="insight-content">{{latestReport.modules.celebrity.keyInsight}}</text>
        </view>
      </view>
      <view class="section-card" wx:if="{{!latestReport.modules.celebrity || !latestReport.modules.celebrity.top5 || !latestReport.modules.celebrity.top5.length}}">
        <view class="section-title">明星相似度分析</view>
        <view class="celeb-empty">
          <text class="celeb-empty-icon">◈</text>
          <text class="celeb-empty-text">本次报告暂未生成明星相似度数据，重新诊断后即可查看 Top 3 相似明星。</text>
        </view>
      </view>
    </view>

    <!-- 保存图片用的隐藏Canvas -->
    <canvas type="2d" id="report-card-canvas" class="report-card-canvas"></canvas>

    <!-- 报告末尾流式操作收尾区 -->
    <view class="report-actions">
      <view class="report-actions-tip" wx:if="{{!shared}}">
        <text class="report-actions-tip-icon">↗</text>
        <text>转发任意聊天即可解锁保存与重新诊断</text>
      </view>
      <view class="report-actions-row" wx:if="{{shared}}">
        <button class="report-action-btn save" bindtap="onSaveAllImages">
          <text class="report-action-icon">⤓</text>
          <text class="report-action-text">保存形象诊断卡</text>
        </button>
        <button class="report-action-btn redo" bindtap="onReDiagnose">
          <text class="report-action-icon">↻</text>
          <text class="report-action-text">重新拍照诊断</text>
        </button>
      </view>
      <view class="report-actions-row" wx:else>
        <button class="report-action-btn save locked" open-type="share">
          <text class="report-action-icon">↗</text>
          <text class="report-action-text">转发解锁·保存</text>
        </button>
        <button class="report-action-btn redo locked" open-type="share">
          <text class="report-action-icon">↗</text>
          <text class="report-action-text">转发解锁·重测</text>
        </button>
      </view>
    </view>
  </view>

  <!-- ==================== 未诊断态：宣传视频 ==================== -->
  <view class="intro-video" wx:if="{{!hasReport}}" bindtap="onStartDiagnose" hover-class="intro-video-hover">
    <video
      wx:if="{{introVideoVisible}}"
      class="intro-video-player"
      id="introVideo"
      src="cloud://dada-d9gw8x8fb426caba5.6461-dada-d9gw8x8fb426caba5-1435078506/home-intro-v2.mp4"
      object-fit="cover"
      autoplay="{{true}}"
      loop="{{true}}"
      muted="{{true}}"
      controls="{{false}}"
      show-center-play-btn="{{false}}"
      show-play-btn="{{false}}"
      show-fullscreen-btn="{{false}}"
      enable-progress-gesture="{{false}}"
      show-progress="{{false}}"
      binderror="onIntroVideoError"
      bindplay="onIntroVideoPlay"
      bindloadedmetadata="onIntroVideoLoaded"
    ></video>
    <view class="tech-overlay" catchtap="onStartDiagnose">
      <view class="tech-cta">
        <view class="tech-cta-main">
          <text class="tech-arrow">▸</text>
          <text class="tech-cta-text">点击开启 · 形象风格分析</text>
          <text class="tech-arrow tech-arrow-rev">◂</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 核心入口 -->
  <view class="action-area {{hasReport ? '' : 'action-area-undiag'}}" wx:if="{{!hasReport}}">
    <view class="live-ticker">
      <swiper class="ticker-swiper" vertical autoplay circular interval="3000" duration="500">
        <swiper-item wx:for="{{tickerList}}" wx:key="index">
          <text class="ticker-text">{{item}}</text>
        </swiper-item>
      </swiper>
    </view>
  </view>

  <!-- 登录确认弹窗 -->
  <view class="login-modal-mask" wx:if="{{showLoginModal}}" bindtap="onCloseLoginModal">
    <view class="login-modal" catchtap="onPreventBubble">
      <view class="login-modal-title">完善个人信息</view>
      <view class="login-modal-desc">点击即可获取微信头像和昵称，也可自行编辑</view>
      <view class="login-avatar-area">
        <button class="login-avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image wx:if="{{loginAvatarUrl}}" class="login-avatar-img" src="{{loginAvatarUrl}}" mode="aspectFill" />
          <view wx:else class="login-avatar-placeholder">
            <text class="login-avatar-add">+</text>
          </view>
          <view class="login-avatar-edit">选择头像</view>
        </button>
      </view>
      <view class="login-nickname-area">
        <input class="login-nickname-input" type="nickname" placeholder="点击获取微信昵称"
               value="{{loginNickname}}" bindblur="onNicknameInput" bindconfirm="onNicknameInput"
               focus="{{autoFocusNickname}}" />
      </view>
      <view class="login-confirm-btn" bindtap="onConfirmLogin">
        <text>确认开启</text>
      </view>
      <view class="login-skip" bindtap="onSkipLogin">暂不设置，直接体验</view>
    </view>
  </view>

  <!-- 浮动 蜕变 入口（仅已诊断态） -->
  <view class="beauty-fab" wx:if="{{hasReport}}" bindtap="onGoBeautyPlan" hover-class="beauty-fab-hover">
    <text class="beauty-fab-text">蜕变</text>
  </view>

  <!-- 未诊断态：底部能力标签横向轮播 -->
  <view class="feature-marquee" wx:if="{{!hasReport}}">
    <view class="feature-marquee-row">
      <view class="feature-marquee-track">
        <view class="feature-chip" wx:for="{{featureTagsRow1}}" wx:key="*this" wx:for-item="ft">
          <text class="feature-chip-dot">◆</text>
          <text class="feature-chip-text">{{ft}}</text>
        </view>
        <view class="feature-chip" wx:for="{{featureTagsRow1}}" wx:key="*this" wx:for-item="ft">
          <text class="feature-chip-dot">◆</text>
          <text class="feature-chip-text">{{ft}}</text>
        </view>
      </view>
    </view>
    <view class="feature-marquee-row">
      <view class="feature-marquee-track feature-marquee-track-rev">
        <view class="feature-chip" wx:for="{{featureTagsRow2}}" wx:key="*this" wx:for-item="ft">
          <text class="feature-chip-dot">◆</text>
          <text class="feature-chip-text">{{ft}}</text>
        </view>
        <view class="feature-chip" wx:for="{{featureTagsRow2}}" wx:key="*this" wx:for-item="ft">
          <text class="feature-chip-dot">◆</text>
          <text class="feature-chip-text">{{ft}}</text>
        </view>
      </view>
    </view>
  </view>

</view>
